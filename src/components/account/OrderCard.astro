---
// ============================================================
//  OrderCard — compact order SUMMARY for list views (account
//  overview "Recent orders" + /account/orders). Shows the order
//  id, date, item count and total only — no product imagery or
//  rows. The full product breakdown lives on the detail page,
//  reached via "View order details".
// ============================================================
import Icon from '~/components/ui/Icon.astro';
import { formatMoney } from '~/lib/utils';
import type { CustomerOrder } from '~/lib/shopify/customer';

interface Props {
  order: CustomerOrder;
}

const { order } = Astro.props;

const fmtDate = (iso: string) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(
    new Date(iso),
  );

const items = order.lineItems?.nodes ?? [];
const unitCount = items.reduce((n, li) => n + (li.quantity || 0), 0);
const cancelled = Boolean(order.cancelledAt);

// Detail route keyed by the numeric id suffix (keeps GID slashes out of URLs).
const detailHref = `/account/orders/${order.id.split('/').pop()}`;
---

<article class="overflow-hidden rounded-xl bg-surface ring-1 ring-inset ring-border transition-fluid hover:shadow-xs">
  {/* Header — order id, date, item count, total */}
  <header class="flex flex-wrap items-center justify-between gap-x-4 gap-y-2 px-5 py-4">
    <div class="flex items-center gap-3">
      <span class="grid h-10 w-10 flex-none place-items-center rounded-full bg-coral-soft text-coral">
        <Icon name="package" size={18} />
      </span>
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <p class="font-heading text-[17px] font-bold leading-tight text-text-primary">{order.name}</p>
          {cancelled && (
            <span class="inline-flex items-center gap-1 rounded-full bg-surface-cool px-2 py-0.5 text-[10.5px] font-bold uppercase tracking-[0.8px] text-text-muted ring-1 ring-inset ring-border">
              <Icon name="close" size={11} /> Cancelled
            </span>
          )}
        </div>
        <p class="mt-0.5 flex items-center gap-1.5 text-[12.5px] text-text-muted">
          <Icon name="clock" size={13} /> {fmtDate(order.processedAt)}
          {unitCount > 0 && <span class="text-border">·</span>}
          {unitCount > 0 && (
            <span>{unitCount} item{unitCount === 1 ? '' : 's'}</span>
          )}
        </p>
      </div>
    </div>
    <div class="text-right">
      <p class="text-[10px] font-bold uppercase tracking-[1.4px] text-text-muted">Total</p>
      <p class:list={['font-heading text-[18px] font-extrabold tabular leading-tight', cancelled ? 'text-text-muted line-through' : 'text-text-primary']}>
        {order.totalPrice ? formatMoney(order.totalPrice.amount, order.totalPrice.currencyCode) : '—'}
      </p>
    </div>
  </header>

  {/* Footer — link to the full order detail */}
  <a
    href={detailHref}
    class="flex items-center justify-between gap-2 border-t border-border px-5 py-3 text-[12.5px] font-bold uppercase tracking-[1px] text-text-secondary transition-fluid hover:bg-surface-cool hover:text-coral"
  >
    View order details
    <Icon name="arrowRight" size={15} />
  </a>
</article>
