---
// ============================================================
//  ProductCard — a "catalogue specimen": numbered index, image
//  with hover zoom, vendor eyebrow, title, price. Whole card
//  links to the PDP (variant choices live there).
// ============================================================
import type { ProductCard as ProductCardType } from '~/lib/shopify/types';
import { discountPercent, isOnSale } from '~/lib/utils';
import Price from '~/components/ui/Price.astro';
import Badge from '~/components/ui/Badge.astro';
import Icon from '~/components/ui/Icon.astro';

interface Props {
  product: ProductCardType;
  index?: number;
  class?: string;
}

const { product, index, class: className = '' } = Astro.props;

const min = product.priceRange.minVariantPrice;
const max = product.priceRange.maxVariantPrice;
const compareAt = product.compareAtPriceRange?.minVariantPrice ?? null;
const onSale = isOnSale(min, compareAt);
const off = discountPercent(min, compareAt);
const ranged = min.amount !== max.amount;
const soldOut = !product.availableForSale;
---

<a
  href={`/products/${product.handle}`}
  class={`group block ${className}`}
  aria-label={product.title}
>
  <div class="relative aspect-square overflow-hidden rounded-lg border border-border bg-surface">
    {
      product.featuredImage ? (
        <img
          src={product.featuredImage.url}
          alt={product.featuredImage.altText ?? product.title}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.05]"
        />
      ) : (
        <div class="grid h-full place-items-center text-text-muted">No image</div>
      )
    }

    {/* Catalogue index marker */}
    {
      index != null && (
        <span class="absolute left-3 top-3 font-mono text-[0.7rem] text-text-secondary/70 tabular">
          {String(index + 1).padStart(2, '0')}
        </span>
      )
    }

    {/* Status badges. For a multi-variant price range the cheapest
        price and lowest compare-at can belong to different variants,
        so only show an exact %-off for a single price point. */}
    <div class="absolute right-3 top-3 flex flex-col items-end gap-1.5">
      {soldOut && <Badge tone="ink">Sold out</Badge>}
      {
        !soldOut &&
          onSale &&
          (!ranged && off != null ? <Badge tone="accent">−{off}%</Badge> : <Badge tone="accent">Sale</Badge>)
      }
    </div>

    {/* Hover view affordance */}
    <span
      class="pointer-events-none absolute bottom-3 right-3 flex translate-y-2 items-center gap-1 rounded-md bg-surface/90 px-2.5 py-1.5 text-xs font-medium text-text-primary opacity-0 backdrop-blur-sm transition-fluid group-hover:translate-y-0 group-hover:opacity-100"
    >
      View
      <Icon name="arrowUpRight" size={14} />
    </span>
  </div>

  <div class="mt-3 flex items-start justify-between gap-3">
    <div class="min-w-0">
      {product.vendor && <p class="text-[11px] font-bold uppercase tracking-[1.8px] truncate text-text-muted">{product.vendor}</p>}
      <h3 class="mt-0.5 truncate text-sm font-medium text-text-primary transition-fluid group-hover:text-coral">
        {product.title}
      </h3>
    </div>
    <Price
      price={min}
      compareAt={ranged ? null : compareAt}
      from={ranged}
      size="sm"
      class="shrink-0 pt-0.5"
    />
  </div>
</a>
