---
// Cursor-based Prev / Next pagination (SSR, no JS). Disabled
// edges render as non-interactive spans (no keyboard focus / no #).
import Icon from '~/components/ui/Icon.astro';

interface Props {
  prevUrl: string | null;
  nextUrl: string | null;
}
const { prevUrl, nextUrl } = Astro.props;

const cls =
  'inline-flex h-11 items-center gap-2 rounded-md border px-5 text-sm font-medium transition-fluid';
const active = 'border-border text-text-primary hover:border-dark';
const disabled = 'border-border/60 text-text-muted cursor-not-allowed';
---

{
  (prevUrl || nextUrl) && (
    <nav class="mt-14 flex items-center justify-center gap-3" aria-label="Pagination">
      {prevUrl ? (
        <a href={prevUrl} class={`${cls} ${active}`} rel="prev">
          <Icon name="chevronLeft" size={16} />
          Previous
        </a>
      ) : (
        <span class={`${cls} ${disabled}`} aria-disabled="true">
          <Icon name="chevronLeft" size={16} />
          Previous
        </span>
      )}

      {nextUrl ? (
        <a href={nextUrl} class={`${cls} ${active}`} rel="next">
          Next
          <Icon name="chevronRight" size={16} />
        </a>
      ) : (
        <span class={`${cls} ${disabled}`} aria-disabled="true">
          Next
          <Icon name="chevronRight" size={16} />
        </span>
      )}
    </nav>
  )
}
