---
// ============================================================
//  CatalogListing — on-brand PLP body: control deck (native
//  sort pills → ?sort=) + product grid + cursor pagination.
//  Filters from the mockup's refine panel are deferred; sort is
//  fully native against the live Shopify catalogue.
// ============================================================
import ProductCard from '~/components/cards/ProductCard.astro';
import Icon from '~/components/ui/Icon.astro';
import type { ProductCard as TProductCard } from '~/lib/shopify/types';

interface SortOption {
  value: string;
  label: string;
}
interface Props {
  products: TProductCard[];
  sortOptions: readonly SortOption[];
  sortValue: string;
  sortAction: string;
  prevUrl?: string | null;
  nextUrl?: string | null;
  countLabel: string;
  emptyTitle?: string;
  emptyBody?: string;
}

const {
  products,
  sortOptions,
  sortValue,
  sortAction,
  prevUrl = null,
  nextUrl = null,
  countLabel,
  emptyTitle = 'Nothing here yet',
  emptyBody = 'Try a different sort or check back soon.',
} = Astro.props;
---

<div class="container-mag pb-section">
  {/* Control deck */}
  <div class="mb-8 flex flex-col gap-4 border-b border-border pb-6 md:flex-row md:items-end md:justify-between">
    <div>
      <span class="mag-label mb-2">The Catalogue</span>
      <p class="text-[14px] text-text-secondary">{countLabel}</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <span class="mr-1 text-[11px] font-bold uppercase tracking-[1.5px] text-text-muted">Sort by</span>
      {
        sortOptions.map((o) => (
          <a
            href={`${sortAction}?sort=${o.value}`}
            class:list={[
              'rounded-pill px-4 py-2 text-[13px] font-semibold transition-fluid',
              o.value === sortValue
                ? 'bg-dark text-white'
                : 'bg-surface-cool text-text-primary hover:bg-coral hover:text-white',
            ]}
          >
            {o.label}
          </a>
        ))
      }
    </div>
  </div>

  {/* Grid */}
  {
    products.length ? (
      <div class="grid grid-cols-2 gap-5 md:grid-cols-3 md:gap-[22px] lg:grid-cols-4">
        {products.map((p, i) => (
          <div data-reveal>
            <ProductCard product={p} eager={i < 4} />
          </div>
        ))}
      </div>
    ) : (
      <div class="flex flex-col items-center py-24 text-center">
        <Icon name="search" size={28} class="text-text-muted" />
        <h3 class="h4 mt-4">{emptyTitle}</h3>
        <p class="mt-2 text-text-secondary">{emptyBody}</p>
      </div>
    )
  }

  {/* Pagination */}
  {
    (prevUrl || nextUrl) && (
      <div class="mt-14 flex items-center justify-center gap-3">
        <a
          href={prevUrl ?? '#'}
          aria-disabled={!prevUrl}
          class:list={[
            'inline-flex h-11 items-center gap-2 rounded-sm border border-border px-5 text-[13px] font-semibold transition-fluid',
            prevUrl ? 'hover:border-dark' : 'pointer-events-none opacity-40',
          ]}
        >
          <Icon name="chevronLeft" size={15} /> Previous
        </a>
        <a
          href={nextUrl ?? '#'}
          aria-disabled={!nextUrl}
          class:list={[
            'inline-flex h-11 items-center gap-2 rounded-sm border border-border px-5 text-[13px] font-semibold transition-fluid',
            nextUrl ? 'hover:border-dark' : 'pointer-events-none opacity-40',
          ]}
        >
          Next <Icon name="chevronRight" size={15} />
        </a>
      </div>
    )
  }
</div>
