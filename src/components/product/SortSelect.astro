---
// Sort control — native select inside a GET form (resets cursor on
// change). Extra params (e.g. search q) are preserved via hidden inputs.
import type { SortOption } from '~/lib/shopify/types';
import Icon from '~/components/ui/Icon.astro';

interface Props {
  options: SortOption[];
  value: string;
  action: string;
  hidden?: Record<string, string>;
}
const { options, value, action, hidden = {} } = Astro.props;
---

<form method="get" action={action} class="relative inline-flex items-center">
  {Object.entries(hidden).map(([k, v]) => <input type="hidden" name={k} value={v} />)}
  <label for="sort" class="text-[11px] font-bold uppercase tracking-[1.8px] sr-only">Sort</label>
  <div
    class="relative inline-flex items-center gap-2 rounded-md border border-border bg-surface pl-3 pr-2 transition-fluid hover:border-dark"
  >
    <span class="text-[11px] font-bold uppercase tracking-[1.8px] text-text-muted">Sort</span>
    <select
      id="sort"
      name="sort"
      onchange="this.form.submit()"
      class="h-10 cursor-pointer appearance-none bg-transparent pr-5 text-sm text-text-primary outline-none"
    >
      {
        options.map((o) => (
          <option value={o.value} selected={o.value === value}>
            {o.label}
          </option>
        ))
      }
    </select>
    <Icon name="chevronDown" size={15} class="pointer-events-none -ml-5 text-text-secondary" />
  </div>
</form>
