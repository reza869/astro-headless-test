---
// ============================================================
//  ProductDetail — 1:1 port of the designer's PDP (Product.html):
//  editorial hero, sticky gallery + buy box, customer reviews and
//  "you may also like". Real Shopify data drives the title, price,
//  images, colour/size options, variants and recommendations; the
//  add-to-bag / buy-now resolve the matching variant and hit the
//  live cart. Reviews are REAL Judge.me reviews (read server-side via
//  the REST API, rendered here in the PDP's own UI). All behaviour
//  lives in the bundled <script> below.
// ============================================================
import Icon from '~/components/ui/Icon.astro';
import ProductCard from '~/components/cards/ProductCard.astro';
import SizeGuide from '~/components/global/SizeGuide.astro';
import { SITE, freeShipThreshold } from '~/config/site';
import { formatMoney, discountPercent, parseGid } from '~/lib/utils';
import type { Product, ProductCard as TProductCard } from '~/lib/shopify/types';
import type { JudgeMeData } from '~/lib/judgeme';
import { JUDGEME_CONFIGURED } from '~/lib/judgeme';

interface Props {
  product: Product;
  recommendations: TProductCard[];
  /** Shopify COMPLEMENTARY recommendations — "goes well with" cross-sell (MP-20). */
  complementary?: TProductCard[];
  reviews: JudgeMeData | null;
}

const { product, recommendations, complementary = [], reviews } = Astro.props;

// ── Reviews summary (real Judge.me data) ────────────────────
const rv = reviews && reviews.count > 0 ? reviews : null;
const rvAvg = rv ? rv.average.toFixed(1) : null;
const rvCount = rv?.count ?? 0;
const fullStars = rv ? Math.round(rv.average) : 0;
const starRow = (n: number) => '★★★★★'.slice(0, n) + '☆☆☆☆☆'.slice(0, 5 - n);
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
// Numeric Shopify id Judge.me needs to attach a submitted review (MP-26).
const reviewProductId = parseGid(product.id);
// Only surface the write-a-review UI when Judge.me is actually configured
// (marketplace buyers without a token must not see a form that always fails).
const canWriteReview = JUDGEME_CONFIGURED && Boolean(reviewProductId);
const currency = product.priceRange.minVariantPrice.currencyCode;
const priceNow = formatMoney(product.priceRange.minVariantPrice.amount, currency);
const compareAt = product.compareAtPriceRange?.minVariantPrice ?? null;
const off = discountPercent(product.priceRange.minVariantPrice, compareAt);
const priceWas = compareAt ? formatMoney(compareAt.amount, currency) : null;

// ── Structured data ─────────────────────────────────────────
// Always emit a Product node with an `offers` object (price + availability +
// currency) so the PDP produces a valid product rich result even with zero
// reviews; merge aggregateRating/review only when real Judge.me reviews exist.
const productUrl = new URL(`/products/${product.handle}`, Astro.url.origin).href;
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.description || undefined,
  image: (product.images?.length
    ? product.images
    : product.featuredImage
      ? [product.featuredImage]
      : []
  )
    .map((i) => i.url)
    .slice(0, 8),
  brand: product.vendor ? { '@type': 'Brand', name: product.vendor } : undefined,
  url: productUrl,
  offers: {
    '@type': 'Offer',
    price: product.priceRange.minVariantPrice.amount,
    priceCurrency: currency,
    availability: product.availableForSale
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    url: productUrl,
  },
  ...(rv
    ? {
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: rv.average,
          reviewCount: rv.count,
        },
        review: rv.reviews.slice(0, 20).map((r) => ({
          '@type': 'Review',
          reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
          author: { '@type': 'Person', name: r.name },
          datePublished: r.createdAt,
          name: r.title,
          reviewBody: r.body,
        })),
      }
    : {}),
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.url.origin },
    { '@type': 'ListItem', position: 2, name: 'Shop', item: new URL('/collections/all', Astro.url.origin).href },
    { '@type': 'ListItem', position: 3, name: product.title, item: productUrl },
  ],
};

// Title → "lead <em>last.</em>" for the editorial hero.
const words = product.title.trim().split(/\s+/);
const titleLast = words.length > 1 ? words[words.length - 1] : product.title;
const titleLead = words.length > 1 ? words.slice(0, -1).join(' ') : '';

const category = product.productType || 'The Edit';
const intro = product.description || '';
// MP-18 — rich, merchant-authored description body (trusted store content).
const descriptionHtml = product.descriptionHtml?.trim() || '';

// MP-17 — visible breadcrumb trail (mirrors the BreadcrumbList JSON-LD).
const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Shop', href: '/collections/all' },
  { name: product.title, href: `/products/${product.handle}` },
];

// MP-21 — social share targets (Pinterest matters for fashion).
const shareUrl = productUrl;
const shareText = `${product.title}${product.vendor ? ` — ${product.vendor}` : ''}`;
const shareImage = product.featuredImage?.url ?? '';
const shareLinks = {
  x: `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareText)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`,
  pinterest: `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(shareUrl)}&media=${encodeURIComponent(shareImage)}&description=${encodeURIComponent(shareText)}`,
};

// MP-20 — complementary cross-sell, de-duplicated against the related rail.
const complementaryUnique = complementary
  .filter((c) => !recommendations.some((r) => r.id === c.id))
  .slice(0, 4);

// ── Editorial facts from metafields (all optional — the PDP hides the
// element when unset; no fabricated defaults). See README "Product metafields".
const mf = product.metafields ?? {};
// MP-22 — sale/drop countdown (only when the metafield is a valid future date).
const countdownIso =
  mf.countdown && !Number.isNaN(Date.parse(mf.countdown)) ? mf.countdown : null;
// MP-23 — promo code surfaced with copy-to-clipboard.
const promoCode = mf.promoCode?.trim() || null;
// MP-29 — per-product size guide from a metafield (falls back to <SizeGuide />).
const sizeGuideHtml = mf.sizeGuide?.trim() || '';
// MP-24 — personalization fields (one label per line in the metafield); each
// renders a text input whose value is attached as a cart line attribute.
const personalizationFields = (mf.personalization ?? '')
  .split('\n')
  .map((s) => s.trim())
  .filter(Boolean)
  .slice(0, 5);
const sku = product.variants.find((v) => v.sku)?.sku ?? null;
const soldCount = mf.unitsSold && Number.isFinite(Number(mf.unitsSold)) ? Number(mf.unitsSold) : null;
const isNew = mf.newBadge === 'true' || mf.newBadge === '1';
const fitBullets = [
  ...(mf.fitNotes ? mf.fitNotes.split('\n').map((s) => s.trim()).filter(Boolean) : []),
  ...(mf.modelNote ? [mf.modelNote] : []),
];
// Any materials/care fact present? Controls the whole accordion item.
const specRows = [
  ['Outer', mf.material],
  ['Lining', mf.lining],
  ['Weight', mf.weight],
  ['Origin', mf.origin],
  ['Care', mf.care],
].filter(([, v]) => Boolean(v)) as [string, string][];
// MP-18 — extra "Label: value" spec rows from a metafield (one per line).
const specMetaRows = (mf.specification ?? '')
  .split('\n')
  .map((line) => line.split(/:(.+)/).map((s) => s.trim()))
  .filter((pair) => pair[0] && pair[1])
  .map((pair) => [pair[0], pair[1]] as [string, string]);
// Whole "Materials & Care" accordion shows if we have any spec row or a SKU.
const hasSpecs = specRows.length > 0 || specMetaRows.length > 0 || Boolean(sku);
// Free-shipping threshold in the shopper's presentment currency. `null` (no
// threshold configured for this currency) drops the "over X" qualifier rather
// than formatting a USD number as if it were local.
const freeShipAmount = freeShipThreshold(currency);
const freeShip = freeShipAmount !== null ? formatMoney(freeShipAmount, currency) : '';

// Gallery images (fall back to the featured image).
const images =
  product.images.length > 0
    ? product.images
    : product.featuredImage
      ? [product.featuredImage]
      : [];

// MP-5 — product videos (hosted + external) surfaced as extra gallery slides.
const videos = (product.media ?? [])
  .filter((m) => m.type === 'video' || m.type === 'external_video')
  .map((m) => ({
    type: m.type,
    poster: m.previewImage?.url ?? '',
    embed: m.embeddedUrl ?? '',
    src: m.sources?.[0]?.url ?? '',
    mime: m.sources?.[0]?.mimeType ?? 'video/mp4',
  }))
  .filter((v) => v.src || v.embed);

// Swatch hexes for known colour names; falls back to the name as a CSS colour.
// Only used when the Shopify option value has no real swatch (MP-2).
const COLORS: Record<string, string> = {
  dark: '#2b2e31', black: '#1b1d1f', tan: '#c8b89a', cream: '#f1e7d6', ivory: '#f1e7d6',
  coral: '#d95846', green: '#5a9761', blue: '#4576e7', sand: '#cbb68f', gold: '#c9a227',
  slate: '#3a4250', charcoal: '#3a3d40', camel: '#c2a878', grey: '#8d969c', gray: '#8d969c',
  navy: '#22304a', white: '#f5f5f0', brown: '#6e5641', olive: '#6b6a44', stone: '#d8ccbb',
};
const swatchHex = (name: string) => COLORS[name.trim().toLowerCase()] ?? name.toLowerCase();

// Ignore Shopify's reserved single-variant placeholder option ("Title" with a
// lone "Default Title" value) — it isn't a real choice, so it must not render
// as a picker.
const realOptions = product.options.filter(
  (o) =>
    !(
      o.name === 'Title' &&
      o.optionValues.length === 1 &&
      /^default title$/i.test(o.optionValues[0]?.name ?? '')
    ),
);

const colorOption = realOptions.find((o) => /colou?r/i.test(o.name));
// Second picker = the Size option, or — for products optioned by Material,
// Style, Fit, etc. — the first non-colour option, so EVERY two-option product
// is fully selectable (not just Colour/Size). Products with a 3rd option fall
// back to their first two dimensions.
const sizeOption =
  realOptions.find((o) => /size/i.test(o.name)) ??
  realOptions.find((o) => o.name !== colorOption?.name);
// Only a real size picker gets the "Size guide" affordance.
const isSizeOption = !!sizeOption && /size/i.test(sizeOption.name);

// Which size values are buyable (some variant with that value is in stock).
const availableSizes = new Set<string>();
if (sizeOption) {
  for (const v of product.variants) {
    if (!v.availableForSale) continue;
    const sz = v.selectedOptions.find((o) => o.name === sizeOption.name)?.value;
    if (sz) availableSizes.add(sz);
  }
}

// MP-1 — a representative gallery image per colour (first in-stock variant with
// that colour that carries an image, falling back to any variant with one).
const imageForColor = new Map<string, string>();
if (colorOption) {
  for (const v of product.variants) {
    const cv = v.selectedOptions.find((o) => o.name === colorOption.name)?.value;
    if (cv && v.image?.url && !imageForColor.has(cv)) imageForColor.set(cv, v.image.url);
  }
}

// MP-2 — prefer the real Shopify swatch (colour or image) over the name map.
const colors = (colorOption?.optionValues ?? []).map((ov) => ({
  label: ov.name,
  hex: ov.swatch?.color ?? swatchHex(ov.name),
  image: ov.swatch?.image ?? null,
}));
const sizes = (sizeOption?.optionValues ?? []).map((ov) => ({
  label: ov.name,
  ok: availableSizes.has(ov.name),
}));

// Option B — mirror the product card: when the shopper has a real choice, don't
// pre-pick a variant. The PDP then opens on the featured image with a "From
// {min}" price (exactly what the card shows) and the shopper resolves a concrete
// variant. Only options with a single value (no real choice) are auto-selected,
// so genuinely single-variant products still add in one tap.
const soleValueOf = (opt: typeof colorOption) =>
  opt && opt.optionValues.length === 1 ? (opt.optionValues[0]?.name ?? '') : '';
const defaultColor = soleValueOf(colorOption);
const defaultSize = soleValueOf(sizeOption);
// Some option still needs a choice → headline shows "From {min}" and Add stays
// gated until a concrete variant is resolved.
const needsChoice = realOptions.some((o) => o.optionValues.length > 1);

// Compact variant index handed to the client to resolve a selection → id.
const variantData = product.variants.map((v) => ({
  id: v.id,
  available: v.availableForSale,
  color: colorOption ? (v.selectedOptions.find((o) => o.name === colorOption.name)?.value ?? '') : '',
  size: sizeOption ? (v.selectedOptions.find((o) => o.name === sizeOption.name)?.value ?? '') : '',
  amount: v.price.amount,
  compareAt: v.compareAtPrice?.amount ?? null,
  // MP-1 media swap + MP-7 low-stock messaging.
  img: v.image?.url ?? null,
  qty: typeof v.quantityAvailable === 'number' ? v.quantityAvailable : null,
  // MP-9 — sells while out of stock on a "continue" policy.
  continueSelling: v.currentlyNotInStock === true && v.availableForSale,
  // MP-10 — live SKU on variant change.
  sku: v.sku ?? null,
  // MP-8 — per-variant purchase rules (min / max / step).
  rule: v.quantityRule
    ? {
        min: v.quantityRule.minimum ?? 1,
        max: v.quantityRule.maximum ?? null,
        inc: v.quantityRule.increment ?? 1,
      }
    : null,
}));

const config = JSON.stringify({
  productId: product.id,
  currency,
  hasColor: !!colorOption,
  hasSize: !!sizeOption,
  defaultColor,
  defaultSize,
  unitAmount: product.priceRange.minVariantPrice.amount,
  // Low-stock threshold below which we surface "Only N left" (MP-7).
  lowStockThreshold: 10,
  variants: variantData,
  // MP-19 — snapshot recorded to localStorage so the recently-viewed rail can
  // render full ProductCard-parity cards (image, badges, actions, price).
  snapshot: {
    id: product.id,
    handle: product.handle,
    title: product.title,
    image: product.featuredImage?.url ?? images[0]?.url ?? '',
    price: product.priceRange.minVariantPrice.amount,
    compareAt: product.compareAtPriceRange?.minVariantPrice?.amount ?? null,
    vendor: product.vendor ?? '',
    currency,
    variantId: product.variants[0]?.id ?? null,
    available: product.availableForSale,
    requiresChoice: product.options
      .filter((o) => o.name !== 'Title')
      .some((o) => o.optionValues.length > 1),
    isNew,
  },
});

const addPriceLabel = formatMoney(
  Number(product.priceRange.minVariantPrice.amount),
  currency,
);

---

<div class="pdp-root" data-config={config}>
  {/* ===================== PRODUCT HERO ===================== */}
  <section class="shop-hero pdp-hero">
    <div class="container-mag">
      <nav class="pdp-crumbs" aria-label="Breadcrumb">
        {crumbs.map((c, i) => (
          <>
            {i > 0 && <span class="crumb-sep" aria-hidden="true"><Icon name="chevronRight" size={13} /></span>}
            {i < crumbs.length - 1 ? (
              <a href={c.href}>{c.name}</a>
            ) : (
              <span aria-current="page">{c.name}</span>
            )}
          </>
        ))}
      </nav>
      <span class="mag-label">{category}{product.vendor ? ` · ${product.vendor}` : ''}</span>
      <div class="sh-grid">
        <h1>{titleLead && <>{titleLead} </>}<em>{titleLast}.</em></h1>
        {intro && <p class="sh-intro">{intro}</p>}
      </div>
      <div class="sh-stats">
        {rv && <div class="st"><b>{rvAvg}★</b><span>{rvCount} {rvCount === 1 ? 'Review' : 'Reviews'}</span></div>}
        {mf.origin && <div class="st"><b>{mf.origin}</b><span>Made In</span></div>}
        {mf.dispatch && <div class="st"><b>{mf.dispatch}</b><span>Ships Within</span></div>}
        <div class="st"><b>30-Day</b><span>Free Returns</span></div>
      </div>
    </div>
  </section>

  {/* ===================== PRODUCT DETAILS ===================== */}
  <section class="pdp">
    <div class="container-mag">
      <div class="pdp-grid">
        {/* Gallery */}
        <div class="pdp-gallery">
          <div class="pg-thumbs">
            {images.map((img, i) => (
              <div
                class:list={['pg-thumb', i === 0 && 'on']}
                data-src={img.url}
                role="button"
                tabindex="0"
                aria-label={`View image ${i + 1}`}
              >
                <img src={img.url} alt={img.altText ?? `View ${i + 1}`} loading="lazy" />
              </div>
            ))}
            {videos.map((v, i) => (
              <div
                class="pg-thumb pg-thumb-video"
                data-video-index={i}
                data-vtype={v.type}
                data-vsrc={v.src}
                data-vembed={v.embed}
                data-vmime={v.mime}
                role="button"
                tabindex="0"
                aria-label={`Play video ${i + 1}`}
              >
                {v.poster && <img src={v.poster} alt="" loading="lazy" />}
                <span class="pg-play"><Icon name="play" size={16} /></span>
              </div>
            ))}
          </div>
          <div class="pg-main" data-pg-zoom>
            <div class="pg-badges">
              {isNew && <span class="tagb coral">New</span>}
              {off && <span class="tagb dark">-{off}%</span>}
            </div>
            <button class="pg-fav" data-pdp-fav aria-label="Add to wishlist">
              <Icon name="heart" size={20} />
            </button>
            <button type="button" class="pg-zoom" data-lb-open aria-label="Open full-screen view">
              <Icon name="zoomIn" size={14} /> Tap to zoom
            </button>
            {images.length > 1 && (
              <>
                <button type="button" class="pg-arrow pg-prev" data-pg-prev aria-label="Previous image">
                  <Icon name="chevronLeft" size={20} />
                </button>
                <button type="button" class="pg-arrow pg-next" data-pg-next aria-label="Next image">
                  <Icon name="chevronRight" size={20} />
                </button>
              </>
            )}
            <img id="pgMain" src={images[0]?.url} alt={product.title} />
            <div class="pg-video" data-pg-video hidden></div>
            {images.length > 1 && (
              <div class="pg-dots" data-pg-dots>
                {images.map((_, i) => (
                  <button
                    type="button"
                    class:list={['pg-dot', i === 0 && 'on']}
                    data-dot={i}
                    aria-label={`Go to image ${i + 1}`}
                  />
                ))}
              </div>
            )}
          </div>
        </div>

        {/* Info / buy box */}
        <div class="pdp-info">
          <div class="pdp-eyebrow">
            <span class="pdp-cat">{category}</span>
            {product.vendor && <span class="pdp-desg">by <b>{product.vendor}</b></span>}
          </div>
          <h2 class="pdp-name">{product.title}</h2>
          <div class="pdp-meta">
            {rv ? (
              <span class="pdp-stars">
                <span class="s">{starRow(fullStars)}</span> {rvAvg}{' '}
                <a href="#reviews">({rvCount} {rvCount === 1 ? 'review' : 'reviews'})</a>
              </span>
            ) : (
              <span class="pdp-stars pdp-stars--empty">
                <span class="s">{starRow(0)}</span> <a href="#reviews">No reviews yet</a>
              </span>
            )}
            {soldCount && (
              <span class="pdp-sold"><Icon name="fire" size={15} /> {soldCount} sold this month</span>
            )}
          </div>
          <div class="pdp-price">
            <span class="from" data-price-from hidden={!needsChoice}>From</span>
            <span class="now" data-price-now>{priceNow}</span>
            <span class="was" data-price-was hidden={!priceWas}>{priceWas}</span>
            <span class="off" data-price-off hidden={!off}>{off ? `Save ${off}%` : ''}</span>
          </div>
          <p class="pdp-tax">Import duties included · <b>Free shipping</b>{freeShip ? ` over ${freeShip}` : ''}</p>

          {countdownIso && (
            <div class="pdp-countdown" data-countdown data-end={countdownIso}>
              <Icon name="clock" size={16} />
              <span class="cd-label">Offer ends in</span>
              <span class="cd-timer" data-countdown-timer>—</span>
            </div>
          )}

          {promoCode && (
            <div class="pdp-promo">
              <span class="promo-txt">Use code at checkout</span>
              <button
                type="button"
                class="promo-code"
                data-promo-code={promoCode}
                aria-label={`Copy code ${promoCode}`}
              >
                <b>{promoCode}</b>
                <Icon name="files" size={13} />
                <span class="promo-copied" data-promo-copied hidden>Copied</span>
              </button>
            </div>
          )}

          {intro && <p class="pdp-lead">{intro}</p>}
          <div class="pdp-divider"></div>

          {colors.length > 0 && (
            <div class="opt">
              <div class="opt-head">
                <h6>{colorOption?.name ?? 'Colour'}</h6>
                <span class="sel" data-color-label>{defaultColor}</span>
              </div>
              <div class="opt-colors">
                {colors.map((c) => (
                  <span
                    class:list={['opt-color', c.image && 'has-img', c.label === defaultColor && 'on']}
                    data-color={c.label}
                    title={c.label}
                    role="button"
                    tabindex="0"
                    aria-label={`Colour: ${c.label}`}
                    aria-pressed={c.label === defaultColor ? 'true' : 'false'}
                    style={c.image
                      ? `background-image:url(${c.image})`
                      : `background:${c.hex}`}
                  />
                ))}
              </div>
            </div>
          )}

          {sizes.length > 0 && (
            <div class="opt">
              <div class="opt-head">
                <h6>{sizeOption?.name ?? 'Size'}</h6>
                {isSizeOption && (
                  <button type="button" class="guide" data-sg-open><Icon name="ruler" size={14} /> Size guide</button>
                )}
              </div>
              <div class="opt-sizes">
                {sizes.map((z) => (
                  <button
                    class:list={['opt-size', !z.ok && 'off', z.label === defaultSize && 'on']}
                    data-size={z.label}
                    disabled={!z.ok}
                  >
                    {z.label}
                  </button>
                ))}
              </div>
            </div>
          )}

          {/* Personalization (MP-24) — merchant-defined via metafield. */}
          {personalizationFields.length > 0 && (
            <div class="pdp-personalize" data-personalize>
              <h6 class="pz-title">Make it yours</h6>
              {personalizationFields.map((label) => (
                <label class="pz-field">
                  <span>{label}</span>
                  <input
                    type="text"
                    data-pz-input
                    data-pz-key={label}
                    maxlength="200"
                    autocomplete="off"
                    placeholder={`Add ${label.toLowerCase()}`}
                  />
                </label>
              ))}
            </div>
          )}

          {/* Low-stock / made-to-order signal (MP-7 / MP-9) — filled by JS. */}
          <p class="pdp-stock" data-pdp-stock hidden></p>

          <div class="buy-row">
            <div class="qty-step">
              <button data-qdec aria-label="Decrease">−</button>
              <span data-qval>1</span>
              <button data-qinc aria-label="Increase">+</button>
            </div>
            <button class="buy-add" data-pdp-add disabled={needsChoice}>
              <span data-add-label>{needsChoice ? 'Select options' : 'Add to Bag'}</span><span
                data-add-price-wrap
                hidden={needsChoice}
              > · <span data-add-price>{addPriceLabel}</span></span>
              <Icon name="bag" size={18} />
            </button>
          </div>
          <button class="buy-now" data-pdp-buy>Buy it now <Icon name="arrowRight" size={16} /></button>

          {/* Social share (MP-21) */}
          <div class="pdp-share" data-share data-share-url={shareUrl} data-share-text={shareText}>
            <span class="sh-lbl">Share</span>
            <a href={shareLinks.x} target="_blank" rel="noopener noreferrer" aria-label="Share on X">
              <Icon name="x" size={14} />
            </a>
            <a href={shareLinks.facebook} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
              <Icon name="facebook" size={15} />
            </a>
            <a href={shareLinks.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Save to Pinterest">
              <Icon name="pinterest" size={15} />
            </a>
            <button type="button" class="sh-native" data-share-native hidden aria-label="Share…">
              <Icon name="send" size={14} />
            </button>
            <button type="button" class="sh-copy" data-share-copy aria-label="Copy link">
              <Icon name="link" size={15} />
              <span class="sh-copied" data-share-copied hidden>Copied</span>
            </button>
          </div>

          <div class="pdp-trust">
            <div class="trust-i">
              <Icon name="truck" size={22} /><b>Free Delivery</b><span>2–4 days{freeShip ? `, orders over ${freeShip}` : ''}</span>
            </div>
            <div class="trust-i">
              <Icon name="rotate" size={22} /><b>30-Day Returns</b><span>Free &amp; easy returns</span>
            </div>
            <div class="trust-i">
              <Icon name="sealCheck" size={22} /><b>Authenticity</b><span>Guaranteed genuine</span>
            </div>
          </div>

          <div class="acc" data-acc>
            {(fitBullets.length > 0 || descriptionHtml || intro) && (
              <div class="acc-item open">
                <button class="acc-head" aria-expanded="true">Details &amp; Fit <Icon name="plus" size={20} /></button>
                <div class="acc-body">
                  <div class="inner">
                    {fitBullets.length > 0 && (
                      <ul>
                        {fitBullets.map((b) => (
                          <li><Icon name="check" size={15} /> {b}</li>
                        ))}
                      </ul>
                    )}
                    {/* Rich merchant-authored body (MP-18) — trusted store
                        content rendered as HTML; plain description as fallback. */}
                    {descriptionHtml ? (
                      <div class="rte" set:html={descriptionHtml} />
                    ) : (
                      fitBullets.length === 0 && <p>{intro}</p>
                    )}
                  </div>
                </div>
              </div>
            )}
            {hasSpecs && (
              <div class="acc-item">
                <button class="acc-head" aria-expanded="false">Materials &amp; Care <Icon name="plus" size={20} /></button>
                <div class="acc-body">
                  <div class="inner">
                    <div class="specs">
                      {specRows.map(([label, value]) => (
                        <div><span>{label}</span><b>{value}</b></div>
                      ))}
                      {specMetaRows.map(([label, value]) => (
                        <div><span>{label}</span><b>{value}</b></div>
                      ))}
                      {sku && (
                        <div><span>SKU</span><b data-sku>{sku}</b></div>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            )}
            <div class="acc-item">
              <button class="acc-head" aria-expanded="false">Shipping &amp; Returns <Icon name="plus" size={20} /></button>
              <div class="acc-body">
                <div class="inner">
                  Complimentary express shipping on all orders{freeShip ? ` over ${freeShip}` : ''}, delivered in 2–4 business
                  days. Enjoy 30 days to return unworn pieces with tags attached — returns are free
                  and fully refunded. Same-day click &amp; collect available at our {SITE.flagshipName}.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===================== REVIEWS (real Judge.me data) ===================== */}
  <section class="reviews" id="reviews" data-reviews>
    <div class="container-mag">
      <div class="rv-head">
        <div>
          <span class="mag-label">Customer Reviews</span>
          <h2>What the <em>editors &amp; buyers</em> say.</h2>
        </div>
        <div class="rv-actions">
          {rv && (
            <div class="rv-filters" data-rv-filters>
              <span class="fl">Filter</span>
              <button class="rv-fp on" data-f="all">All</button>
              <button class="rv-fp" data-f="5">5 ★</button>
              <button class="rv-fp" data-f="4">4 ★</button>
              <button class="rv-fp" data-f="photos">With photos</button>
            </div>
          )}
          {canWriteReview && (
            <button type="button" class="rv-write-trigger" data-rv-write-open aria-expanded="false" aria-controls="review-form">
              <Icon name="pencil" size={15} /> Write a review
            </button>
          )}
        </div>
      </div>

      {rv ? (
        <div class="rv-layout">
          <aside class="rv-summary">
            <div class="rv-score">{rvAvg}<sub>/5</sub></div>
            <div class="rv-sstars">{starRow(fullStars)}</div>
            <div class="rv-scount">Based on {rvCount} verified {rvCount === 1 ? 'review' : 'reviews'}</div>
            <div class="rv-bars">
              {([5, 4, 3, 2, 1] as const).map((s) => {
                const c = rv.histogram[s];
                const pct = rvCount ? Math.round((c / rvCount) * 100) : 0;
                return (
                  <div class="rv-bar">
                    <span class="lab">{s} ★</span>
                    <span class="track"><span class="fill" style={`width:${pct}%`} /></span>
                    <span class="pct">{pct}%</span>
                  </div>
                );
              })}
            </div>
            <div class="rv-rec-line"><b>{rv.recommendPct}%</b> would recommend this piece</div>
          </aside>

          <div>
            <div class="rv-list" data-rv-list>
              {rv.reviews.map((r, i) => (
                <article
                  class="rv-card"
                  data-rating={r.rating}
                  data-has-photos={r.pictures.length ? '1' : '0'}
                  data-index={i}
                  style={i >= 3 ? 'display:none' : ''}
                >
                  <div class="rv-top">
                    <span class="rv-av">{r.name.charAt(0).toUpperCase()}</span>
                    <div class="rv-who">
                      <b>{r.name}</b>
                      {r.verified && (
                        <span class="vf"><Icon name="sealCheck" size={13} /> Verified Buyer</span>
                      )}
                    </div>
                    <span class="rv-when">{fmtDate(r.createdAt)}</span>
                  </div>
                  <div class="rv-rate">{starRow(r.rating)}</div>
                  {r.title && <h5>{r.title}</h5>}
                  {r.body && <p>{r.body}</p>}
                  {r.pictures.length > 0 && (
                    <div class="rv-photos">
                      {r.pictures.map((src) => (
                        <img src={src} alt={`${r.name}'s photo`} loading="lazy" />
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
            <div class="rv-empty-filter" data-rv-noresult style="display:none">
              No reviews match this filter yet.
            </div>
            {rvCount > 3 && (
              <div class="rv-more" data-rv-more>
                <button class="btn-load" data-rv-loadmore>
                  Load more reviews <Icon name="arrowDown" size={16} />
                </button>
              </div>
            )}
          </div>
        </div>
      ) : (
        <div class="rv-empty">
          <p class="rv-empty-title">No reviews yet</p>
          <p class="rv-empty-sub">Be the first to share your thoughts on the {product.title}.</p>
        </div>
      )}

      {/* ---- Write a review (MP-26 — submits to Judge.me, awaits moderation) ---- */}
      {canWriteReview && (
      <div class="rv-write" id="review-form" data-rv-write hidden>
        <form class="rv-form" data-rv-form data-product-id={reviewProductId} novalidate>
          <div class="rv-form-head">
            <h3>Write a review</h3>
            <button type="button" class="rv-form-close" data-rv-write-close aria-label="Close review form">
              <Icon name="close" size={18} />
            </button>
          </div>

          <div class="rv-field">
            <span class="rv-label">Your rating <i>*</i></span>
            <div class="rv-stars" data-rv-stars role="radiogroup" aria-label="Rating out of 5">
              {[1, 2, 3, 4, 5].map((n) => (
                <button
                  type="button"
                  class="rv-star"
                  data-val={n}
                  role="radio"
                  aria-checked="false"
                  aria-label={`${n} star${n === 1 ? '' : 's'}`}
                >
                  <Icon name="star" size={26} />
                </button>
              ))}
            </div>
            <input type="hidden" name="rating" value="" data-rv-rating />
          </div>

          <div class="rv-row">
            <label class="rv-field">
              <span class="rv-label">Name <i>*</i></span>
              <input type="text" name="name" autocomplete="name" maxlength="100" required />
            </label>
            <label class="rv-field">
              <span class="rv-label">Email <i>*</i></span>
              <input type="email" name="email" autocomplete="email" maxlength="150" required />
            </label>
          </div>

          <label class="rv-field">
            <span class="rv-label">Review title</span>
            <input type="text" name="title" maxlength="150" placeholder="Sum it up in a few words" />
          </label>

          <label class="rv-field">
            <span class="rv-label">Your review <i>*</i></span>
            <textarea name="body" rows="4" maxlength="5000" required placeholder="What did you like or dislike? How was the fit, quality and feel?"></textarea>
          </label>

          {/* Honeypot — hidden from real users; bots that fill it are silently dropped. */}
          <div class="rv-hp" aria-hidden="true">
            <label>Leave this field empty<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
          </div>

          <p class="rv-note">Your email is never published. Reviews appear after moderation.</p>

          <div class="rv-form-foot">
            <button type="submit" class="rv-submit" data-rv-submit>
              <span class="rv-submit-label"><Icon name="send" size={15} /> Submit review</span>
              <span class="rv-submit-spin" hidden><span class="rv-spinner" /></span>
            </button>
            <p class="rv-status" data-rv-status role="status" aria-live="polite" hidden></p>
          </div>
        </form>
      </div>
      )}
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />


  {/* ===================== GOES WELL WITH (complementary, MP-20) ========= */}
  {complementaryUnique.length > 0 && (
    <section class="related related--complementary">
      <div class="container-mag">
        <div class="rel-head">
          <div>
            <span class="mag-label">Goes Well With</span>
            <h2>Style it <em>together.</em></h2>
          </div>
        </div>
        <div class="rel-grid">
          {complementaryUnique.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ===================== YOU MAY ALSO LIKE ===================== */}
  {recommendations.length > 0 && (
    <section class="related">
      <div class="container-mag">
        <div class="rel-head">
          <div>
            <span class="mag-label">Complete the Look</span>
            <h2>You may <em>also like.</em></h2>
          </div>
          <a href="/products" class="rel-cta">View All Products <Icon name="arrowRight" size={15} /></a>
        </div>
        <div class="rel-grid">
          {recommendations.slice(0, 4).map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ===================== RECENTLY VIEWED (MP-19, client-rendered) ====== */}
  <section class="recent" data-recent hidden>
    <div class="container-mag">
      <div class="rel-head">
        <div>
          <span class="mag-label">Pick Up Where You Left Off</span>
          <h2>Recently <em>viewed.</em></h2>
        </div>
        <div class="recent-nav" data-recent-nav hidden>
          <button type="button" class="rc-arrow" data-recent-prev aria-label="Scroll back">
            <Icon name="chevronLeft" size={18} />
          </button>
          <button type="button" class="rc-arrow" data-recent-next aria-label="Scroll forward">
            <Icon name="chevronRight" size={18} />
          </button>
        </div>
      </div>
      {/* Layout class (grid ≤4 / rail >4) + cards are set by the client. */}
      <div class="recent-track" data-recent-grid></div>
    </div>
  </section>

  {/* ===================== STICKY ADD-TO-CART BAR (MP-16) ================ */}
  <div class="pdp-sticky" data-sticky hidden aria-hidden="true">
    <div class="container-mag pdp-sticky-in">
      <div class="ps-media">
        {images[0] && <img src={images[0].url} alt="" />}
        <div class="ps-txt">
          <span class="ps-name">{product.title}</span>
          <span class="ps-price" data-sticky-price>{priceNow}</span>
        </div>
      </div>
      <button type="button" class="ps-add" data-sticky-add>
        Add to Bag <Icon name="bag" size={17} />
      </button>
    </div>
  </div>

  {/* ===================== IMAGE LIGHTBOX (MP-3) ===================== */}
  {images.length > 0 && (
    <div class="lb-overlay" data-lb-overlay hidden>
      <div class="lb-stage" role="dialog" aria-modal="true" aria-label="Product image viewer">
        <button type="button" class="lb-close" data-lb-close aria-label="Close viewer">
          <Icon name="close" size={20} />
        </button>
        <div class="lb-frame">
          {images.length > 1 && (
            <button type="button" class="lb-nav lb-prev" data-lb-prev aria-label="Previous image">
              <Icon name="chevronLeft" size={24} />
            </button>
          )}
          <img class="lb-img" data-lb-img src={images[0]?.url} alt={product.title} />
          {images.length > 1 && (
            <button type="button" class="lb-nav lb-next" data-lb-next aria-label="Next image">
              <Icon name="chevronRight" size={24} />
            </button>
          )}
        </div>
        {images.length > 1 && (
          <div class="lb-thumbs">
            {images.map((img, i) => (
              <button
                type="button"
                class:list={['lb-thumb', i === 0 && 'on']}
                data-lb-thumb={i}
                data-src={img.url}
                aria-label={`View image ${i + 1}`}
              >
                <img src={img.url} alt="" loading="lazy" />
              </button>
            ))}
          </div>
        )}
        <div class="lb-count"><span data-lb-current>1</span> / {images.length}</div>
      </div>
    </div>
  )}

  {/* ===================== SIZE GUIDE MODAL ===================== */}
  {sizes.length > 0 && (
    <div class="sg-overlay" data-sg-overlay hidden>
      <div class="sg-modal" role="dialog" aria-modal="true" aria-label="Size guide">
        <div class="sg-modal-head">
          <div>
            <span class="mag-label">Find Your Fit</span>
            <h3>Size guide</h3>
          </div>
          <button type="button" class="sg-close" data-sg-close aria-label="Close size guide">
            <Icon name="close" size={20} />
          </button>
        </div>
        <div class="sg-modal-body">
          {sizeGuideHtml ? <div class="rte" set:html={sizeGuideHtml} /> : <SizeGuide />}
        </div>
        <a href="/size-guide" class="sg-modal-foot">
          Open the full size guide <Icon name="arrowRight" size={15} />
        </a>
      </div>
    </div>
  )}

</div>

<style>
  /* ============================================================
     PDP — ported 1:1 from the designer's Product.html, with the
     mockup's --mag-* / --r-* variables mapped to project tokens.
     ============================================================ */

  /* ---- Editorial hero ---- */
  .shop-hero {
    padding: 60px 0;
  }
  .shop-hero .mag-label {
    margin-bottom: 18px;
  }
  .pdp-hero {
    padding-bottom: 60px;
  }
  .sh-grid {
    display: flex;
    gap: 40px;
    align-items: start;
    justify-content: space-between;
  }
  .sh-grid h1 {
