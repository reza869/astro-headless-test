{/* Recently-viewed cards are injected as HTML (not Astro-scoped), so the two
    interaction styles ProductCard defines in scoped CSS are provided globally
    here — bounded to `.recent` so nothing else is affected. */}
<style is:global>
  .recent .wishlist-btn.is-active {
    background: var(--color-coral);
    color: #fff;
  }
  .recent .add-to-bag-btn[data-loading] .btn-default {
    display: none;
  }
  .recent .add-to-bag-btn[data-loading] .btn-loading {
    display: inline-flex;
  }
</style>

<script>
  import { addItem, buyNow } from '~/stores/cart';
  import { $wishlist, toggleWishlist } from '~/stores/wishlist';

  interface VariantInfo {
    id: string;
    available: boolean;
    color: string;
    size: string;
    amount: string;
    compareAt: string | null;
    img: string | null;
    qty: number | null;
    continueSelling: boolean;
    sku: string | null;
    rule: { min: number; max: number | null; inc: number } | null;
  }
  interface PdpConfig {
    productId: string;
    currency: string;
    hasColor: boolean;
    hasSize: boolean;
    defaultColor: string;
    defaultSize: string;
    unitAmount: string;
    lowStockThreshold: number;
    variants: VariantInfo[];
    snapshot?: {
      id: string;
      handle: string;
      title: string;
      image: string;
      price: string;
      compareAt: string | null;
      vendor: string;
      currency: string;
      variantId: string | null;
      available: boolean;
      requiresChoice: boolean;
      isNew: boolean;
    };
  }

  function initPdp(): void {
    const root = document.querySelector<HTMLElement>('.pdp-root');
    if (!root || root.dataset.bound) return;
    root.dataset.bound = 'true';

    let cfg: PdpConfig;
    try {
      cfg = JSON.parse(root.dataset.config || '{}');
    } catch {
      return;
    }

    const $ = <T extends Element = HTMLElement>(sel: string) => root.querySelector<T>(sel);
    const money = (a: number) => {
      if (!Number.isFinite(a)) return '—';
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: cfg.currency,
        minimumFractionDigits: Number.isInteger(a) ? 0 : 2,
      }).format(a);
    };

    const state = { qty: 1, color: cfg.defaultColor, size: cfg.defaultSize };

    // ── Gallery carousel + video (MP-4 / MP-5) ─────────────
    const main = $<HTMLImageElement>('#pgMain');
    const videoMount = $<HTMLElement>('[data-pg-video]');
    const imageThumbs = Array.from(
      root.querySelectorAll<HTMLElement>('.pg-thumb:not(.pg-thumb-video)'),
    );
    const videoThumbs = Array.from(root.querySelectorAll<HTMLElement>('.pg-thumb-video'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('.pg-dot'));
    const imageUrls = imageThumbs.map((t) => t.dataset.src || '');
    let slideIdx = 0;

    /** Stop + clear any playing video, revealing the still image again. */
    const clearVideo = (): void => {
      if (!videoMount) return;
      videoMount.hidden = true;
      videoMount.innerHTML = '';
      if (main) main.hidden = false;
      videoThumbs.forEach((t) => t.classList.remove('on'));
    };

    const paintActive = (): void => {
      imageThumbs.forEach((t, i) => t.classList.toggle('on', i === slideIdx));
      dots.forEach((d, i) => d.classList.toggle('on', i === slideIdx));
    };

    const showImage = (i: number): void => {
      if (!imageUrls.length) return;
      slideIdx = (i + imageUrls.length) % imageUrls.length;
      clearVideo();
      if (main && imageUrls[slideIdx]) main.src = imageUrls[slideIdx];
      paintActive();
    };

    /** Public helper used by the variant swap — jump to a specific image url. */
    const setMainImage = (url: string): void => {
      const i = imageUrls.indexOf(url);
      if (i >= 0) showImage(i);
      else if (main) {
        clearVideo();
        main.src = url; // variant image not present in the thumbnail strip
      }
    };

    imageThumbs.forEach((t, i) => {
      const go = () => showImage(i);
      t.addEventListener('click', go);
      t.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          go();
        }
      });
    });

    // Video slides — hosted <video> or external <iframe> in the main stage.
    const showVideo = (t: HTMLElement): void => {
      if (!videoMount) return;
      const type = t.dataset.vtype;
      const src = t.dataset.vsrc || '';
      const embed = t.dataset.vembed || '';
      const mime = t.dataset.vmime || 'video/mp4';
      let html = '';
      if (type === 'external_video' && embed) {
        html = `<iframe src="${embed}" title="Product video" loading="lazy" frameborder="0" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>`;
      } else if (src) {
        html = `<video controls autoplay playsinline preload="metadata"><source src="${src}" type="${mime}" /></video>`;
      }
      if (!html) return;
      videoMount.innerHTML = html;
      videoMount.hidden = false;
      if (main) main.hidden = true;
      imageThumbs.forEach((x) => x.classList.remove('on'));
      dots.forEach((d) => d.classList.remove('on'));
      videoThumbs.forEach((x) => x.classList.toggle('on', x === t));
    };
    videoThumbs.forEach((t) => {
      const go = () => showVideo(t);
      t.addEventListener('click', go);
      t.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          go();
        }
      });
    });

    // Prev / next / dots.
    root.querySelector('[data-pg-prev]')?.addEventListener('click', () => showImage(slideIdx - 1));
    root.querySelector('[data-pg-next]')?.addEventListener('click', () => showImage(slideIdx + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => showImage(i)));

    // ── Cursor-follow magnify (MP-3) + swipe (MP-4) ────────
    const pgMain = $<HTMLElement>('.pg-main');
    if (pgMain && main && !window.matchMedia('(hover: none)').matches) {
      pgMain.addEventListener('mouseenter', () => {
        if (!main.hidden) pgMain.classList.add('magnify');
      });
      pgMain.addEventListener('mouseleave', () => {
        pgMain.classList.remove('magnify');
        main.style.transformOrigin = 'center center';
      });
      pgMain.addEventListener('mousemove', (e) => {
        const r = pgMain.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        main.style.transformOrigin = `${x}% ${y}%`;
      });
    }
    if (pgMain && imageUrls.length > 1) {
      let sx = 0;
      let sy = 0;
      pgMain.addEventListener(
        'touchstart',
        (e) => {
          sx = e.changedTouches[0].clientX;
          sy = e.changedTouches[0].clientY;
        },
        { passive: true },
      );
      pgMain.addEventListener(
        'touchend',
        (e) => {
          const dx = e.changedTouches[0].clientX - sx;
          const dy = e.changedTouches[0].clientY - sy;
          if (Math.abs(dx) > 45 && Math.abs(dx) > Math.abs(dy)) {
            showImage(slideIdx + (dx < 0 ? 1 : -1));
          }
        },
        { passive: true },
      );
    }

    // ── Variant resolution + price ─────────────────────────
    const resolve = (): VariantInfo | null =>
      cfg.variants.find(
        (v) =>
          (!cfg.hasColor || v.color === state.color) && (!cfg.hasSize || v.size === state.size),
      ) ?? null;

    const syncPrice = () => {
      const v = resolve();
      const unit = Number(v?.amount ?? cfg.unitAmount);
      const cmp = v?.compareAt != null ? Number(v.compareAt) : null;
      const onSale = cmp != null && Number.isFinite(cmp) && cmp > unit;

      // Option B — show the "From" prefix while the price is the min-variant
      // placeholder (no concrete variant resolved yet); drop it once resolved.
      const fromEl = $<HTMLElement>('[data-price-from]');
      if (fromEl) fromEl.hidden = !!v;

      const ap = $('[data-add-price]');
      if (ap) ap.textContent = money(unit * state.qty);

      // Headline price + compare-at, synced to the RESOLVED variant so the big
      // price always matches what's actually added, and the discount badge is
      // the selected variant's real saving (not a min-vs-min approximation).
      const nowEl = $('[data-price-now]');
      if (nowEl) nowEl.textContent = money(unit);
      const stickyPrice = $('[data-sticky-price]');
      if (stickyPrice) stickyPrice.textContent = money(unit);
      const wasEl = $<HTMLElement>('[data-price-was]');
      if (wasEl) {
        wasEl.hidden = !onSale;
        if (onSale) wasEl.textContent = money(cmp as number);
      }
      const offEl = $<HTMLElement>('[data-price-off]');
      if (offEl) {
        const pct = onSale ? Math.round((((cmp as number) - unit) / (cmp as number)) * 100) : 0;
        offEl.hidden = pct <= 0;
        if (pct > 0) offEl.textContent = `Save ${pct}%`;
      }
    };

    // ── Variant-driven gallery (MP-1) ──────────────────────
    // Swap the hero image to the resolved variant's own image when it has one
    // (colour changes drive the gallery, matching real fashion PDP behaviour).
    const syncMedia = () => {
      // Prefer the fully-resolved variant's image; otherwise, once a colour is
      // chosen, swap to that colour's first imaged variant so the gallery tracks
      // the colour even before the size/material is picked (Option B).
      const v =
        resolve() ??
        (cfg.hasColor && state.color
          ? cfg.variants.find((x) => x.color === state.color && x.img)
          : null);
      if (v?.img) setMainImage(v.img);
    };

    // ── Low-stock / made-to-order signal + buy state (MP-7 / MP-9) ──
    const stockEl = $<HTMLElement>('[data-pdp-stock]');
    const addBtn = $<HTMLButtonElement>('[data-pdp-add]');
    const addLabelEl = $<HTMLElement>('[data-add-label]');
    const priceWrap = $<HTMLElement>('[data-add-price-wrap]');
    const syncStock = () => {
      const v = resolve();
      const q = v?.qty ?? null;
      const buyable = !!v && v.available;
      // Option B — no concrete variant resolved yet (the shopper still owes a
      // choice). Prompt for it instead of a misleading "Sold out"/price.
      const needsPick = !v;

      // Availability line — a status for the resolved variant; hidden until then.
      if (stockEl) {
        stockEl.classList.remove('is-in', 'is-low', 'is-order', 'is-out');
        if (needsPick) {
          stockEl.hidden = true;
        } else if (v && v.available && typeof q === 'number' && q > 0 && q <= cfg.lowStockThreshold) {
          stockEl.textContent = q === 1 ? 'Only 1 left in stock' : `Only ${q} left — selling fast`;
          stockEl.classList.add('is-low');
          stockEl.hidden = false;
        } else if (v && v.continueSelling) {
          stockEl.textContent = 'Made to order · ships when restocked';
          stockEl.classList.add('is-order');
          stockEl.hidden = false;
        } else if (buyable) {
          stockEl.textContent = 'In stock';
          stockEl.classList.add('is-in');
          stockEl.hidden = false;
        } else {
          stockEl.textContent = 'Out of stock';
          stockEl.classList.add('is-out');
          stockEl.hidden = false;
        }
      }

      // Add button: prompt to choose → pre-order → sold out → add. The price tag
      // beside the label only makes sense once a concrete variant is priced.
      if (addLabelEl) {
        addLabelEl.textContent = needsPick
          ? 'Select options'
          : v?.continueSelling
            ? 'Pre-order'
            : buyable
              ? 'Add to Bag'
              : 'Sold out';
      }
      if (priceWrap) priceWrap.hidden = needsPick;
      if (addBtn) addBtn.disabled = !buyable;
      const stickyAddEl = $<HTMLButtonElement>('[data-sticky-add]');
      if (stickyAddEl) stickyAddEl.disabled = !buyable;
    };

    // ── Deep-linkable variant (MP-6) ───────────────────────
    // Shopify convention: ?variant=<numeric id>. Keep the URL in step with the
    // selection so it's shareable, refresh-stable and back-button correct.
    const numericId = (gid: string) => gid.split('/').pop() || gid;
    const updateUrl = () => {
      const v = resolve();
      if (!v) return;
      const url = new URL(window.location.href);
      url.searchParams.set('variant', numericId(v.id));
      history.replaceState(history.state, '', url);
    };

    /** Move the UI + state to match a specific variant (URL seed / restore). */
    const applySelection = (v: VariantInfo) => {
      if (cfg.hasColor && v.color) {
        state.color = v.color;
        root.querySelectorAll<HTMLElement>('.opt-color').forEach((x) => {
          const on = x.dataset.color === v.color;
          x.classList.toggle('on', on);
          x.setAttribute('aria-pressed', String(on));
        });
        const lbl = $('[data-color-label]');
        if (lbl) lbl.textContent = state.color;
      }
      if (cfg.hasSize && v.size) {
        state.size = v.size;
        root
          .querySelectorAll<HTMLElement>('.opt-size')
          .forEach((x) => x.classList.toggle('on', x.dataset.size === v.size));
      }
      syncMedia();
      syncStock();
      syncSku();
      clampQty();
      syncQty();
    };

    // ── Colours ────────────────────────────────────────────
    root.querySelectorAll<HTMLElement>('.opt-color').forEach((o) => {
      const activate = () => {
        root.querySelectorAll('.opt-color').forEach((x) => {
          x.classList.remove('on');
          x.setAttribute('aria-pressed', 'false');
        });
        o.classList.add('on');
        o.setAttribute('aria-pressed', 'true');
        state.color = o.dataset.color || '';
        const lbl = $('[data-color-label]');
        if (lbl) lbl.textContent = state.color;
        syncMedia();
        syncStock();
        syncSku();
        clampQty();
        syncQty();
        updateUrl();
      };
      o.addEventListener('click', activate);
      o.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activate();
        }
      });
    });

    // ── Sizes ──────────────────────────────────────────────
    root.querySelectorAll<HTMLButtonElement>('.opt-size').forEach((o) => {
      if (o.classList.contains('off')) return;
      o.addEventListener('click', () => {
        root.querySelectorAll('.opt-size').forEach((x) => x.classList.remove('on'));
        o.classList.add('on');
        state.size = o.dataset.size || '';
        syncMedia();
        syncStock();
        syncSku();
        clampQty();
        syncQty();
        updateUrl();
      });
    });

    // ── Quantity + purchase rules / stock cap (MP-8) ───────
    const qval = $('[data-qval]');
    const qdec = $<HTMLButtonElement>('[data-qdec]');
    const qinc = $<HTMLButtonElement>('[data-qinc]');

    /** Resolve the active min / step / max (rule.max capped at live stock). */
    const bounds = () => {
      const v = resolve();
      const rule = v?.rule ?? null;
      const min = rule?.min && rule.min > 0 ? rule.min : 1;
      const inc = rule?.inc && rule.inc > 0 ? rule.inc : 1;
      const stockCap = v && !v.continueSelling && typeof v.qty === 'number' ? v.qty : null;
      const ruleMax = rule?.max ?? null;
      let max =
        ruleMax != null && stockCap != null
          ? Math.min(ruleMax, stockCap)
          : (ruleMax ?? stockCap);
      if (max != null && max < min) max = min;
      return { min, inc, max };
    };

    /** Clamp the current qty into [min, max] snapped to the increment. */
    const clampQty = () => {
      const { min, inc, max } = bounds();
      let q = Number.isFinite(state.qty) ? state.qty : min;
      if (q < min) q = min;
      const steps = Math.max(0, Math.round((q - min) / inc));
      q = min + steps * inc;
      if (max != null && q > max) q = min + Math.max(0, Math.floor((max - min) / inc)) * inc;
      state.qty = q;
    };

    const syncQty = () => {
      if (qval) qval.textContent = String(state.qty);
      const { min, max } = bounds();
      if (qdec) qdec.disabled = state.qty <= min;
      if (qinc) qinc.disabled = max != null && state.qty >= max;
      syncPrice();
    };
    qinc?.addEventListener('click', () => {
      state.qty += bounds().inc;
      clampQty();
      syncQty();
    });
    qdec?.addEventListener('click', () => {
      state.qty -= bounds().inc;
      clampQty();
      syncQty();
    });

    // ── Live SKU on variant change (MP-10) ─────────────────
    const skuEl = $<HTMLElement>('[data-sku]');
    const syncSku = () => {
      const v = resolve();
      if (skuEl && v?.sku) skuEl.textContent = v.sku;
    };

    // ── Personalization → cart line attributes (MP-24) ─────
    const pzInputs = Array.from(root.querySelectorAll<HTMLInputElement>('[data-pz-input]'));
    const collectAttributes = () =>
      pzInputs
        .map((i) => ({ key: (i.dataset.pzKey || '').trim(), value: i.value.trim() }))
        .filter((a) => a.key && a.value);

    // ── Add to bag / buy now ───────────────────────────────
    const add = $<HTMLButtonElement>('[data-pdp-add]');
    add?.addEventListener('click', async () => {
      const v = resolve();
      if (!v || !v.available || add.dataset.loading) return;
      add.dataset.loading = '1';
      try {
        await addItem(v.id, state.qty, { attributes: collectAttributes() }); // opens drawer on success
      } finally {
        delete add.dataset.loading;
      }
    });
    $('[data-pdp-buy]')?.addEventListener('click', () => {
      const v = resolve();
      if (v && v.available) buyNow(v.id, state.qty, collectAttributes());
    });

    // ── Wishlist heart (synced with header badge) ──────────
    const fav = $<HTMLButtonElement>('[data-pdp-fav]');
    const paintFav = () => fav?.classList.toggle('on', $wishlist.get().includes(cfg.productId));
    fav?.addEventListener('click', () => {
      toggleWishlist(cfg.productId);
      window.dispatchEvent(new CustomEvent('wishlist-updated'));
    });
    $wishlist.subscribe(paintFav);

    // ── Accordions ─────────────────────────────────────────
    root.querySelectorAll<HTMLElement>('[data-acc] .acc-head').forEach((h) => {
      h.addEventListener('click', () => {
        const item = h.closest('.acc-item') as HTMLElement;
        const body = item.querySelector<HTMLElement>('.acc-body')!;
        const open = item.classList.toggle('open');
        body.style.maxHeight = open ? body.scrollHeight + 'px' : '0';
        h.setAttribute('aria-expanded', String(open));
      });
    });
    const openBody = root.querySelector<HTMLElement>('[data-acc] .acc-item.open .acc-body');
    if (openBody) openBody.style.maxHeight = openBody.scrollHeight + 'px';

    clampQty();
    syncQty();
    syncSku();

    // Seed the selection from a shared ?variant= link (MP-6); otherwise just
    // paint the initial stock state for the default selection.
    const wantedVariant = new URLSearchParams(window.location.search).get('variant');
    const seedVariant = wantedVariant
      ? cfg.variants.find((v) => numericId(v.id) === wantedVariant)
      : null;
    if (seedVariant) applySelection(seedVariant);
    else syncStock();

    // ── Size guide modal ───────────────────────────────────
    const sgOverlay = $<HTMLElement>('[data-sg-overlay]');
    if (sgOverlay) {
      const openSg = (): void => {
        sgOverlay.hidden = false;
        requestAnimationFrame(() => sgOverlay.classList.add('is-open'));
        document.documentElement.classList.add('nav-open'); // reuse scroll lock
      };
      const closeSg = (): void => {
        sgOverlay.classList.remove('is-open');
        document.documentElement.classList.remove('nav-open');
        window.setTimeout(() => {
          sgOverlay.hidden = true;
        }, 300);
      };
      root
        .querySelectorAll<HTMLButtonElement>('[data-sg-open]')
        .forEach((b) => b.addEventListener('click', openSg));
      sgOverlay.querySelector('[data-sg-close]')?.addEventListener('click', closeSg);
      sgOverlay.addEventListener('click', (e) => {
        if (e.target === sgOverlay) closeSg(); // backdrop click
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !sgOverlay.hidden) closeSg();
      });
    }

    // ── Image lightbox (MP-3) ──────────────────────────────
    const lb = $<HTMLElement>('[data-lb-overlay]');
    if (lb && main) {
      const lbImg = lb.querySelector<HTMLImageElement>('[data-lb-img]');
      const lbThumbs = Array.from(lb.querySelectorAll<HTMLElement>('.lb-thumb'));
      const lbCurrent = lb.querySelector<HTMLElement>('[data-lb-current]');
      const urls = lbThumbs.length ? lbThumbs.map((t) => t.dataset.src || '') : [main.src];
      let idx = 0;

      const show = (i: number): void => {
        idx = (i + urls.length) % urls.length;
        if (lbImg) lbImg.src = urls[idx];
        lbThumbs.forEach((t, k) => t.classList.toggle('on', k === idx));
        if (lbCurrent) lbCurrent.textContent = String(idx + 1);
      };
      const openLb = (): void => {
        // Open on whatever the hero currently shows (respects a colour swap).
        const at = urls.indexOf(main.src);
        show(at >= 0 ? at : 0);
        lb.hidden = false;
        requestAnimationFrame(() => lb.classList.add('is-open'));
        document.documentElement.classList.add('nav-open');
      };
      const closeLb = (): void => {
        lb.classList.remove('is-open');
        document.documentElement.classList.remove('nav-open');
        window.setTimeout(() => (lb.hidden = true), 300);
      };

      root.querySelectorAll('[data-lb-open]').forEach((b) => b.addEventListener('click', openLb));
      main.addEventListener('click', openLb);
      lb.querySelector('[data-lb-close]')?.addEventListener('click', closeLb);
      lb.querySelector('[data-lb-prev]')?.addEventListener('click', () => show(idx - 1));
      lb.querySelector('[data-lb-next]')?.addEventListener('click', () => show(idx + 1));
      lbThumbs.forEach((t, k) => t.addEventListener('click', () => show(k)));
      lb.addEventListener('click', (e) => {
        if (e.target === lb) closeLb();
      });
      document.addEventListener('keydown', (e) => {
        if (lb.hidden) return;
        if (e.key === 'Escape') closeLb();
        else if (e.key === 'ArrowLeft') show(idx - 1);
        else if (e.key === 'ArrowRight') show(idx + 1);
      });
    }

    // ── Sticky add-to-cart bar (MP-16) ─────────────────────
    const sticky = $<HTMLElement>('[data-sticky]');
    if (sticky && addBtn) {
      sticky.hidden = false; // enable transitions; stays translated off-screen
      const stickyAdd = sticky.querySelector<HTMLButtonElement>('[data-sticky-add]');
      stickyAdd?.addEventListener('click', () => addBtn.click());
      const io = new IntersectionObserver(
        ([entry]) => {
          // Reveal once the primary Add button has scrolled ABOVE the viewport.
          const reveal = !entry.isIntersecting && entry.boundingClientRect.top < 0;
          sticky.classList.toggle('is-visible', reveal);
          sticky.setAttribute('aria-hidden', String(!reveal));
        },
        { threshold: 0 },
      );
      io.observe(addBtn);
    }

    // ── Social share (MP-21) ───────────────────────────────
    const share = $<HTMLElement>('[data-share]');
    if (share) {
      const url = share.dataset.shareUrl || window.location.href;
      const text = share.dataset.shareText || document.title;
      const nativeBtn = share.querySelector<HTMLButtonElement>('[data-share-native]');
      if (nativeBtn && typeof navigator !== 'undefined' && 'share' in navigator) {
        nativeBtn.hidden = false;
        nativeBtn.addEventListener('click', () => {
          navigator.share({ title: text, url }).catch(() => {});
        });
      }
      const copyBtn = share.querySelector<HTMLButtonElement>('[data-share-copy]');
      const copied = share.querySelector<HTMLElement>('[data-share-copied]');
      copyBtn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(url);
          if (copied) {
            copied.hidden = false;
            window.setTimeout(() => (copied.hidden = true), 1600);
          }
        } catch {
          /* clipboard blocked — no-op */
        }
      });
    }

    // ── Countdown timer (MP-22) ────────────────────────────
    const cd = $<HTMLElement>('[data-countdown]');
    const cdTimer = $<HTMLElement>('[data-countdown-timer]');
    if (cd && cdTimer) {
      const end = Date.parse(cd.dataset.end || '');
      if (!Number.isNaN(end)) {
        const pad = (n: number) => String(n).padStart(2, '0');
        const tick = () => {
          if (!document.contains(cd)) {
            window.clearInterval(timer);
            return;
          }
          const diff = end - Date.now();
          if (diff <= 0) {
            cd.hidden = true;
            window.clearInterval(timer);
            return;
          }
          const d = Math.floor(diff / 86400000);
          const h = Math.floor((diff % 86400000) / 3600000);
          const m = Math.floor((diff % 3600000) / 60000);
          const s = Math.floor((diff % 60000) / 1000);
          cdTimer.textContent = (d > 0 ? `${d}d ` : '') + `${pad(h)}h ${pad(m)}m ${pad(s)}s`;
        };
        const timer = window.setInterval(tick, 1000);
        tick();
      }
    }

    // ── Promo code copy (MP-23) ────────────────────────────
    const promoBtn = $<HTMLButtonElement>('[data-promo-code]');
    if (promoBtn) {
      const code = promoBtn.dataset.promoCode || '';
      const promoCopied = promoBtn.querySelector<HTMLElement>('[data-promo-copied]');
      promoBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code);
          if (promoCopied) {
            promoCopied.hidden = false;
            window.setTimeout(() => (promoCopied.hidden = true), 1600);
          }
        } catch {
          /* clipboard blocked — no-op */
        }
      });
    }

    // ── Recently viewed (MP-19) ────────────────────────────
    // Pure client + localStorage: store a snapshot per PDP view and render the
    // previous ones as ProductCard-parity cards — a 4/2/2 grid for 1–4 items,
    // a scroll-snap slider (with arrows) beyond that. No network round-trip.
    try {
      const KEY = 'tailored:recentlyViewed';
      const snap = cfg.snapshot;
      const esc = (s: string) =>
        String(s ?? '').replace(/[&<>"']/g, (c) =>
          ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string,
        );
      const svg = (paths: string, size: number) =>
        `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${paths}</svg>`;
      const ICON = {
        heart: '<path d="M19 14c1.5-1.5 3-3.4 3-5.5A4.5 4.5 0 0 0 12 5 4.5 4.5 0 0 0 2 8.5C2 12 5 14 12 20c3-2.6 5-4.4 7-6Z"/>',
        eye: '<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>',
        plus: '<path d="M5 12h14"/><path d="M12 5v14"/>',
      };
      const fmt = (amt: string, cur: string) => {
        const n = Number(amt);
        if (!Number.isFinite(n)) return '';
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: cur || 'USD',
          minimumFractionDigits: Number.isInteger(n) ? 0 : 2,
        }).format(n);
      };

      type Snap = NonNullable<PdpConfig['snapshot']>;
      const reveal = 'translate-x-3 opacity-0 group-hover:translate-x-0 group-hover:opacity-100';
      // A ProductCard-identical card (utility classes only, so it styles the
      // injected markup); actions reuse the same hooks the theme card uses.
      const rvCard = (s: Snap, rail: boolean): string => {
        const href = `/products/${encodeURIComponent(s.handle)}`;
        const price = Number(s.price);
        const cmp = s.compareAt != null ? Number(s.compareAt) : null;
        const onSale = cmp != null && Number.isFinite(cmp) && cmp > price;
        const off = onSale ? Math.round(((cmp! - price) / cmp!) * 100) : 0;
        const badges: string[] = [];
        if (s.isNew) badges.push('<span class="rounded-pill bg-green px-2.5 py-1.5 text-[9.5px] font-bold uppercase tracking-[0.8px] text-white">New</span>');
        if (off >= 1) badges.push(`<span class="rounded-pill bg-coral px-2.5 py-1.5 text-[9.5px] font-bold uppercase tracking-[0.8px] text-white">-${off}%</span>`);
        if (!s.available) badges.push('<span class="rounded-pill bg-dark px-2.5 py-1.5 text-[9.5px] font-bold uppercase tracking-[0.8px] text-white">Sold out</span>');
        const lqip = s.image
          ? `<img src="${esc(s.image)}${s.image.includes('?') ? '&' : '?'}width=32" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full scale-110 object-cover blur-xl">`
          : '';
        const vendor = s.vendor
          ? `<span class="flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-[1.1px] text-green"><span class="h-[5px] w-[5px] rounded-pill bg-green"></span>${esc(s.vendor)}</span>`
          : '';
        const priceHtml = `${fmt(s.price, s.currency)}${onSale ? `<span class="ml-1.5 text-[12.5px] font-medium text-text-muted line-through">${fmt(String(cmp), s.currency)}</span>` : ''}`;
        let cta: string;
        if (s.variantId && s.available && !s.requiresChoice) {
          cta = `<button type="button" data-variant-id="${esc(s.variantId)}" aria-label="Add ${esc(s.title)} to bag" class="add-to-bag-btn inline-flex flex-none items-center gap-1.5 rounded-md bg-dark px-3 py-2 text-[11px] font-bold uppercase tracking-[0.5px] text-white transition-fluid hover:bg-coral disabled:opacity-50 data-[loading]:pointer-events-none"><span class="btn-default inline-flex items-center gap-1.5">${svg(ICON.plus, 14)} Add</span><span class="btn-loading hidden items-center gap-1.5"><span class="h-3.5 w-3.5 animate-spin rounded-pill border-2 border-current border-t-transparent"></span> Add</span></button>`;
        } else if (s.available && s.requiresChoice) {
          cta = `<button type="button" data-quick-view="${esc(s.handle)}" aria-label="Choose options for ${esc(s.title)}" class="quick-view-btn inline-flex flex-none items-center gap-1.5 rounded-md bg-dark px-3 py-2 text-[11px] font-bold uppercase tracking-[0.5px] text-white transition-fluid hover:bg-coral">${svg(ICON.plus, 14)} Add</button>`;
        } else {
          cta = `<a href="${href}" class="inline-flex flex-none items-center gap-1.5 rounded-md bg-dark px-3 py-2 text-[11px] font-bold uppercase tracking-[0.5px] text-white transition-fluid hover:bg-coral">${svg(ICON.plus, 14)} Add</a>`;
        }
        const widthCls = rail ? 'flex-none w-[78%] sm:w-[46%] lg:w-[calc(25%_-_18px)] snap-start' : '';
        return `<article class="pcard group relative overflow-hidden rounded-lg bg-surface shadow-xs transition-fluid hover:-translate-y-[5px] hover:shadow-md ${widthCls}">
    <div class="relative aspect-[3/4] overflow-hidden bg-surface-cool">
      <div class="absolute left-3 top-3 z-[2] flex flex-col gap-1.5">${badges.join('')}</div>
      <div class="absolute right-3 top-3 z-[3] flex flex-col gap-2">
        <button type="button" data-wishlist="${esc(s.id)}" aria-label="Add ${esc(s.title)} to wishlist" aria-pressed="false" class="wishlist-btn grid h-9 w-9 place-items-center rounded-full bg-white text-dark shadow-sm transition-fluid hover:scale-110 ${reveal}">${svg(ICON.heart, 16)}</button>
        <button type="button" data-quick-view="${esc(s.handle)}" aria-label="Quick view ${esc(s.title)}" class="quick-view-btn grid h-9 w-9 place-items-center rounded-full bg-white text-dark shadow-sm transition-fluid hover:scale-110 hover:bg-coral hover:text-white ${reveal}">${svg(ICON.eye, 17)}</button>
      </div>
      <a href="${href}" class="block h-full w-full">${lqip}<img src="${esc(s.image)}" alt="${esc(s.title)}" loading="lazy" decoding="async" class="relative z-[1] h-full w-full object-cover transition-transform duration-[1000ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.05]"></a>
    </div>
    <div class="px-[17px] pb-[18px] pt-4">
      ${vendor}
      <a href="${href}"><h3 class="my-2 font-heading text-[21px] font-bold leading-[0.98] text-text-primary transition-fluid hover:text-coral">${esc(s.title)}</h3></a>
      <div class="flex items-center justify-between border-t border-border pt-3">
        <span class="text-[16px] font-bold tabular">${priceHtml}</span>
        ${cta}
      </div>
    </div>
  </article>`;
      };

      let list: (Snap | undefined)[] = [];
      try {
        const parsed = JSON.parse(localStorage.getItem(KEY) || '[]');
        if (Array.isArray(parsed)) list = parsed;
      } catch {
        list = [];
      }
      const others = list
        .filter((p): p is Snap => Boolean(p && p.handle && p.handle !== snap?.handle))
        .slice(0, 12);
      const grid = $<HTMLElement>('[data-recent-grid]');
      const section = $<HTMLElement>('[data-recent]');
      if (grid && section && others.length) {
        const rail = others.length > 4; // grid for 1–4, slider beyond
        grid.className = `recent-track ${rail ? 'is-rail' : 'is-grid'}`;
        grid.innerHTML = others.map((s) => rvCard(s, rail)).join('');
        section.hidden = false;

        // Arrows only in slider mode.
        const nav = $<HTMLElement>('[data-recent-nav]');
        if (nav) nav.hidden = !rail;
        if (rail) {
          const page = () => Math.max(grid.clientWidth * 0.9, 260);
          $('[data-recent-prev]')?.addEventListener('click', () =>
            grid.scrollBy({ left: -page(), behavior: 'smooth' }),
          );
          $('[data-recent-next]')?.addEventListener('click', () =>
            grid.scrollBy({ left: page(), behavior: 'smooth' }),
          );
        }

        // Wire card actions (self-contained — no reliance on ProductCard's script).
        grid.querySelectorAll<HTMLButtonElement>('.add-to-bag-btn').forEach((b) =>
          b.addEventListener('click', async (e) => {
            e.preventDefault();
            const v = b.dataset.variantId;
            if (!v || b.hasAttribute('data-loading')) return;
            b.setAttribute('data-loading', '');
            try {
              await addItem(v, 1);
            } finally {
              b.removeAttribute('data-loading');
            }
          }),
        );
        grid.querySelectorAll<HTMLElement>('.quick-view-btn').forEach((b) =>
          b.addEventListener('click', (e) => {
            e.preventDefault();
            const h = b.dataset.quickView;
            if (h) window.dispatchEvent(new CustomEvent('quickview:open', { detail: { handle: h } }));
          }),
        );
        const paintRV = () => {
          const saved = new Set($wishlist.get());
          grid.querySelectorAll<HTMLElement>('.wishlist-btn').forEach((b) => {
            const on = saved.has(b.dataset.wishlist || '');
            b.classList.toggle('is-active', on);
            b.setAttribute('aria-pressed', String(on));
          });
        };
        grid.querySelectorAll<HTMLButtonElement>('.wishlist-btn').forEach((b) =>
          b.addEventListener('click', (e) => {
            e.preventDefault();
            const id = b.dataset.wishlist;
            if (id) {
              toggleWishlist(id);
              window.dispatchEvent(new CustomEvent('wishlist-updated'));
            }
          }),
        );
        paintRV();
        $wishlist.subscribe(paintRV);
      }
      // Record the current product at the front (deduped), cap at 12.
      if (snap?.handle) {
        const next = [snap, ...list.filter((p) => p && p.handle !== snap.handle)].slice(0, 12);
        localStorage.setItem(KEY, JSON.stringify(next));
      }
    } catch {
      /* storage disabled — skip the rail */
    }

    // ── Reviews: client-side filter + progressive reveal ───
    const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-rv-list] .rv-card'));
    if (cards.length) {
      const PER = 3;
      let filter = 'all';
      let shown = PER;
      const noResult = $<HTMLElement>('[data-rv-noresult]');
      const moreWrap = $<HTMLElement>('[data-rv-more]');

      const matches = (c: HTMLElement) =>
        filter === 'all' ||
        (filter === 'photos' ? c.dataset.hasPhotos === '1' : c.dataset.rating === filter);

      const apply = () => {
        const eligible = cards.filter(matches);
        cards.forEach((c) => (c.style.display = 'none'));
        eligible.slice(0, shown).forEach((c) => (c.style.display = ''));
        if (noResult) noResult.style.display = eligible.length ? 'none' : '';
        if (moreWrap) moreWrap.style.display = eligible.length > shown ? '' : 'none';
      };

      root.querySelectorAll<HTMLButtonElement>('[data-rv-filters] .rv-fp').forEach((b) => {
        b.addEventListener('click', () => {
          root.querySelectorAll('[data-rv-filters] .rv-fp').forEach((x) => x.classList.remove('on'));
          b.classList.add('on');
          filter = b.dataset.f || 'all';
          shown = PER;
          apply();
        });
      });
      $('[data-rv-loadmore]')?.addEventListener('click', () => {
        shown += PER;
        apply();
      });
      apply();
    }

    // ── Write a review (MP-26 → Judge.me, awaits moderation) ───
    const form = $<HTMLFormElement>('[data-rv-form]');
    if (form) {
      const wrap = $<HTMLElement>('[data-rv-write]');
      const openBtn = $<HTMLButtonElement>('[data-rv-write-open]');
      const closeBtn = $<HTMLButtonElement>('[data-rv-write-close]');
      const stars = Array.from(form.querySelectorAll<HTMLButtonElement>('.rv-star'));
      const ratingInput = form.querySelector<HTMLInputElement>('[data-rv-rating]');
      const submitBtn = form.querySelector<HTMLButtonElement>('[data-rv-submit]');
      const submitLabel = form.querySelector<HTMLElement>('.rv-submit-label');
      const submitSpin = form.querySelector<HTMLElement>('.rv-submit-spin');
      const statusEl = form.querySelector<HTMLElement>('[data-rv-status]');
      let rating = 0;
      let sending = false;
      let done = false;

      const paint = (n: number) =>
        stars.forEach((s, i) => s.classList.toggle('is-on', i < n));

      const openForm = () => {
        if (!wrap) return;
        wrap.hidden = false;
        openBtn?.setAttribute('aria-expanded', 'true');
        wrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
        form.querySelector<HTMLInputElement>('input[name="name"]')?.focus({ preventScroll: true });
      };
      const closeForm = () => {
        if (!wrap) return;
        wrap.hidden = true;
        openBtn?.setAttribute('aria-expanded', 'false');
      };

      openBtn?.addEventListener('click', () => (wrap?.hidden ? openForm() : closeForm()));
      closeBtn?.addEventListener('click', closeForm);

      stars.forEach((star, i) => {
        const val = Number(star.dataset.val) || i + 1;
        star.addEventListener('mouseenter', () => paint(val));
        star.addEventListener('focus', () => paint(val));
        star.addEventListener('click', () => {
          rating = val;
          if (ratingInput) ratingInput.value = String(val);
          stars.forEach((s, si) => s.setAttribute('aria-checked', si < val ? 'true' : 'false'));
          paint(val);
        });
      });
      form.querySelector('[data-rv-stars]')?.addEventListener('mouseleave', () => paint(rating));

      const setStatus = (msg: string, ok: boolean) => {
        if (!statusEl) return;
        statusEl.textContent = msg;
        statusEl.hidden = false;
        statusEl.classList.toggle('is-ok', ok);
        statusEl.classList.toggle('is-err', !ok);
      };

      const EMAIL = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (sending || done) return;

        const data = new FormData(form);
        const name = String(data.get('name') ?? '').trim();
        const email = String(data.get('email') ?? '').trim();
        const bodyText = String(data.get('body') ?? '').trim();

        // Mirror the server rules so the shopper sees the failing field instantly.
        form.querySelectorAll('.is-invalid').forEach((el) => el.classList.remove('is-invalid'));
        if (!rating) {
          setStatus('Please choose a star rating.', false);
          form.querySelector('.rv-stars')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        if (!name) {
          form.querySelector('input[name="name"]')?.classList.add('is-invalid');
          setStatus('Please enter your name.', false);
          return;
        }
        if (!EMAIL.test(email)) {
          form.querySelector('input[name="email"]')?.classList.add('is-invalid');
          setStatus('Please enter a valid email.', false);
          return;
        }
        if (bodyText.length < 10) {
          form.querySelector('textarea[name="body"]')?.classList.add('is-invalid');
          setStatus('Please add a little more detail to your review.', false);
          return;
        }

        sending = true;
        submitBtn?.setAttribute('disabled', '');
        if (submitLabel) submitLabel.hidden = true;
        if (submitSpin) submitSpin.hidden = false;
        if (statusEl) statusEl.hidden = true;

        try {
          const res = await fetch('/api/reviews/create', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              productId: form.dataset.productId,
              rating,
              name,
              email,
              title: String(data.get('title') ?? '').trim(),
              body: bodyText,
              website: String(data.get('website') ?? ''),
            }),
          });
          const payload = (await res.json().catch(() => ({}))) as {
            ok?: boolean;
            message?: string;
            error?: string;
          };
          if (res.ok && payload.ok) {
            done = true; // one submission per page view — Judge.me has no idempotency key
            form.querySelectorAll<HTMLElement>('input, textarea, .rv-star').forEach((el) =>
              el.setAttribute('disabled', ''),
            );
            setStatus(
              payload.message ?? 'Thank you! Your review will appear once approved.',
              true,
            );
            if (submitBtn) submitBtn.style.display = 'none';
          } else {
            setStatus(payload.error ?? 'Something went wrong. Please try again.', false);
          }
        } catch {
          setStatus('We could not reach the review service. Please try again shortly.', false);
        } finally {
          sending = false;
          if (!done) {
            submitBtn?.removeAttribute('disabled');
            if (submitLabel) submitLabel.hidden = false;
            if (submitSpin) submitSpin.hidden = true;
          }
        }
      });
    }
  }

  initPdp();
  document.addEventListener('astro:page-load', initPdp);
</script>
