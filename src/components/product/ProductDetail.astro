---
// ============================================================
//  ProductDetail — 1:1 port of the designer's PDP (Product.html):
//  editorial hero, sticky gallery + buy box, customer reviews and
//  "you may also like". Real Shopify data drives the title, price,
//  images, colour/size options, variants and recommendations; the
//  add-to-bag / buy-now resolve the matching variant and hit the
//  live cart. Reviews are REAL Judge.me reviews (read server-side via
//  the REST API, rendered here in the PDP's own UI). All behaviour
//  lives in the bundled <script> below.
// ============================================================
import Icon from '~/components/ui/Icon.astro';
import ProductCard from '~/components/cards/ProductCard.astro';
import SizeGuide from '~/components/global/SizeGuide.astro';
import { SITE } from '~/config/site';
import { formatMoney, discountPercent } from '~/lib/utils';
import type { Product, ProductCard as TProductCard } from '~/lib/shopify/types';
import type { JudgeMeData } from '~/lib/judgeme';

interface Props {
  product: Product;
  recommendations: TProductCard[];
  reviews: JudgeMeData | null;
}

const { product, recommendations, reviews } = Astro.props;

// ── Reviews summary (real Judge.me data) ────────────────────
const rv = reviews && reviews.count > 0 ? reviews : null;
const rvAvg = rv ? rv.average.toFixed(1) : null;
const rvCount = rv?.count ?? 0;
const fullStars = rv ? Math.round(rv.average) : 0;
const starRow = (n: number) => '★★★★★'.slice(0, n) + '☆☆☆☆☆'.slice(0, 5 - n);
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const currency = product.priceRange.minVariantPrice.currencyCode;
const priceNow = formatMoney(product.priceRange.minVariantPrice.amount, currency);
const compareAt = product.compareAtPriceRange?.minVariantPrice ?? null;
const off = discountPercent(product.priceRange.minVariantPrice, compareAt);
const priceWas = compareAt ? formatMoney(compareAt.amount, currency) : null;

// ── Structured data ─────────────────────────────────────────
// Always emit a Product node with an `offers` object (price + availability +
// currency) so the PDP produces a valid product rich result even with zero
// reviews; merge aggregateRating/review only when real Judge.me reviews exist.
const productUrl = new URL(`/products/${product.handle}`, Astro.url.origin).href;
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.description || undefined,
  image: (product.images?.length
    ? product.images
    : product.featuredImage
      ? [product.featuredImage]
      : []
  )
    .map((i) => i.url)
    .slice(0, 8),
  brand: product.vendor ? { '@type': 'Brand', name: product.vendor } : undefined,
  url: productUrl,
  offers: {
    '@type': 'Offer',
    price: product.priceRange.minVariantPrice.amount,
    priceCurrency: currency,
    availability: product.availableForSale
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    url: productUrl,
  },
  ...(rv
    ? {
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: rv.average,
          reviewCount: rv.count,
        },
        review: rv.reviews.slice(0, 20).map((r) => ({
          '@type': 'Review',
          reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
          author: { '@type': 'Person', name: r.name },
          datePublished: r.createdAt,
          name: r.title,
          reviewBody: r.body,
        })),
      }
    : {}),
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.url.origin },
    { '@type': 'ListItem', position: 2, name: 'Shop', item: new URL('/collections/all', Astro.url.origin).href },
    { '@type': 'ListItem', position: 3, name: product.title, item: productUrl },
  ],
};

// Title → "lead <em>last.</em>" for the editorial hero.
const words = product.title.trim().split(/\s+/);
const titleLast = words.length > 1 ? words[words.length - 1] : product.title;
const titleLead = words.length > 1 ? words.slice(0, -1).join(' ') : '';

const category = product.productType || 'The Edit';
const intro = product.description || '';

// ── Editorial facts from metafields (all optional — the PDP hides the
// element when unset; no fabricated defaults). See README "Product metafields".
const mf = product.metafields ?? {};
const sku = product.variants.find((v) => v.sku)?.sku ?? null;
const soldCount = mf.unitsSold && Number.isFinite(Number(mf.unitsSold)) ? Number(mf.unitsSold) : null;
const isNew = mf.newBadge === 'true' || mf.newBadge === '1';
const fitBullets = [
  ...(mf.fitNotes ? mf.fitNotes.split('\n').map((s) => s.trim()).filter(Boolean) : []),
  ...(mf.modelNote ? [mf.modelNote] : []),
];
// Any materials/care fact present? Controls the whole accordion item.
const specRows = [
  ['Outer', mf.material],
  ['Lining', mf.lining],
  ['Weight', mf.weight],
  ['Origin', mf.origin],
  ['Care', mf.care],
  ['SKU', sku],
].filter(([, v]) => Boolean(v)) as [string, string][];
// Free-shipping threshold — single source of truth (SITE), shown in shop currency.
const freeShip = formatMoney(SITE.freeShippingThreshold, currency);

// Gallery images (fall back to the featured image).
const images =
  product.images.length > 0
    ? product.images
    : product.featuredImage
      ? [product.featuredImage]
      : [];

// Swatch hexes for known colour names; falls back to the name as a CSS colour.
const COLORS: Record<string, string> = {
  dark: '#2b2e31', black: '#1b1d1f', tan: '#c8b89a', cream: '#f1e7d6', ivory: '#f1e7d6',
  coral: '#d95846', green: '#5a9761', blue: '#4576e7', sand: '#cbb68f', gold: '#c9a227',
  slate: '#3a4250', charcoal: '#3a3d40', camel: '#c2a878', grey: '#8d969c', gray: '#8d969c',
  navy: '#22304a', white: '#f5f5f0', brown: '#6e5641', olive: '#6b6a44', stone: '#d8ccbb',
};
const swatchHex = (name: string) => COLORS[name.trim().toLowerCase()] ?? name.toLowerCase();

const colorOption = product.options.find((o) => /colou?r/i.test(o.name));
// Second picker = the Size option, or — for products optioned by Material,
// Style, Fit, etc. — the first non-colour option, so EVERY two-option product
// is fully selectable (not just Colour/Size). Products with a 3rd option fall
// back to their first two dimensions.
const sizeOption =
  product.options.find((o) => /size/i.test(o.name)) ??
  product.options.find((o) => o.name !== colorOption?.name);
// Only a real size picker gets the "Size guide" affordance.
const isSizeOption = !!sizeOption && /size/i.test(sizeOption.name);

// Which size values are buyable (some variant with that value is in stock).
const availableSizes = new Set<string>();
if (sizeOption) {
  for (const v of product.variants) {
    if (!v.availableForSale) continue;
    const sz = v.selectedOptions.find((o) => o.name === sizeOption.name)?.value;
    if (sz) availableSizes.add(sz);
  }
}

const colors = (colorOption?.optionValues ?? []).map((ov) => ({
  label: ov.name,
  hex: swatchHex(ov.name),
}));
const sizes = (sizeOption?.optionValues ?? []).map((ov) => ({
  label: ov.name,
  ok: availableSizes.has(ov.name),
}));

const defaultColor = colors[0]?.label ?? '';
const defaultSize = sizes.find((s) => s.ok)?.label ?? sizes[0]?.label ?? '';

// Compact variant index handed to the client to resolve a selection → id.
const variantData = product.variants.map((v) => ({
  id: v.id,
  available: v.availableForSale,
  color: colorOption ? (v.selectedOptions.find((o) => o.name === colorOption.name)?.value ?? '') : '',
  size: sizeOption ? (v.selectedOptions.find((o) => o.name === sizeOption.name)?.value ?? '') : '',
  amount: v.price.amount,
  compareAt: v.compareAtPrice?.amount ?? null,
}));

const config = JSON.stringify({
  productId: product.id,
  currency,
  hasColor: !!colorOption,
  hasSize: !!sizeOption,
  defaultColor,
  defaultSize,
  unitAmount: product.priceRange.minVariantPrice.amount,
  variants: variantData,
});

const addPriceLabel = formatMoney(
  Number(product.priceRange.minVariantPrice.amount),
  currency,
);

---

<div class="pdp-root" data-config={config}>
  {/* ===================== PRODUCT HERO ===================== */}
  <section class="shop-hero pdp-hero">
    <div class="container-mag">
      <span class="mag-label">{category}{product.vendor ? ` · ${product.vendor}` : ''}</span>
      <div class="sh-grid">
        <h1>{titleLead && <>{titleLead} </>}<em>{titleLast}.</em></h1>
        {intro && <p class="sh-intro">{intro}</p>}
      </div>
      <div class="sh-stats">
        {rv && <div class="st"><b>{rvAvg}★</b><span>{rvCount} {rvCount === 1 ? 'Review' : 'Reviews'}</span></div>}
        {mf.origin && <div class="st"><b>{mf.origin}</b><span>Made In</span></div>}
        {mf.dispatch && <div class="st"><b>{mf.dispatch}</b><span>Ships Within</span></div>}
        <div class="st"><b>30-Day</b><span>Free Returns</span></div>
      </div>
    </div>
  </section>

  {/* ===================== PRODUCT DETAILS ===================== */}
  <section class="pdp">
    <div class="container-mag">
      <div class="pdp-grid">
        {/* Gallery */}
        <div class="pdp-gallery">
          <div class="pg-thumbs">
            {images.map((img, i) => (
              <div
                class:list={['pg-thumb', i === 0 && 'on']}
                data-src={img.url}
                role="button"
                tabindex="0"
                aria-label={`View image ${i + 1}`}
              >
                <img src={img.url} alt={img.altText ?? `View ${i + 1}`} loading="lazy" />
              </div>
            ))}
          </div>
          <div class="pg-main">
            <div class="pg-badges">
              {isNew && <span class="tagb coral">New</span>}
              {off && <span class="tagb dark">-{off}%</span>}
            </div>
            <button class="pg-fav" data-pdp-fav aria-label="Add to wishlist">
              <Icon name="heart" size={20} />
            </button>
            <span class="pg-zoom"><Icon name="zoomIn" size={14} /> Hover to zoom</span>
            <img id="pgMain" src={images[0]?.url} alt={product.title} />
          </div>
        </div>

        {/* Info / buy box */}
        <div class="pdp-info">
          <div class="pdp-eyebrow">
            <span class="pdp-cat">{category}</span>
            {product.vendor && <span class="pdp-desg">by <b>{product.vendor}</b></span>}
          </div>
          <h2 class="pdp-name">{product.title}</h2>
          <div class="pdp-meta">
            {rv ? (
              <span class="pdp-stars">
                <span class="s">{starRow(fullStars)}</span> {rvAvg}{' '}
                <a href="#reviews">({rvCount} {rvCount === 1 ? 'review' : 'reviews'})</a>
              </span>
            ) : (
              <span class="pdp-stars pdp-stars--empty">
                <span class="s">{starRow(0)}</span> <a href="#reviews">No reviews yet</a>
              </span>
            )}
            {soldCount && (
              <span class="pdp-sold"><Icon name="fire" size={15} /> {soldCount} sold this month</span>
            )}
          </div>
          <div class="pdp-price">
            <span class="now" data-price-now>{priceNow}</span>
            <span class="was" data-price-was hidden={!priceWas}>{priceWas}</span>
            <span class="off" data-price-off hidden={!off}>{off ? `Save ${off}%` : ''}</span>
          </div>
          <p class="pdp-tax">Import duties included · <b>Free shipping</b> over {freeShip}</p>
          {intro && <p class="pdp-lead">{intro}</p>}
          <div class="pdp-divider"></div>

          {colors.length > 0 && (
            <div class="opt">
              <div class="opt-head">
                <h6>{colorOption?.name ?? 'Colour'}</h6>
                <span class="sel" data-color-label>{defaultColor}</span>
              </div>
              <div class="opt-colors">
                {colors.map((c, i) => (
                  <span
                    class:list={['opt-color', i === 0 && 'on']}
                    data-color={c.label}
                    title={c.label}
                    role="button"
                    tabindex="0"
                    aria-label={`Colour: ${c.label}`}
                    aria-pressed={i === 0 ? 'true' : 'false'}
                    style={`background:${c.hex}`}
                  />
                ))}
              </div>
            </div>
          )}

          {sizes.length > 0 && (
            <div class="opt">
              <div class="opt-head">
                <h6>{sizeOption?.name ?? 'Size'}</h6>
                {isSizeOption && (
                  <button type="button" class="guide" data-sg-open><Icon name="ruler" size={14} /> Size guide</button>
                )}
              </div>
              <div class="opt-sizes">
                {sizes.map((z) => (
                  <button
                    class:list={['opt-size', !z.ok && 'off', z.label === defaultSize && 'on']}
                    data-size={z.label}
                    disabled={!z.ok}
                  >
                    {z.label}
                  </button>
                ))}
              </div>
            </div>
          )}

          <div class="buy-row">
            <div class="qty-step">
              <button data-qdec aria-label="Decrease">−</button>
              <span data-qval>1</span>
              <button data-qinc aria-label="Increase">+</button>
            </div>
            <button class="buy-add" data-pdp-add>
              Add to Bag · <span data-add-price>{addPriceLabel}</span>
              <Icon name="bag" size={18} />
            </button>
          </div>
          <button class="buy-now" data-pdp-buy>Buy it now <Icon name="arrowRight" size={16} /></button>

          <div class="pdp-trust">
            <div class="trust-i">
              <Icon name="truck" size={22} /><b>Free Delivery</b><span>2–4 days, orders over {freeShip}</span>
            </div>
            <div class="trust-i">
              <Icon name="rotate" size={22} /><b>30-Day Returns</b><span>Free &amp; easy returns</span>
            </div>
            <div class="trust-i">
              <Icon name="sealCheck" size={22} /><b>Authenticity</b><span>Guaranteed genuine</span>
            </div>
          </div>

          <div class="acc" data-acc>
            {(fitBullets.length > 0 || intro) && (
              <div class="acc-item open">
                <button class="acc-head" aria-expanded="true">Details &amp; Fit <Icon name="plus" size={20} /></button>
                <div class="acc-body">
                  <div class="inner">
                    {fitBullets.length > 0 ? (
                      <ul>
                        {fitBullets.map((b) => (
                          <li><Icon name="check" size={15} /> {b}</li>
                        ))}
                      </ul>
                    ) : (
                      <p>{intro}</p>
                    )}
                  </div>
                </div>
              </div>
            )}
            {specRows.length > 0 && (
              <div class="acc-item">
                <button class="acc-head" aria-expanded="false">Materials &amp; Care <Icon name="plus" size={20} /></button>
                <div class="acc-body">
                  <div class="inner">
                    <div class="specs">
                      {specRows.map(([label, value]) => (
                        <div><span>{label}</span><b>{value}</b></div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            )}
            <div class="acc-item">
              <button class="acc-head" aria-expanded="false">Shipping &amp; Returns <Icon name="plus" size={20} /></button>
              <div class="acc-body">
                <div class="inner">
                  Complimentary express shipping on all orders over {freeShip}, delivered in 2–4 business
                  days. Enjoy 30 days to return unworn pieces with tags attached — returns are free
                  and fully refunded. Same-day click &amp; collect available at our {SITE.flagshipName}.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===================== REVIEWS (real Judge.me data) ===================== */}
  <section class="reviews" id="reviews" data-reviews>
    <div class="container-mag">
      <div class="rv-head">
        <div>
          <span class="mag-label">Customer Reviews</span>
          <h2>What the <em>editors &amp; buyers</em> say.</h2>
        </div>
        {rv && (
          <div class="rv-filters" data-rv-filters>
            <span class="fl">Filter</span>
            <button class="rv-fp on" data-f="all">All</button>
            <button class="rv-fp" data-f="5">5 ★</button>
            <button class="rv-fp" data-f="4">4 ★</button>
            <button class="rv-fp" data-f="photos">With photos</button>
          </div>
        )}
      </div>

      {rv ? (
        <div class="rv-layout">
          <aside class="rv-summary">
            <div class="rv-score">{rvAvg}<sub>/5</sub></div>
            <div class="rv-sstars">{starRow(fullStars)}</div>
            <div class="rv-scount">Based on {rvCount} verified {rvCount === 1 ? 'review' : 'reviews'}</div>
            <div class="rv-bars">
              {([5, 4, 3, 2, 1] as const).map((s) => {
                const c = rv.histogram[s];
                const pct = rvCount ? Math.round((c / rvCount) * 100) : 0;
                return (
                  <div class="rv-bar">
                    <span class="lab">{s} ★</span>
                    <span class="track"><span class="fill" style={`width:${pct}%`} /></span>
                    <span class="pct">{pct}%</span>
                  </div>
                );
              })}
            </div>
            <div class="rv-rec-line"><b>{rv.recommendPct}%</b> would recommend this piece</div>
          </aside>

          <div>
            <div class="rv-list" data-rv-list>
              {rv.reviews.map((r, i) => (
                <article
                  class="rv-card"
                  data-rating={r.rating}
                  data-has-photos={r.pictures.length ? '1' : '0'}
                  data-index={i}
                  style={i >= 3 ? 'display:none' : ''}
                >
                  <div class="rv-top">
                    <span class="rv-av">{r.name.charAt(0).toUpperCase()}</span>
                    <div class="rv-who">
                      <b>{r.name}</b>
                      {r.verified && (
                        <span class="vf"><Icon name="sealCheck" size={13} /> Verified Buyer</span>
                      )}
                    </div>
                    <span class="rv-when">{fmtDate(r.createdAt)}</span>
                  </div>
                  <div class="rv-rate">{starRow(r.rating)}</div>
                  {r.title && <h5>{r.title}</h5>}
                  {r.body && <p>{r.body}</p>}
                  {r.pictures.length > 0 && (
                    <div class="rv-photos">
                      {r.pictures.map((src) => (
                        <img src={src} alt={`${r.name}'s photo`} loading="lazy" />
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
            <div class="rv-empty-filter" data-rv-noresult style="display:none">
              No reviews match this filter yet.
            </div>
            {rvCount > 3 && (
              <div class="rv-more" data-rv-more>
                <button class="btn-load" data-rv-loadmore>
                  Load more reviews <Icon name="arrowDown" size={16} />
                </button>
              </div>
            )}
          </div>
        </div>
      ) : (
        <div class="rv-empty">
          <p class="rv-empty-title">No reviews yet</p>
          <p class="rv-empty-sub">Be the first to share your thoughts on the {product.title}.</p>
        </div>
      )}
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />


  {/* ===================== YOU MAY ALSO LIKE ===================== */}
  {recommendations.length > 0 && (
    <section class="related">
      <div class="container-mag">
        <div class="rel-head">
          <div>
            <span class="mag-label">Complete the Look</span>
            <h2>You may <em>also like.</em></h2>
          </div>
          <a href="/products" class="rel-cta">View All Products <Icon name="arrowRight" size={15} /></a>
        </div>
        <div class="rel-grid">
          {recommendations.slice(0, 4).map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ===================== SIZE GUIDE MODAL ===================== */}
  {sizes.length > 0 && (
    <div class="sg-overlay" data-sg-overlay hidden>
      <div class="sg-modal" role="dialog" aria-modal="true" aria-label="Size guide">
        <div class="sg-modal-head">
          <div>
            <span class="mag-label">Find Your Fit</span>
            <h3>Size guide</h3>
          </div>
          <button type="button" class="sg-close" data-sg-close aria-label="Close size guide">
            <Icon name="close" size={20} />
          </button>
        </div>
        <div class="sg-modal-body">
          <SizeGuide />
        </div>
        <a href="/size-guide" class="sg-modal-foot">
          Open the full size guide <Icon name="arrowRight" size={15} />
        </a>
      </div>
    </div>
  )}

</div>

<style>
  /* ============================================================
     PDP — ported 1:1 from the designer's Product.html, with the
     mockup's --mag-* / --r-* variables mapped to project tokens.
     ============================================================ */

  /* ---- Editorial hero ---- */
  .shop-hero {
    padding: 60px 0;
  }
  .shop-hero .mag-label {
    margin-bottom: 18px;
  }
  .pdp-hero {
    padding-bottom: 60px;
  }
  .sh-grid {
    display: flex;
    gap: 40px;
    align-items: start;
    justify-content: space-between;
  }
  .sh-grid h1 {
    font-family: var(--font-heading);
    font-size: clamp(54px, 7.2vw, 112px);
    font-weight: 800;
    line-height: 0.8;
    letter-spacing: -1.5px;
    text-transform: uppercase;
  }
  .sh-grid h1 em {
    font-style: normal;
    color: var(--color-coral);
  }
  .sh-intro {
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 430px;
    padding-top: 12px;
    /* Cap the hero intro at three lines regardless of the product copy. */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }
  .sh-stats {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    margin-top: 34px;
  }
  .sh-stats .st {
    padding-right: 18px;
    box-shadow: inset -1px 0 0 var(--color-border);
  }
  .sh-stats .st:last-child {
    box-shadow: none;
  }
  .sh-stats .st b {
    font-family: var(--font-heading);
    font-size: 34px;
    font-weight: 800;
    line-height: 0.9;
    display: block;
  }
  .sh-stats .st span {
    font-size: 10.5px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-top: 7px;
    display: block;
  }

  /* ---- Detail block ---- */
  .pdp {
    padding: 120px 0;
    background: var(--color-surface);
  }
  .pdp-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 54px;
    align-items: start;
  }

  /* ---- Gallery ---- */
  .pdp-gallery {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 16px;
    position: sticky;
    top: 96px;
  }
  .pg-thumbs {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pg-thumb {
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--color-surface-cool);
    cursor: pointer;
    box-shadow: inset 0 0 0 1px var(--color-border);
    transition: box-shadow 0.25s, opacity 0.25s;
    opacity: 0.65;
  }
  .pg-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pg-thumb.on {
    opacity: 1;
    box-shadow: inset 0 0 0 2px var(--color-coral);
  }
  .pg-thumb:hover {
    opacity: 1;
  }
  .pg-main {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-surface-cool);
    aspect-ratio: 4/5;
  }
  .pg-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s var(--ease-out-soft);
  }
  .pg-main:hover img {
    transform: scale(1.04);
  }
  .pg-badges {
    position: absolute;
    top: 18px;
    left: 18px;
    display: flex;
    gap: 8px;
    z-index: 2;
  }
  .pg-fav {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-primary);
    z-index: 2;
    box-shadow: var(--shadow-sm);
    transition: all 0.25s;
  }
  .pg-fav:hover,
  .pg-fav.on {
    color: var(--color-coral);
  }
  .pg-fav.on :global(svg) {
    fill: var(--color-coral);
  }
  .pg-zoom {
    position: absolute;
    bottom: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
    background: rgba(21, 23, 25, 0.5);
    padding: 9px 14px;
    border-radius: var(--radius-pill);
    z-index: 2;
  }

  /* ---- Tags ---- */
  .tagb {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 6px 11px;
    border-radius: var(--radius-pill);
    color: #fff;
  }
  .tagb.coral {
    background: var(--color-coral);
  }
  .tagb.dark {
    background: var(--color-dark);
  }

  /* ---- Info ---- */
  .pdp-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .pdp-cat {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-coral);
  }
  .pdp-desg {
    font-size: 12px;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .pdp-desg b {
    color: var(--color-text-secondary);
    font-weight: 700;
  }
  .pdp-name {
    font-family: var(--font-heading);
    font-size: clamp(40px, 4.4vw, 62px);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.5px;
    margin-bottom: 16px;
  }
  .pdp-meta {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }
  .pdp-stars {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-secondary);
    font-weight: 600;
  }
  .pdp-stars .s {
    color: var(--color-coral);
    letter-spacing: 1px;
    font-size: 15px;
  }
  .pdp-stars a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pdp-sold {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12.5px;
    color: var(--color-green);
    font-weight: 700;
  }
  .pdp-price {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .pdp-price .now {
    font-family: var(--font-heading);
    font-size: 38px;
    font-weight: 800;
    color: var(--color-text-primary);
  }
  .pdp-price .was {
    font-size: 19px;
    color: var(--color-text-muted);
    text-decoration: line-through;
  }
  .pdp-price .off {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #fff;
    background: var(--color-coral);
    padding: 5px 10px;
    border-radius: var(--radius-xs);
  }
  .pdp-tax {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-bottom: 22px;
  }
  .pdp-tax b {
    color: var(--color-green);
    font-weight: 700;
  }
  .pdp-lead {
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
    max-width: 48ch;
  }
  .pdp-divider {
    height: 1px;
    background: var(--color-border);
    margin: 24px 0;
  }

  /* ---- Options ---- */
  .opt {
    margin-bottom: 24px;
  }
  .opt-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 13px;
  }
  .opt-head h6 {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .opt-head .sel {
    font-size: 12.5px;
    color: var(--color-text-secondary);
    font-weight: 600;
  }
  .opt-head .guide {
    font-size: 12px;
    color: var(--color-blue);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    background: none;
    transition: color 0.2s;
  }
  .opt-head .guide:hover {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ---- Size guide modal ---- */
  .sg-overlay {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: rgba(21, 23, 25, 0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s var(--ease-out-soft);
  }
  .sg-overlay[hidden] {
    display: none;
  }
  .sg-overlay.is-open {
    opacity: 1;
  }
  .sg-modal {
    width: min(860px, 100%);
    max-height: min(88vh, 860px);
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    transform: translateY(14px) scale(0.98);
    transition: transform 0.35s var(--ease-out-soft);
    overflow: hidden;
  }
  .sg-overlay.is-open .sg-modal {
    transform: none;
  }
  .sg-modal-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 26px 18px;
    border-bottom: 1px solid var(--color-border);
  }
  .sg-modal-head .mag-label {
    margin-bottom: 8px;
  }
  .sg-modal-head h3 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 800;
    line-height: 0.95;
    color: var(--color-text-primary);
  }
  .sg-close {
    flex: none;
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: background 0.2s;
  }
  .sg-close:hover {
    background: var(--color-surface-cool);
  }
  .sg-modal-body {
    padding: 24px 26px;
    overflow-y: auto;
  }
  .sg-modal-foot {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 26px;
    border-top: 1px solid var(--color-border);
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--color-coral);
    transition: gap 0.2s;
  }
  .sg-modal-foot:hover {
    gap: 12px;
  }
  @media (max-width: 680px) {
    .sg-modal-body {
      padding: 18px 16px;
    }
    .sg-modal-head {
      padding: 20px 18px 14px;
    }
    .sg-modal-head h3 {
      font-size: 24px;
    }
  }
  .opt-colors {
    display: flex;
    gap: 14px;
  }
  .opt-color {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    position: relative;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s;
  }
  .opt-color::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: var(--radius-pill);
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .opt-color.on::after {
    border-color: var(--color-text-primary);
  }
  /* Keyboard focus ring for the now-focusable swatches + thumbnails (H17). */
  .opt-color:focus-visible,
  .pg-thumb:focus-visible {
    outline: 2px solid var(--color-coral);
    outline-offset: 2px;
  }
  .opt-color:hover {
    transform: scale(1.07);
  }
  .opt-sizes {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .opt-size {
    min-width: 52px;
    padding: 13px 8px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text-primary);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border);
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
  }
  .opt-size:hover {
    box-shadow: inset 0 0 0 1px var(--color-text-muted);
  }
  .opt-size.on {
    background: var(--color-text-primary);
    color: #fff;
    box-shadow: none;
  }
  .opt-size.off {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* ---- Buy row ---- */
  .buy-row {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
  }
  .qty-step {
    display: inline-flex;
    align-items: center;
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .qty-step button {
    width: 46px;
    height: 54px;
    font-size: 20px;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qty-step span {
    min-width: 32px;
    text-align: center;
    font-weight: 700;
    font-size: 15px;
  }
  .buy-add {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    height: 54px;
    border-radius: var(--radius-sm);
    background: var(--color-coral);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    transition: background 0.3s;
  }
  .buy-add:hover {
    background: var(--color-coral-hover);
  }
  .buy-now {
    width: 100%;
    height: 52px;
    border-radius: var(--radius-sm);
    background: var(--color-dark);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    transition: background 0.3s;
    margin-bottom: 24px;
  }
  .buy-now:hover {
    background: var(--color-dark-hover);
  }

  /* ---- Trust ---- */
  .pdp-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 28px;
  }
  .trust-i {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 14px;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .trust-i :global(svg) {
    color: var(--color-coral);
  }
  .trust-i b {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .trust-i span {
    font-size: 11.5px;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ---- Accordions ---- */
  .acc {
    border-top: 1px solid var(--color-border);
  }
  .acc-item {
    border-bottom: 1px solid var(--color-border);
  }
  .acc-head {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 700;
    color: var(--color-text-primary);
    cursor: pointer;
  }
  .acc-head :global(svg) {
    color: var(--color-text-secondary);
    transition: transform 0.3s;
  }
  .acc-item.open .acc-head :global(svg) {
    transform: rotate(45deg);
  }
  .acc-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s var(--ease-out-soft);
  }
  .acc-body .inner {
    padding: 0 0 20px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }
  .acc-body .inner ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }
  .acc-body .inner li {
    display: flex;
    gap: 9px;
    align-items: flex-start;
  }
  .acc-body .inner li :global(svg) {
    color: var(--color-green);
    margin-top: 3px;
    flex: none;
  }
  .acc-body .specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 24px;
    margin-top: 4px;
  }
  .acc-body .specs div {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px dashed var(--color-border);
    font-size: 13px;
  }
  .acc-body .specs span {
    color: var(--color-text-muted);
  }
  .acc-body .specs b {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  /* ---- Reviews ---- */
  .reviews {
    padding: 120px 0;
    background: var(--color-surface-cool);
  }
  .rv-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 42px;
    flex-wrap: wrap;
  }
  .rv-head h2,
  .rel-head h2 {
    font-family: var(--font-heading);
    font-size: clamp(40px, 4.5vw, 58px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.5px;
  }
  .rv-head h2 em,
  .rel-head h2 em {
    font-style: normal;
    color: var(--color-coral);
  }
  .rv-head .mag-label,
  .rel-head .mag-label {
    margin-bottom: 16px;
  }
  .rv-head > div:first-child {
    flex: 1 1 auto;
  }
  .rv-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .rv-filters .fl {
    font-size: 10.5px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--color-text-muted);
    margin-right: 4px;
  }
  .rv-fp {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-secondary);
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border);
    cursor: pointer;
    transition: all 0.2s;
  }
  .rv-fp:hover {
    color: var(--color-text-primary);
  }
  .rv-fp.on {
    background: var(--color-coral);
    color: #fff;
    box-shadow: none;
  }
  .rv-layout {
    display: grid;
    grid-template-columns: 0.78fr 1.22fr;
    gap: 40px;
    align-items: start;
  }
  .rv-summary {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: 34px 30px;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 96px;
  }
  .rv-score {
    font-family: var(--font-heading);
    font-size: 76px;
    font-weight: 800;
    line-height: 0.85;
    color: var(--color-text-primary);
  }
  .rv-score sub {
    font-size: 24px;
    color: var(--color-text-muted);
    font-weight: 600;
    vertical-align: baseline;
  }
  .rv-sstars {
    color: var(--color-coral);
    font-size: 18px;
    letter-spacing: 2px;
    margin: 12px 0 6px;
  }
  .rv-scount {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-bottom: 24px;
  }
  .rv-bars {
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin-bottom: 22px;
  }
  .rv-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--color-text-secondary);
  }
  .rv-bar .lab {
    width: 30px;
    font-weight: 600;
    white-space: nowrap;
  }
  .rv-bar .track {
    flex: 1;
    height: 7px;
    border-radius: var(--radius-pill);
    background: var(--color-surface-cool);
    overflow: hidden;
  }
  .rv-bar .fill {
    display: block;
    height: 100%;
    background: var(--color-coral);
    border-radius: var(--radius-pill);
  }
  .rv-bar .pct {
    width: 34px;
    text-align: right;
    font-weight: 600;
  }
  .rv-rec-line {
    font-size: 12.5px;
    color: var(--color-text-secondary);
  }
  .rv-rec-line b {
    color: var(--color-green);
  }
  .rv-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .rv-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 26px;
    box-shadow: var(--shadow-xs);
  }
  .rv-top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 13px;
  }
  .rv-av {
    width: 46px;
    height: 46px;
    border-radius: var(--radius-pill);
    flex: none;
    display: grid;
    place-items: center;
    background: var(--color-coral-soft);
    color: var(--color-coral-hover);
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 800;
  }
  .rv-who b {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text-primary);
    display: block;
  }
  .rv-who .vf {
    font-size: 11px;
    color: var(--color-green);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 2px;
  }
  .rv-when {
    margin-left: auto;
    font-size: 12px;
    color: var(--color-text-muted);
  }
  .rv-rate {
    color: var(--color-coral);
    font-size: 14px;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .rv-card h5 {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 7px;
  }
  .rv-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 14px;
  }
  .rv-card p:last-child {
    margin-bottom: 0;
  }
  .rv-photos {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rv-photos img {
    width: 62px;
    height: 62px;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .rv-more {
    margin-top: 24px;
    text-align: center;
  }
  .btn-load {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    height: 50px;
    padding: 0 26px;
    border-radius: var(--radius-sm);
    background: var(--color-dark);
    color: #fff;
    font-size: 12.5px;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: background 0.3s;
  }
  .btn-load:hover {
    background: var(--color-dark-hover);
  }
  .rv-empty-filter,
  .rv-empty {
    padding: 44px 24px;
    text-align: center;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
  }
  .rv-empty-filter {
    color: var(--color-text-muted);
    font-size: 14px;
  }
  .rv-empty-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 800;
    color: var(--color-text-primary);
  }
  .rv-empty-sub {
    margin-top: 8px;
    font-size: 14px;
    color: var(--color-text-secondary);
  }
  .pdp-stars--empty .s {
    color: var(--color-border);
  }
  .pdp-stars--empty a {
    color: var(--color-text-muted);
  }

  /* ---- Related ---- */
  .related {
    padding: 90px 0;
  }
  .rel-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 38px;
    flex-wrap: wrap;
  }
  .rel-cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    height: 48px;
    padding: 0 24px;
    border-radius: var(--radius-sm);
    background: var(--color-coral);
    color: #fff;
    font-size: 12.5px;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: background 0.3s;
  }
  .rel-cta:hover {
    background: var(--color-coral-hover);
  }
  .rel-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1080px) {
    .pdp {
      padding: 70px 0;
    }
    .pdp-grid {
      grid-template-columns: 1fr;
      gap: 34px;
    }
    .pdp-gallery {
      position: static;
    }
    .rv-layout {
      grid-template-columns: 1fr;
      gap: 26px;
    }
    .rv-summary {
      position: static;
    }
    .rel-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 680px) {
    .pdp-gallery {
      grid-template-columns: 1fr;
    }
    .pg-thumbs {
      flex-direction: row;
      order: 2;
    }
    .pg-thumb {
      width: 70px;
      flex: none;
    }
    .pdp-trust {
      grid-template-columns: 1fr;
    }
    .buy-row {
      flex-wrap: wrap;
    }
    .acc-body .specs {
      grid-template-columns: 1fr;
    }
    .rel-grid {
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
  }
</style>

<script>
  import { addItem, buyNow } from '~/stores/cart';
  import { $wishlist, toggleWishlist } from '~/stores/wishlist';

  interface VariantInfo {
    id: string;
    available: boolean;
    color: string;
    size: string;
    amount: string;
    compareAt: string | null;
  }
  interface PdpConfig {
    productId: string;
    currency: string;
    hasColor: boolean;
    hasSize: boolean;
    defaultColor: string;
    defaultSize: string;
    unitAmount: string;
    variants: VariantInfo[];
  }

  function initPdp(): void {
    const root = document.querySelector<HTMLElement>('.pdp-root');
    if (!root || root.dataset.bound) return;
    root.dataset.bound = 'true';

    let cfg: PdpConfig;
    try {
      cfg = JSON.parse(root.dataset.config || '{}');
    } catch {
      return;
    }

    const $ = <T extends Element = HTMLElement>(sel: string) => root.querySelector<T>(sel);
    const money = (a: number) => {
      if (!Number.isFinite(a)) return '—';
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: cfg.currency,
        minimumFractionDigits: Number.isInteger(a) ? 0 : 2,
      }).format(a);
    };

    const state = { qty: 1, color: cfg.defaultColor, size: cfg.defaultSize };

    // ── Gallery ────────────────────────────────────────────
    const main = $<HTMLImageElement>('#pgMain');
    root.querySelectorAll<HTMLElement>('.pg-thumb').forEach((t) => {
      const activate = () => {
        root.querySelectorAll('.pg-thumb').forEach((x) => x.classList.remove('on'));
        t.classList.add('on');
        if (main && t.dataset.src) main.src = t.dataset.src;
      };
      t.addEventListener('click', activate);
      t.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activate();
        }
      });
    });

    // ── Variant resolution + price ─────────────────────────
    const resolve = (): VariantInfo | null =>
      cfg.variants.find(
        (v) =>
          (!cfg.hasColor || v.color === state.color) && (!cfg.hasSize || v.size === state.size),
      ) ?? null;

    const syncPrice = () => {
      const v = resolve();
      const unit = Number(v?.amount ?? cfg.unitAmount);
      const cmp = v?.compareAt != null ? Number(v.compareAt) : null;
      const onSale = cmp != null && Number.isFinite(cmp) && cmp > unit;

      const ap = $('[data-add-price]');
      if (ap) ap.textContent = money(unit * state.qty);

      // Headline price + compare-at, synced to the RESOLVED variant so the big
      // price always matches what's actually added, and the discount badge is
      // the selected variant's real saving (not a min-vs-min approximation).
      const nowEl = $('[data-price-now]');
      if (nowEl) nowEl.textContent = money(unit);
      const wasEl = $<HTMLElement>('[data-price-was]');
      if (wasEl) {
        wasEl.hidden = !onSale;
        if (onSale) wasEl.textContent = money(cmp as number);
      }
      const offEl = $<HTMLElement>('[data-price-off]');
      if (offEl) {
        const pct = onSale ? Math.round((((cmp as number) - unit) / (cmp as number)) * 100) : 0;
        offEl.hidden = pct <= 0;
        if (pct > 0) offEl.textContent = `Save ${pct}%`;
      }
    };

    // ── Colours ────────────────────────────────────────────
    root.querySelectorAll<HTMLElement>('.opt-color').forEach((o) => {
      const activate = () => {
        root.querySelectorAll('.opt-color').forEach((x) => {
          x.classList.remove('on');
          x.setAttribute('aria-pressed', 'false');
        });
        o.classList.add('on');
        o.setAttribute('aria-pressed', 'true');
        state.color = o.dataset.color || '';
        const lbl = $('[data-color-label]');
        if (lbl) lbl.textContent = state.color;
        syncPrice();
      };
      o.addEventListener('click', activate);
      o.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activate();
        }
      });
    });

    // ── Sizes ──────────────────────────────────────────────
    root.querySelectorAll<HTMLButtonElement>('.opt-size').forEach((o) => {
      if (o.classList.contains('off')) return;
      o.addEventListener('click', () => {
        root.querySelectorAll('.opt-size').forEach((x) => x.classList.remove('on'));
        o.classList.add('on');
        state.size = o.dataset.size || '';
        syncPrice();
      });
    });

    // ── Quantity ───────────────────────────────────────────
    const qval = $('[data-qval]');
    const syncQty = () => {
      if (qval) qval.textContent = String(state.qty);
      syncPrice();
    };
    $('[data-qinc]')?.addEventListener('click', () => {
      state.qty++;
      syncQty();
    });
    $('[data-qdec]')?.addEventListener('click', () => {
      state.qty = Math.max(1, state.qty - 1);
      syncQty();
    });

    // ── Add to bag / buy now ───────────────────────────────
    const add = $<HTMLButtonElement>('[data-pdp-add]');
    add?.addEventListener('click', async () => {
      const v = resolve();
      if (!v || !v.available || add.dataset.loading) return;
      add.dataset.loading = '1';
      try {
        await addItem(v.id, state.qty); // opens the cart drawer on success
      } finally {
        delete add.dataset.loading;
      }
    });
    $('[data-pdp-buy]')?.addEventListener('click', () => {
      const v = resolve();
      if (v && v.available) buyNow(v.id, state.qty);
    });

    // ── Wishlist heart (synced with header badge) ──────────
    const fav = $<HTMLButtonElement>('[data-pdp-fav]');
    const paintFav = () => fav?.classList.toggle('on', $wishlist.get().includes(cfg.productId));
    fav?.addEventListener('click', () => {
      toggleWishlist(cfg.productId);
      window.dispatchEvent(new CustomEvent('wishlist-updated'));
    });
    $wishlist.subscribe(paintFav);

    // ── Accordions ─────────────────────────────────────────
    root.querySelectorAll<HTMLElement>('[data-acc] .acc-head').forEach((h) => {
      h.addEventListener('click', () => {
        const item = h.closest('.acc-item') as HTMLElement;
        const body = item.querySelector<HTMLElement>('.acc-body')!;
        const open = item.classList.toggle('open');
        body.style.maxHeight = open ? body.scrollHeight + 'px' : '0';
        h.setAttribute('aria-expanded', String(open));
      });
    });
    const openBody = root.querySelector<HTMLElement>('[data-acc] .acc-item.open .acc-body');
    if (openBody) openBody.style.maxHeight = openBody.scrollHeight + 'px';

    syncQty();

    // ── Size guide modal ───────────────────────────────────
    const sgOverlay = $<HTMLElement>('[data-sg-overlay]');
    if (sgOverlay) {
      const openSg = (): void => {
        sgOverlay.hidden = false;
        requestAnimationFrame(() => sgOverlay.classList.add('is-open'));
        document.documentElement.classList.add('nav-open'); // reuse scroll lock
      };
      const closeSg = (): void => {
        sgOverlay.classList.remove('is-open');
        document.documentElement.classList.remove('nav-open');
        window.setTimeout(() => {
          sgOverlay.hidden = true;
        }, 300);
      };
      root
        .querySelectorAll<HTMLButtonElement>('[data-sg-open]')
        .forEach((b) => b.addEventListener('click', openSg));
      sgOverlay.querySelector('[data-sg-close]')?.addEventListener('click', closeSg);
      sgOverlay.addEventListener('click', (e) => {
        if (e.target === sgOverlay) closeSg(); // backdrop click
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !sgOverlay.hidden) closeSg();
      });
    }

    // ── Reviews: client-side filter + progressive reveal ───
    const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-rv-list] .rv-card'));
    if (cards.length) {
      const PER = 3;
      let filter = 'all';
      let shown = PER;
      const noResult = $<HTMLElement>('[data-rv-noresult]');
      const moreWrap = $<HTMLElement>('[data-rv-more]');

      const matches = (c: HTMLElement) =>
        filter === 'all' ||
        (filter === 'photos' ? c.dataset.hasPhotos === '1' : c.dataset.rating === filter);

      const apply = () => {
        const eligible = cards.filter(matches);
        cards.forEach((c) => (c.style.display = 'none'));
        eligible.slice(0, shown).forEach((c) => (c.style.display = ''));
        if (noResult) noResult.style.display = eligible.length ? 'none' : '';
        if (moreWrap) moreWrap.style.display = eligible.length > shown ? '' : 'none';
      };

      root.querySelectorAll<HTMLButtonElement>('[data-rv-filters] .rv-fp').forEach((b) => {
        b.addEventListener('click', () => {
          root.querySelectorAll('[data-rv-filters] .rv-fp').forEach((x) => x.classList.remove('on'));
          b.classList.add('on');
          filter = b.dataset.f || 'all';
          shown = PER;
          apply();
        });
      });
      $('[data-rv-loadmore]')?.addEventListener('click', () => {
        shown += PER;
        apply();
      });
      apply();
    }
  }

  initPdp();
  document.addEventListener('astro:page-load', initPdp);
</script>
