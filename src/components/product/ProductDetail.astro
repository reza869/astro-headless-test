  }
  .pdp-tax {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-bottom: 22px;
  }
  .pdp-tax b {
    color: var(--color-green);
    font-weight: 700;
  }
  .pdp-lead {
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
    max-width: 48ch;
    /* Cap at three lines with a graceful ellipsis. */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }
  .pdp-divider {
    height: 1px;
    background: var(--color-border);
    margin: 24px 0;
  }

  /* ---- Options ---- */
  .opt {
    margin-bottom: 24px;
  }
  .opt-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 13px;
  }
  .opt-head h6 {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .opt-head .sel {
    font-size: 12.5px;
    color: var(--color-text-secondary);
    font-weight: 600;
  }
  .opt-head .guide {
    font-size: 12px;
    color: var(--color-blue);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    background: none;
    transition: color 0.2s;
  }
  .opt-head .guide:hover {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ---- Size guide modal ---- */
  .sg-overlay {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: rgba(21, 23, 25, 0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s var(--ease-out-soft);
  }
  .sg-overlay[hidden] {
    display: none;
  }
  .sg-overlay.is-open {
    opacity: 1;
  }
  .sg-modal {
    width: min(860px, 100%);
    max-height: min(88vh, 860px);
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    transform: translateY(14px) scale(0.98);
    transition: transform 0.35s var(--ease-out-soft);
    overflow: hidden;
  }
  .sg-overlay.is-open .sg-modal {
    transform: none;
  }
  .sg-modal-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 26px 18px;
    border-bottom: 1px solid var(--color-border);
  }
  .sg-modal-head .mag-label {
    margin-bottom: 8px;
  }
  .sg-modal-head h3 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 800;
    line-height: 0.95;
    color: var(--color-text-primary);
  }
  .sg-close {
    flex: none;
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: background 0.2s;
  }
  .sg-close:hover {
    background: var(--color-surface-cool);
  }
  .sg-modal-body {
    padding: 24px 26px;
    overflow-y: auto;
  }
  .sg-modal-foot {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 26px;
    border-top: 1px solid var(--color-border);
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--color-coral);
    transition: gap 0.2s;
  }
  .sg-modal-foot:hover {
    gap: 12px;
  }
  @media (max-width: 680px) {
    .sg-modal-body {
      padding: 18px 16px;
    }
    .sg-modal-head {
      padding: 20px 18px 14px;
    }
    .sg-modal-head h3 {
      font-size: 24px;
    }
  }
  .opt-colors {
    display: flex;
    gap: 14px;
  }
  .opt-color {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    position: relative;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s;
  }
  .opt-color::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: var(--radius-pill);
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .opt-color.on::after {
    border-color: var(--color-text-primary);
  }
  /* Keyboard focus ring for the now-focusable swatches + thumbnails (H17). */
  .opt-color:focus-visible,
  .pg-thumb:focus-visible {
    outline: 2px solid var(--color-coral);
    outline-offset: 2px;
  }
  .opt-color:hover {
    transform: scale(1.07);
  }
  .opt-sizes {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .opt-size {
    min-width: 52px;
    padding: 13px 8px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text-primary);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border);
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
  }
  .opt-size:hover {
    box-shadow: inset 0 0 0 1px var(--color-text-muted);
  }
  .opt-size.on {
    background: var(--color-text-primary);
    color: #fff;
    box-shadow: none;
  }
  .opt-size.off {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* ---- Personalization (MP-24) ---- */
  .pdp-personalize {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 22px;
    padding: 18px;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .pdp-personalize .pz-title {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .pz-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pz-field span {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-secondary);
  }
  .pz-field input {
    height: 44px;
    padding: 0 14px;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border);
    font-size: 13.5px;
    color: var(--color-text-primary);
    transition: box-shadow 0.2s;
  }
  .pz-field input:focus {
    outline: none;
    box-shadow: inset 0 0 0 2px var(--color-coral);
  }

  /* ---- Stock availability signal (MP-7) ---- */
  .pdp-stock {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    font-weight: 700;
    margin-bottom: 14px;
    color: var(--color-green);
  }
  .pdp-stock[hidden] {
    display: none;
  }
  .pdp-stock::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: var(--radius-pill);
    background: currentColor;
  }
  .pdp-stock.is-in {
    color: var(--color-green);
  }
  .pdp-stock.is-low,
  .pdp-stock.is-order {
    color: var(--color-coral);
  }
  .pdp-stock.is-out {
    color: var(--color-text-muted);
  }
  /* Pulse the dot only for the urgency states. */
  .pdp-stock.is-low::before,
  .pdp-stock.is-order::before {
    animation: pdp-pulse 1.8s ease-in-out infinite;
  }
  @keyframes pdp-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  /* ---- Buy row ---- */
  .buy-row {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
  }
  .qty-step {
    display: inline-flex;
    align-items: center;
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .qty-step button {
    width: 46px;
    height: 54px;
    font-size: 20px;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qty-step button:disabled {
    opacity: 0.32;
    cursor: not-allowed;
  }
  .qty-step span {
    min-width: 32px;
    text-align: center;
    font-weight: 700;
    font-size: 15px;
  }
  .buy-add {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    height: 54px;
    border-radius: var(--radius-sm);
    background: var(--color-coral);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    transition: background 0.3s;
  }
  .buy-add:hover {
    background: var(--color-coral-hover);
  }
  .buy-add:disabled {
    background: var(--color-text-muted);
    cursor: not-allowed;
    opacity: 0.7;
  }
  .buy-now {
    width: 100%;
    height: 52px;
    border-radius: var(--radius-sm);
    background: var(--color-dark);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    transition: background 0.3s;
    margin-bottom: 24px;
  }
  .buy-now:hover {
    background: var(--color-dark-hover);
  }

  /* ---- Trust ---- */
  .pdp-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 28px;
  }
  .trust-i {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 14px;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .trust-i :global(svg) {
    color: var(--color-coral);
  }
  .trust-i b {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .trust-i span {
    font-size: 11.5px;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ---- Accordions ---- */
  .acc {
    border-top: 1px solid var(--color-border);
  }
  .acc-item {
    border-bottom: 1px solid var(--color-border);
  }
  .acc-head {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 700;
    color: var(--color-text-primary);
    cursor: pointer;
  }
  .acc-head :global(svg) {
    color: var(--color-text-secondary);
    transition: transform 0.3s;
  }
  .acc-item.open .acc-head :global(svg) {
    transform: rotate(45deg);
  }
  .acc-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s var(--ease-out-soft);
  }
  .acc-body .inner {
    padding: 0 0 20px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }
  .acc-body .inner ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }
  .acc-body .inner li {
    display: flex;
    gap: 9px;
    align-items: flex-start;
  }
  .acc-body .inner li :global(svg) {
    color: var(--color-green);
    margin-top: 3px;
    flex: none;
  }
  .acc-body .specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 24px;
    margin-top: 4px;
  }
  .acc-body .specs div {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px dashed var(--color-border);
    font-size: 13px;
  }
  .acc-body .specs span {
    color: var(--color-text-muted);
  }
  .acc-body .specs b {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  /* ---- Reviews ---- */
  .reviews {
    padding: 120px 0;
    background: var(--color-surface-cool);
  }
  .rv-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 42px;
    flex-wrap: wrap;
  }
  .rv-head h2,
  .rel-head h2 {
    font-family: var(--font-heading);
    font-size: clamp(40px, 4.5vw, 58px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.5px;
  }
  .rv-head h2 em,
  .rel-head h2 em {
    font-style: normal;
    color: var(--color-coral);
  }
  .rv-head .mag-label,
  .rel-head .mag-label {
    margin-bottom: 16px;
  }
  .rv-head > div:first-child {
    flex: 1 1 auto;
  }
  .rv-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .rv-filters .fl {
    font-size: 10.5px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--color-text-muted);
    margin-right: 4px;
  }
  .rv-fp {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-secondary);
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border);
    cursor: pointer;
    transition: all 0.2s;
  }
  .rv-fp:hover {
    color: var(--color-text-primary);
  }
  .rv-fp.on {
    background: var(--color-coral);
    color: #fff;
    box-shadow: none;
  }
  .rv-layout {
    display: grid;
    grid-template-columns: 0.78fr 1.22fr;
    gap: 40px;
    align-items: start;
  }
  .rv-summary {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: 34px 30px;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 96px;
  }
  .rv-score {
    font-family: var(--font-heading);
    font-size: 76px;
    font-weight: 800;
    line-height: 0.85;
    color: var(--color-text-primary);
  }
  .rv-score sub {
    font-size: 24px;
    color: var(--color-text-muted);
    font-weight: 600;
    vertical-align: baseline;
  }
  .rv-sstars {
    color: var(--color-coral);
    font-size: 18px;
    letter-spacing: 2px;
    margin: 12px 0 6px;
  }
  .rv-scount {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-bottom: 24px;
  }
  .rv-bars {
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin-bottom: 22px;
  }
  .rv-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--color-text-secondary);
  }
  .rv-bar .lab {
    width: 30px;
    font-weight: 600;
    white-space: nowrap;
  }
  .rv-bar .track {
    flex: 1;
    height: 7px;
    border-radius: var(--radius-pill);
    background: var(--color-surface-cool);
    overflow: hidden;
  }
  .rv-bar .fill {
    display: block;
    height: 100%;
    background: var(--color-coral);
    border-radius: var(--radius-pill);
  }
  .rv-bar .pct {
    width: 34px;
    text-align: right;
    font-weight: 600;
  }
  .rv-rec-line {
    font-size: 12.5px;
    color: var(--color-text-secondary);
  }
  .rv-rec-line b {
    color: var(--color-green);
  }
  .rv-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .rv-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 26px;
    box-shadow: var(--shadow-xs);
  }
  .rv-top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 13px;
  }
  .rv-av {
    width: 46px;
    height: 46px;
    border-radius: var(--radius-pill);
    flex: none;
    display: grid;
    place-items: center;
    background: var(--color-coral-soft);
    color: var(--color-coral-hover);
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 800;
  }
  .rv-who b {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text-primary);
    display: block;
  }
  .rv-who .vf {
    font-size: 11px;
    color: var(--color-green);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 2px;
  }
  .rv-when {
    margin-left: auto;
    font-size: 12px;
    color: var(--color-text-muted);
  }
  .rv-rate {
    color: var(--color-coral);
    font-size: 14px;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .rv-card h5 {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 7px;
  }
  .rv-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 14px;
  }
  .rv-card p:last-child {
    margin-bottom: 0;
  }
  .rv-photos {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rv-photos img {
    width: 62px;
    height: 62px;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .rv-more {
    margin-top: 24px;
    text-align: center;
  }
  .btn-load {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    height: 50px;
    padding: 0 26px;
    border-radius: var(--radius-sm);
    background: var(--color-dark);
    color: #fff;
    font-size: 12.5px;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: background 0.3s;
  }
  .btn-load:hover {
    background: var(--color-dark-hover);
  }
  .rv-empty-filter,
  .rv-empty {
    padding: 44px 24px;
    text-align: center;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
  }
  .rv-empty-filter {
    color: var(--color-text-muted);
    font-size: 14px;
  }
  .rv-empty-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 800;
    color: var(--color-text-primary);
  }
  .rv-empty-sub {
    margin-top: 8px;
    font-size: 14px;
    color: var(--color-text-secondary);
  }
  .pdp-stars--empty .s {
    color: var(--color-border);
  }
  .pdp-stars--empty a {
    color: var(--color-text-muted);
  }

  /* ---- Write a review (MP-26) ---- */
  .rv-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .rv-write-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 44px;
    padding: 0 20px;
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    color: var(--color-text-primary);
    box-shadow: inset 0 0 0 1.5px var(--color-dark);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background 0.25s,
      color 0.25s;
  }
  .rv-write-trigger:hover {
    background: var(--color-dark);
    color: #fff;
  }
  .rv-write {
    margin-top: 30px;
  }
  .rv-form {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    padding: clamp(24px, 4vw, 40px);
    max-width: 720px;
    margin: 0 auto;
  }
  .rv-form-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 22px;
  }
  .rv-form-head h3 {
    font-family: var(--font-heading);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 800;
    letter-spacing: -0.3px;
  }
  .rv-form-close {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-pill);
    color: var(--color-text-muted);
    background: var(--color-surface-cool);
    cursor: pointer;
    transition:
      color 0.2s,
      background 0.2s;
  }
  .rv-form-close:hover {
    color: var(--color-text-primary);
    background: var(--color-border);
  }
  .rv-field {
    display: block;
    margin-bottom: 18px;
  }
  .rv-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .rv-label {
    display: block;
    font-size: 11.5px;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 9px;
  }
  .rv-label i {
    color: var(--color-coral);
    font-style: normal;
