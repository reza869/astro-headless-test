    font-size: clamp(54px, 7.2vw, 112px);
    font-weight: 800;
    line-height: 0.8;
    letter-spacing: -1.5px;
    text-transform: uppercase;
  }
  .sh-grid h1 em {
    font-style: normal;
    color: var(--color-coral);
  }
  .sh-intro {
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 430px;
    padding-top: 12px;
    /* Cap the hero intro at three lines regardless of the product copy. */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }
  .sh-stats {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    margin-top: 34px;
  }
  .sh-stats .st {
    padding-right: 18px;
    box-shadow: inset -1px 0 0 var(--color-border);
  }
  .sh-stats .st:last-child {
    box-shadow: none;
  }
  .sh-stats .st b {
    font-family: var(--font-heading);
    font-size: 34px;
    font-weight: 800;
    line-height: 0.9;
    display: block;
  }
  .sh-stats .st span {
    font-size: 10.5px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-top: 7px;
    display: block;
  }

  /* ---- Detail block ---- */
  .pdp {
    padding: 120px 0;
    background: var(--color-surface);
  }
  .pdp-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 54px;
    align-items: start;
  }

  /* ---- Gallery ---- */
  .pdp-gallery {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 16px;
    position: sticky;
    top: 96px;
  }
  .pg-thumbs {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
