---
// Responsive product grid. Numbers cards continuing from startIndex.
import type { ProductCard as ProductCardType } from '~/lib/shopify/types';
import ProductCard from './ProductCard.astro';
import { cn } from '~/lib/utils';

interface Props {
  products: ProductCardType[];
  startIndex?: number;
  numbered?: boolean;
  class?: string;
}

const { products, startIndex = 0, numbered = true, class: className } = Astro.props;
---

<div
  class={cn(
    'grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 md:gap-x-6 md:gap-y-12',
    className,
  )}
>
  {
    products.map((product, i) => (
      <ProductCard
        product={product}
        index={numbered ? startIndex + i : undefined}
        class="reveal"
      />
    ))
  }
</div>
