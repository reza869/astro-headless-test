---
// Trust strip — mono technical value props from site config.
import { SITE } from '~/config/site';
import Icon from '~/components/ui/Icon.astro';
---

<section class="border-b border-border bg-surface">
  <div class="wrap grid gap-px sm:grid-cols-3">
    {
      SITE.valueProps.map((vp) => (
        <div class="flex items-start gap-4 py-8 sm:px-6">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-md border border-border text-text-primary">
            <Icon name={vp.icon} size={20} />
          </span>
          <div>
            <p class="text-sm font-semibold text-text-primary">{vp.title}</p>
            <p class="mt-1 text-sm text-text-secondary">{vp.body}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
