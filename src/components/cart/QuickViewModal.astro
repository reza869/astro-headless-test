---
// ============================================================
//  QuickViewModal — global product preview (vanilla island). Opened
//  by a card's 'quickview:open' CustomEvent; lazy-fetches full detail
//  from /api/products/:handle, lets the shopper pick options, and adds
//  to cart (closing itself + opening the drawer). Markup/classes match
//  the former React version so the modal is identical.
// ============================================================
import Icon from '~/components/ui/Icon.astro';
---

<div
  data-qv-overlay
  class="fixed inset-0 z-[200] flex items-center justify-center p-4 pointer-events-none"
  aria-hidden="true"
  inert
>
  <div
    data-qv-backdrop
    class="absolute inset-0 bg-black/60 backdrop-blur-md opacity-0 transition-opacity duration-300"
  ></div>

  <div
    data-qv-panel
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-label="Quick view"
    class="relative grid max-h-[90vh] w-full max-w-[850px] scale-95 grid-cols-1 gap-8 overflow-y-auto rounded-3xl bg-white p-6 opacity-0 shadow-2xl outline-none transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] md:grid-cols-2 md:p-8"
  >
    <button
      type="button"
      data-qv-close
      aria-label="Close quick view"
      class="absolute right-4 top-4 z-10 grid h-10 w-10 place-items-center rounded-full bg-surface text-text-primary shadow-xs transition-fluid hover:bg-dark hover:text-white"
    >
      <Icon name="close" size={19} strokeWidth={1.8} />
    </button>

    {/* Body (image + meta) built client-side; `contents` so children join the grid */}
    <div data-qv-body class="contents"></div>
  </div>
</div>

<script>
  import type { Product, ProductOption, ProductVariant } from '~/lib/shopify/types';
  import { formatMoney, isOnSale, discountPercent } from '~/lib/utils';
  import { addItem } from '~/stores/cart';
  import { lockScroll, unlockScroll } from '~/lib/scroll-lock';

  const COLOR_HEX: Record<string, string> = {
    black: '#151719', white: '#ffffff', ivory: '#f4efe3', cream: '#efe7d6',
    beige: '#d8c4a5', tan: '#c9a87c', camel: '#b58a5a', brown: '#6f4e37',
    green: '#3f7d5c', olive: '#6b7a4a', sage: '#9aa987', coral: '#d95846',
    red: '#c0392b', burgundy: '#7b1e3b', pink: '#e6a4b4', blush: '#e7c4c4',
    blue: '#2f4b7c', navy: '#1f2a44', denim: '#3b5a7a', grey: '#8a8f94',
    gray: '#8a8f94', charcoal: '#3a3d40', yellow: '#e8c468', orange: '#e08a3c',
  };
  const swatchColor = (name: string) => COLOR_HEX[name.toLowerCase()] ?? name.toLowerCase();
  const isColorOption = (name: string) => /colou?r/i.test(name);
  const esc = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!);

  function swatchStyleAttr(ov: { name: string; swatch?: { color?: string | null; image?: string | null } | null }): string {
    if (ov.swatch?.image) {
      return `background-image:url(${ov.swatch.image});background-size:cover;background-position:center`;
    }
    return `background-color:${ov.swatch?.color ?? swatchColor(ov.name)}`;
  }
  const spinner = (size = 18) =>
    `<svg class="animate-spin" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-opacity="0.25" stroke-width="2.5"/><path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>`;

  function findVariant(variants: ProductVariant[], selected: Record<string, string>) {
    return variants.find((v) => v.selectedOptions.every((o) => selected[o.name] === o.value));
  }

  function initQuickView(): void {
    const overlay = document.querySelector<HTMLElement>('[data-qv-overlay]');
    if (!overlay || overlay.dataset.bound) return;
    overlay.dataset.bound = 'true';

    const panel = overlay.querySelector<HTMLElement>('[data-qv-panel]')!;
    const backdrop = overlay.querySelector<HTMLElement>('[data-qv-backdrop]')!;
    const body = overlay.querySelector<HTMLElement>('[data-qv-body]')!;

    let product: Product | null = null;
    let selected: Record<string, string> = {};
    let loading = false;
    let error: string | null = null;
    let adding = false;
    let lastPick: { name: string; value: string } | null = null;
    let opener: HTMLElement | null = null;
    let ctrl: AbortController | null = null;

    function render(): void {
      if (loading) {
        body.innerHTML = `<div class="col-span-full grid min-h-[360px] place-items-center text-text-muted">${spinner(28)}</div>`;
        return;
      }
      if (error) {
        body.innerHTML = `<div class="col-span-full grid min-h-[240px] place-items-center text-center text-sm text-text-secondary">${esc(error)}</div>`;
        return;
      }
      if (!product) {
        body.innerHTML = '';
        return;
      }

      const p = product;
      const variant = findVariant(p.variants, selected);
      const singleVariant =
        p.options.length === 0 || (p.options.length === 1 && p.options[0].name === 'Title');
      const available = variant?.availableForSale ?? false;
      const currency = variant?.price.currencyCode ?? p.priceRange.minVariantPrice.currencyCode ?? 'USD';
      const onSale = isOnSale(variant?.price, variant?.compareAtPrice);
      const off = discountPercent(variant?.price, variant?.compareAtPrice);
      const category = p.productType || p.vendor || '';
      // Option B — the selected variant drives the image once a full choice is
      // made; until then show the featured image (what the card displayed).
      const image = variant?.image ?? p.featuredImage ?? p.images?.[0] ?? null;
      panel.setAttribute('aria-label', p.title);

      const valueAvailable = (optName: string, value: string) =>
        p.variants.some(
          (v) => v.availableForSale && v.selectedOptions.some((o) => o.name === optName && o.value === value),
        );

      const optionsHtml = singleVariant
        ? ''
        : p.options
            .map((option: ProductOption) => {
              const values = option.optionValues
                .map((ov) => {
                  const active = selected[option.name] === ov.name;
                  const possible = valueAvailable(option.name, ov.name);
                  if (isColorOption(option.name)) {
                    return `<button type="button" data-qv-opt data-opt-name="${esc(option.name)}" data-opt-value="${esc(ov.name)}" aria-pressed="${active}" aria-label="${esc(ov.name)}" title="${esc(ov.name)}" class="relative grid h-8 w-8 place-items-center rounded-full ring-1 ring-inset ring-black/10 transition-fluid ${active ? 'ring-2 ring-dark ring-offset-2' : ''} ${!possible && !active ? 'opacity-40' : ''}" style="${swatchStyleAttr(ov)}">${active ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-white mix-blend-difference"><path d="M20 6 9 17l-5-5"/></svg>' : ''}</button>`;
                  }
                  return `<button type="button" data-qv-opt data-opt-name="${esc(option.name)}" data-opt-value="${esc(ov.name)}" aria-pressed="${active}" class="inline-flex h-10 min-w-[44px] items-center justify-center rounded-md border px-3 text-sm font-semibold transition-fluid ${active ? 'border-dark bg-dark text-white' : 'border-border bg-surface text-text-primary hover:border-dark'} ${!possible && !active ? 'text-text-muted line-through decoration-1' : ''}">${esc(ov.name)}</button>`;
                })
                .join('');
              return `<fieldset class="mt-6 border-0 p-0"><legend class="mb-2.5 text-[11px] font-bold uppercase tracking-[1.6px] text-text-secondary">${esc(option.name)}</legend><div class="flex flex-wrap gap-2.5">${values}</div></fieldset>`;
            })
            .join('');

      // Resolved variant → its exact price (+ any sale). No full selection yet →
      // the card's "From {min}" range price, so the modal opens matching the card.
      const priceHtml = variant
        ? `<span class="text-2xl font-bold tabular text-text-primary">${esc(formatMoney(variant.price.amount, currency))}</span>${
            onSale && variant.compareAtPrice
              ? `<s class="text-base text-text-muted tabular">${esc(formatMoney(variant.compareAtPrice.amount, currency))}</s>${off != null ? `<span class="rounded-sm bg-coral px-2 py-1 text-[11px] font-bold uppercase leading-none tracking-[1px] text-white">−${off}%</span>` : ''}`
              : ''
          }`
        : `<span class="text-2xl font-bold tabular text-text-primary"><span class="mr-1.5 align-middle text-[11px] font-semibold uppercase tracking-[1px] text-text-muted">From</span>${esc(formatMoney(p.priceRange.minVariantPrice.amount, currency))}</span>`;

      body.innerHTML =
        `<div class="overflow-hidden rounded-2xl bg-surface-cool">${
          image
            ? `<img src="${image.url}" alt="${esc(image.altText ?? p.title)}" class="h-full max-h-[520px] w-full object-cover">`
            : '<div class="grid aspect-[3/4] place-items-center text-text-muted">No image</div>'
        }</div>` +
        `<div class="flex flex-col">${category ? `<span class="text-[11px] font-bold uppercase tracking-[1.6px] text-green">${esc(category)}</span>` : ''}` +
        `<h2 class="mt-2 font-heading text-[30px] font-bold leading-[0.98] text-text-primary">${esc(p.title)}</h2>` +
        `<div class="mt-2 flex items-center gap-1 text-coral" aria-hidden="true">${'<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" stroke-width="0"><path d="M12 2.5 14.9 8.4l6.5.9-4.7 4.6 1.1 6.5L12 17.8 6.2 20.9l1.1-6.5L2.6 9.3l6.5-.9z"/></svg>'.repeat(5)}</div>` +
        `<div class="mt-4 flex items-center gap-3">${priceHtml}</div>` +
        (p.description ? `<p class="mt-4 line-clamp-3 text-sm leading-relaxed text-text-secondary">${esc(p.description)}</p>` : '') +
        optionsHtml +
        `<button type="button" data-qv-add ${adding || !variant || !available ? 'disabled' : ''} class="mt-7 flex h-14 w-full items-center justify-center gap-2 rounded-md bg-coral text-base font-bold uppercase tracking-[1px] text-white transition-fluid hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50">${adding ? spinner(20) : !variant ? 'Select options' : available ? 'Add to Bag' : 'Sold out'}</button>` +
        `<a href="/products/${p.handle}" class="mt-3 text-center text-sm text-text-secondary underline-offset-4 transition-fluid hover:text-text-primary hover:underline">View full details</a></div>`;

      // Restore focus to the just-picked option so keyboard users aren't dropped.
      if (lastPick) {
        panel
          .querySelector<HTMLElement>(
            `[data-qv-opt][data-opt-name="${CSS.escape(lastPick.name)}"][data-opt-value="${CSS.escape(lastPick.value)}"]`,
          )
          ?.focus();
        lastPick = null;
      }
    }

    async function load(handle: string): Promise<void> {
      product = null;
      selected = {};
      error = null;
      loading = true;
      render();
      ctrl?.abort();
      ctrl = new AbortController();
      const signal = ctrl.signal;
      try {
        const r = await fetch(`/api/products/${encodeURIComponent(handle)}`, {
          headers: { accept: 'application/json' },
          signal,
        });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const data = await r.json();
        if (signal.aborted) return;
        if (data.product) {
          product = data.product as Product;
          selected = {};
          // Option B — mirror the product card: open on the featured image with a
          // "From {min}" price and NO variant pre-picked, so the shopper chooses
          // colour/material before a concrete price + Add. Only auto-select when
          // there's genuinely nothing to choose (a single/optionless variant),
          // so those still add in one click.
          const singleVariant =
            product.options.length === 0 ||
            (product.options.length === 1 && product.options[0].name === 'Title');
          if (singleVariant) {
            const base = product.variants.find((v) => v.availableForSale) ?? product.variants[0];
            base?.selectedOptions.forEach((o) => (selected[o.name] = o.value));
          }
        } else {
          error = data.error ?? 'Product unavailable';
        }
      } catch (e) {
        if (!signal.aborted && (e as Error)?.name !== 'AbortError') error = 'Could not load product';
      } finally {
        if (!signal.aborted) {
          loading = false;
          render();
        }
      }
    }

    const onKey = (e: KeyboardEvent): void => {
      if (e.key === 'Escape') close();
      else if (e.key === 'Tab') {
        const items = Array.from(
          panel.querySelectorAll<HTMLElement>('a[href],button:not([disabled]),input,[tabindex]:not([tabindex="-1"])'),
        ).filter((el) => el.offsetParent !== null);
        if (!items.length) return;
        const first = items[0];
        const last = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    };

    function open(handle: string): void {
      opener = document.activeElement as HTMLElement;
      overlay!.classList.remove('pointer-events-none');
      overlay!.removeAttribute('aria-hidden');
      overlay!.removeAttribute('inert');
      backdrop.classList.replace('opacity-0', 'opacity-100');
      panel.classList.replace('scale-95', 'scale-100');
      panel.classList.replace('opacity-0', 'opacity-100');
      lockScroll();
      document.addEventListener('keydown', onKey);
      panel.focus();
      void load(handle);
    }

    function close(): void {
      ctrl?.abort();
      overlay!.classList.add('pointer-events-none');
      overlay!.setAttribute('aria-hidden', 'true');
      overlay!.setAttribute('inert', '');
      backdrop.classList.replace('opacity-100', 'opacity-0');
      panel.classList.replace('scale-100', 'scale-95');
      panel.classList.replace('opacity-100', 'opacity-0');
      unlockScroll();
      document.removeEventListener('keydown', onKey);
      product = null;
      opener?.focus();
    }

    // Option pick + add-to-bag (delegated).
    panel.addEventListener('click', async (e) => {
      const opt = (e.target as HTMLElement).closest<HTMLElement>('[data-qv-opt]');
      if (opt) {
        const name = opt.dataset.optName!;
        const value = opt.dataset.optValue!;
        selected = { ...selected, [name]: value };
        lastPick = { name, value };
        render();
        return;
      }
      const add = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-qv-add]');
      if (add && product && !adding) {
        const variant = findVariant(product.variants, selected);
        if (!variant || !variant.availableForSale) return;
        adding = true;
        render();
        await addItem(variant.id, 1); // opens the CartDrawer
        adding = false;
        close();
      }
    });

    overlay.querySelector('[data-qv-close]')?.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    window.addEventListener('quickview:open', (e) => {
      const h = (e as CustomEvent<{ handle?: string }>).detail?.handle;
      if (h) open(h);
    });
  }

  initQuickView();
  document.addEventListener('astro:page-load', initQuickView);
</script>
