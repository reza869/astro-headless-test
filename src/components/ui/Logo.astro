---
// ============================================================
//  Logo — peak mark + expanded wordmark. The mark is a stylized
//  fall line (the steepest descent) carved down a peak.
// ============================================================
import { SITE } from '~/config/site';
import { cn } from '~/lib/utils';

interface Props {
  class?: string;
  compact?: boolean;
}
const { class: className, compact = false } = Astro.props;
---

<a href="/" class={cn('group inline-flex items-center gap-2.5', className)} aria-label={`${SITE.name} — home`}>
  <svg width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true" class="shrink-0">
    <rect x="3" y="3" width="26" height="26" rx="7" stroke="currentColor" stroke-width="1.8" />
    <path d="M10 22 22 10" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" />
    <path d="M10 10h0M22 22h0" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
  </svg>
  {
    !compact && (
      <span
        class="masthead text-[1.05rem] leading-none uppercase"
        style="font-variation-settings: 'wght' 800, 'wdth' 112; letter-spacing: 0.02em;"
      >
        {SITE.name}
      </span>
    )
  }
</a>
