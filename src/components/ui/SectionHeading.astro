---
// Section heading — mono text-[11px] font-bold uppercase tracking-[1.8px] + display title + optional link.
import Icon from '~/components/ui/Icon.astro';

interface Props {
  eyebrow?: string;
  title: string;
  href?: string;
  linkLabel?: string;
  class?: string;
}
const { eyebrow, title, href, linkLabel = 'View all', class: className = '' } = Astro.props;
---

<div class={`flex items-end justify-between gap-6 ${className}`}>
  <div>
    {text-[11px] font-bold uppercase tracking-[1.8px] && <p class="text-[11px] font-bold uppercase tracking-[1.8px] mb-2 text-coral">{eyebrow}</p>}
    <h2 class="masthead text-3xl uppercase sm:text-4xl">{title}</h2>
  </div>
  {
    href && (
      <a
        href={href}
        class="group hidden shrink-0 items-center gap-1.5 pb-1 text-sm font-medium text-text-secondary transition-fluid hover:text-text-primary sm:inline-flex"
      >
        {linkLabel}
        <Icon name="arrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
      </a>
    )
  }
</div>
