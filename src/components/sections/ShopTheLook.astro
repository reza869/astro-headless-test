---
// ============================================================
//  ShopTheLook — interactive 3-tab lookbook (config-driven).
//  Each look's products come from SITE.shopTheLook.looks[].handles
//  (curated) or fall back to best-sellers. Products are fetched WITH
//  their real variants, so the inline picker shows the ACTUAL sizes/
//  options — selecting one adds exactly that variant; with no choice
//  the single variant is added. "+" adds to the cart and opens the
//  drawer. The bundle bar only claims a "Save X%" when a REAL Shopify
//  discount code is configured (SITE.shopTheLook.bundleCode).
// ============================================================
import MagHeading from '~/components/sections/MagHeading.astro';
import Icon from '~/components/ui/Icon.astro';
import { getProduct, getProducts } from '~/lib/shopify';
import { formatMoney } from '~/lib/utils';
import { SITE } from '~/config/site';
import type { Product } from '~/lib/shopify/types';

const cfg = SITE.shopTheLook;
const LOOK_DEFS = cfg.looks;

const bundleCode = (cfg.bundleCode ?? '').trim();
const bundlePct = cfg.bundleDiscountPct ?? 0;
const hasBundleSaving = Boolean(bundleCode) && bundlePct > 0;

// Best-seller handles power any look left un-curated.
let bestHandles: string[] = [];
try {
  bestHandles = (await getProducts({ pageSize: 12, sortKey: 'BEST_SELLING' })).items.map((p) => p.handle);
} catch (err) {
  console.error('[shop-the-look] best-seller load failed:', (err as Error).message);
}

// Resolve the handle list for each look (curated → else a best-seller slice).
const lookHandles = LOOK_DEFS.map((d, li) => {
  const curated = (d.handles ?? []).filter(Boolean);
  return curated.length ? curated : bestHandles.slice(li * 3, li * 3 + 3);
});

// Fetch each product ONCE with full variant data, in parallel, then index by
// handle. Best-sellers are fetched too so they can back-fill any curated look
// whose handles don't exist on THIS store (e.g. a fresh buyer store that hasn't
// renamed its products yet) — the tab still shows a full look, never a blank.
const uniqueHandles = [...new Set([...lookHandles.flat(), ...bestHandles])];
const fetched = await Promise.all(uniqueHandles.map((h) => getProduct(h).catch(() => null)));
const byHandle = new Map<string, Product>();
uniqueHandles.forEach((h, i) => {
  const p = fetched[i];
  if (p) byHandle.set(h, p);
});
const resolve = (handles: string[]) =>
  handles.map((h) => byHandle.get(h)).filter((p): p is Product => Boolean(p));

const firstProduct = [...byHandle.values()][0];
const currency = firstProduct?.priceRange.minVariantPrice.currencyCode ?? 'USD';

// Never surface internal/demo vendor names as a category — fall back to brand.
const cleanCat = (v?: string) => (v && !/demo|partner|sample|test/i.test(v) ? v : SITE.name);

const looks = LOOK_DEFS.map((d, li) => {
  // Curated products; if none resolve on this store, fall back to best-sellers.
  const picked = resolve(lookHandles[li]);
  const source = picked.length ? picked : resolve(bestHandles.slice(li * 3, li * 3 + 3));
  const products = source
    .map((p) => {
      const variants = p.variants ?? [];
      const def = variants.find((v) => v.availableForSale) ?? variants[0] ?? null;
      const amount = Number(def?.price.amount ?? p.priceRange.minVariantPrice.amount);
      // Offer the picker only when there's a genuine choice (>1 real variant).
      const options =
        variants.length > 1
          ? variants.map((v) => ({ id: v.id, label: v.title, available: v.availableForSale }))
          : [];
      return {
        handle: p.handle,
        title: p.title,
        cat: cleanCat(p.vendor),
        image: p.featuredImage?.url ?? d.image,
        amount,
        price: formatMoney(amount, currency),
        defaultVariantId: def?.id ?? '',
        options,
      };
    });
  const original = products.reduce((s, p) => s + p.amount, 0);
  const bundleTotal = hasBundleSaving ? original * (1 - bundlePct / 100) : original;
  return { ...d, products, original, bundleTotal };
});

const hasLooks = looks.some((l) => l.products.length > 0);
---

{
  hasLooks && (
    <section id="shop-the-look" class="pb-section" data-look-section data-bundle-code={bundleCode}>
      <div class="container-mag">
        <MagHeading eyebrow="Styled by the Editors" title="Shop the" em="Look" class="mb-10 md:mb-12">
          {/* Tabs */}
          <div slot="actions" class="hidden flex-none items-center gap-1 rounded-pill bg-surface p-1 shadow-xs lg:flex">
            {looks.map((look, i) => (
              <button
                type="button"
                data-look-tab
                data-look={look.id}
                class:list={[
                  'look-tab flex items-center gap-2 rounded-pill px-4 py-2.5 text-[12.5px] font-semibold transition-fluid',
                  i === 0 ? 'is-active' : 'text-text-muted hover:text-text-primary',
                ]}
              >
                <span class="font-heading text-[13px] font-bold opacity-60">{look.id}</span>
                {look.name}
              </button>
            ))}
          </div>
        </MagHeading>

        {/* Mobile tab row */}
        <div class="mb-6 flex gap-1 overflow-x-auto rounded-pill bg-surface p-1 shadow-xs lg:hidden">
          {looks.map((look, i) => (
            <button
              type="button"
              data-look-tab
              data-look={look.id}
              class:list={[
                'look-tab flex flex-none items-center gap-1.5 rounded-pill px-3.5 py-2 text-[12px] font-semibold transition-fluid',
                i === 0 ? 'is-active' : 'text-text-muted',
              ]}
            >
              <span class="font-heading font-bold opacity-60">{look.id}</span>
              {look.name}
            </button>
          ))}
        </div>

        {looks.map((look, li) => (
          <div
            data-look-panel
            data-look={look.id}
            data-currency={currency}
            class:list={['grid grid-cols-1 items-stretch gap-6 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)]', li !== 0 && 'hidden']}
          >
            {/* ===== Left — stage + hotspots ===== */}
            <div class="look-stage relative min-h-[440px] overflow-hidden rounded-3xl shadow-md md:min-h-[620px]">
              <img src={look.image} alt={`${look.name} look`} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />

              <span class="absolute left-5 top-5 z-30 inline-flex items-center rounded-pill bg-white/95 px-3.5 py-2 text-[10px] font-bold uppercase tracking-[1px] text-text-primary shadow-xs">
                Look {look.id} · {look.name}
              </span>

              {look.products.map((_, j) => {
                const hs = look.hotspots?.[j] ?? { x: '50%', y: '50%' };
                return (
                  <button
                    type="button"
                    data-hotspot
                    data-index={j}
                    aria-label={`Highlight item ${j + 1}`}
                    class:list={['hotspot absolute z-40 flex h-9 w-9 items-center justify-center rounded-full shadow-md', j === 0 && 'is-active']}
                    style={`left:${hs.x};top:${hs.y};transform:translate(-50%,-50%)`}
                  >
                    <Icon name="plus" size={18} />
                  </button>
                );
              })}
            </div>

            {/* ===== Right — note + products + bundle ===== */}
            <div class="flex min-w-0 flex-col gap-3">
              <div class="flex items-center gap-3 rounded-2xl bg-coral-soft px-4 py-3">
                <span class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-coral text-white">
                  <Icon name="star" size={18} />
                </span>
                <div>
                  <b class="block text-[12.5px] font-bold text-text-primary">Styled by the TAILORED editors</b>
                  <span class="text-[11.5px] text-coral-hover">
                    {look.products.length} pieces · {look.name}
                  </span>
                </div>
              </div>

              {look.products.map((p, j) => (
                <article
                  data-look-card
                  data-index={j}
                  data-variant={p.defaultVariantId}
                  data-price={p.amount}
                  class:list={['look-card flex items-center gap-4 rounded-2xl border bg-white p-3 transition-fluid', j === 0 ? 'is-active' : 'border-border']}
                >
                  <a href={`/products/${p.handle}`} class="flex-none" aria-label={p.title}>
                    <img src={p.image} alt={p.title} loading="lazy" class="h-[74px] w-[64px] rounded-xl object-cover" />
                  </a>

                  <div class="min-w-0 flex-1">
                    <span class="text-[10px] font-bold uppercase tracking-[1px] text-green">{p.cat}</span>
                    <h4 class="font-heading text-[18px] font-bold leading-tight text-text-primary">
                      <a href={`/products/${p.handle}`} class="transition-fluid hover:text-coral">{p.title}</a>
                    </h4>
                    <span class="text-[14px] font-bold tabular text-text-primary">{p.price}</span>

                    {/* Real variant picker — only when the product has a genuine choice.
                        Single scrollable row so cards stay tidy regardless of count. */}
                    {p.options.length > 0 && (
                      <div class="stl-variants mt-2 flex gap-1.5 overflow-x-auto" data-variant-picker>
                        {p.options.map((o) => (
                          <button
                            type="button"
                            data-variant-opt
                            data-variant={o.id}
                            disabled={!o.available}
                            aria-label={`Select ${o.label}`}
                            class:list={[
                              'look-size grid h-7 min-w-7 flex-none place-items-center whitespace-nowrap rounded-md px-2 text-[11px] font-bold transition-fluid',
                              o.id === p.defaultVariantId && 'is-on',
                              !o.available && 'is-oos',
                            ]}
                          >
                            {o.label}
                          </button>
                        ))}
                      </div>
                    )}
                  </div>

                  {p.defaultVariantId ? (
                    <button
                      type="button"
                      data-card-toggle
                      aria-label={`Add ${p.title} to cart`}
                      class="look-toggle grid h-10 w-10 flex-none place-items-center rounded-full bg-surface-cool text-text-primary transition-fluid hover:bg-coral hover:text-white"
                    >
                      <Icon name="plus" size={18} />
                    </button>
                  ) : (
                    <a
                      href={`/products/${p.handle}`}
                      aria-label={`View ${p.title}`}
                      class="look-toggle grid h-10 w-10 flex-none place-items-center rounded-full bg-surface-cool text-text-primary transition-fluid hover:bg-coral hover:text-white"
                    >
                      <Icon name="arrowRight" size={18} />
                    </a>
                  )}
                </article>
              ))}

              {/* Bundle bar */}
              <div class="mt-1 flex items-center justify-between gap-4 rounded-2xl bg-dark p-5 text-white">
                <div class="min-w-0">
                  <span class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-[1.4px] text-white/70">
                    Complete the Look
                    {hasBundleSaving && (
                      <span class="rounded-pill bg-green px-2 py-0.5 text-[9px] font-bold tracking-[0.5px] text-white">
                        Save {bundlePct}%
                      </span>
                    )}
                  </span>
                  <div class="mt-1.5 flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
                    <b class="whitespace-nowrap font-heading text-2xl font-extrabold tabular" data-bundle-total>
                      {formatMoney(look.bundleTotal, currency)}
                    </b>
                    {hasBundleSaving && (
                      <s class="whitespace-nowrap text-[14px] text-white/50 tabular" data-bundle-original>
                        {formatMoney(look.original, currency)}
                      </s>
                    )}
                  </div>
                </div>
                <button
                  type="button"
                  data-add-all
                  class="inline-flex flex-none items-center gap-2 rounded-md bg-coral px-5 py-3.5 text-[12px] font-bold uppercase tracking-[0.5px] text-white transition-fluid hover:brightness-110 disabled:opacity-60"
                >
                  <span class="add-all-label inline-flex items-center gap-2">
                    Add All <Icon name="arrowRight" size={16} />
                  </span>
                  <span class="add-all-spin hidden">
                    <span class="block h-4 w-4 animate-spin rounded-pill border-2 border-current border-t-transparent" />
                  </span>
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}

<style>
  .look-tab.is-active {
    background: var(--color-dark);
    color: #fff;
  }
  .look-tab.is-active .opacity-60 {
    opacity: 0.7;
  }

  /* Active product card — coral frame */
  .look-card.is-active {
    border-color: var(--color-coral);
    box-shadow: 0 0 0 1px var(--color-coral);
  }

  /* Variant picker — single tidy scroll row, no visible scrollbar */
  .stl-variants {
    scrollbar-width: none;
  }
  .stl-variants::-webkit-scrollbar {
    display: none;
  }

  /* Variant pills */
  .look-size {
    background: var(--color-surface-cool);
    color: var(--color-text-primary);
  }
  .look-size.is-on {
    background: var(--color-dark);
    color: #fff;
  }
  .look-size.is-oos {
    opacity: 0.4;
    text-decoration: line-through;
    cursor: not-allowed;
  }

  /* Hotspots */
  .hotspot {
    background: #fff;
    color: var(--color-text-primary);
    transition: transform 0.3s, background 0.3s, color 0.3s;
  }
  .hotspot.is-active {
    background: var(--color-coral);
    color: #fff;
  }
  .hotspot:hover {
    transform: translate(-50%, -50%) scale(1.08);
  }

  .look-stage::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgb(9 10 11 / 0.12), transparent 28%, rgb(9 10 11 / 0.2));
  }
</style>

<script>
  import { addItem, applyDiscountCode, openCart } from '~/stores/cart';

  /** Variant the card will add: the shopper's pick, else the default. */
  const chosenVariant = (card: HTMLElement) => card.dataset.selectedVariant || card.dataset.variant || '';

  function initPanel(panel: HTMLElement, bundleCode: string): void {
    const cards = Array.from(panel.querySelectorAll<HTMLElement>('[data-look-card]'));
    const hotspots = Array.from(panel.querySelectorAll<HTMLElement>('[data-hotspot]'));
    const addAll = panel.querySelector<HTMLButtonElement>('[data-add-all]');

    const setActive = (idx: string) => {
      cards.forEach((c) => c.classList.toggle('is-active', c.dataset.index === idx));
      hotspots.forEach((h) => h.classList.toggle('is-active', h.dataset.index === idx));
    };

    cards.forEach((card) => {
      // Seed the selection with the default variant.
      card.dataset.selectedVariant = card.dataset.variant || '';

      // Spotlight follows the hovered (or focused) card.
      const activate = () => setActive(card.dataset.index || '0');
      card.addEventListener('mouseenter', activate);
      card.addEventListener('focusin', activate);

      // Variant picker — selecting a pill sets the exact variant this card adds.
      const opts = Array.from(card.querySelectorAll<HTMLButtonElement>('[data-variant-opt]'));
      opts.forEach((opt) => {
        opt.addEventListener('click', () => {
          if (opt.disabled) return;
          card.dataset.selectedVariant = opt.dataset.variant || '';
          opts.forEach((o) => o.classList.toggle('is-on', o === opt));
        });
      });

      // Per-card "+" — adds the chosen (or default) variant and opens the drawer.
      const toggle = card.querySelector<HTMLButtonElement>('[data-card-toggle]');
      toggle?.addEventListener('click', async () => {
        const variant = chosenVariant(card);
        if (!variant || card.dataset.busy) return;
        card.dataset.busy = '1';
        try {
          await addItem(variant, 1); // opens the cart drawer + bumps the badge
        } finally {
          delete card.dataset.busy;
        }
      });
    });

    // Hotspots are functional: highlight + scroll to the matching product.
    hotspots.forEach((h) => {
      h.addEventListener('click', () => {
        const idx = h.dataset.index || '0';
        setActive(idx);
        cards.find((c) => c.dataset.index === idx)?.scrollIntoView({
          behavior: 'smooth',
          block: 'nearest',
        });
      });
    });

    // Add All — every piece (each with its chosen/default variant); the bundle
    // discount only applies when a real code is configured.
    addAll?.addEventListener('click', async () => {
      const items = cards.map(chosenVariant).filter(Boolean);
      if (!items.length) return;
      addAll.setAttribute('disabled', '');
      panel.querySelector('.add-all-label')?.classList.add('hidden');
      panel.querySelector('.add-all-spin')?.classList.remove('hidden');
      try {
        for (const variant of items) {
          await addItem(variant, 1, { open: false });
        }
        if (bundleCode) await applyDiscountCode([bundleCode], { open: false });
        openCart();
      } finally {
        addAll.removeAttribute('disabled');
        panel.querySelector('.add-all-label')?.classList.remove('hidden');
        panel.querySelector('.add-all-spin')?.classList.add('hidden');
      }
    });
  }

  function initShopTheLook(): void {
    document.querySelectorAll<HTMLElement>('[data-look-section]').forEach((section) => {
      if (section.dataset.bound) return;
      section.dataset.bound = 'true';

      const bundleCode = section.dataset.bundleCode || '';
      const tabs = Array.from(section.querySelectorAll<HTMLButtonElement>('[data-look-tab]'));
      const panels = Array.from(section.querySelectorAll<HTMLElement>('[data-look-panel]'));

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const id = tab.dataset.look;
          tabs.forEach((t) => {
            const on = t.dataset.look === id;
            t.classList.toggle('is-active', on);
            t.classList.toggle('text-text-muted', !on);
          });
          panels.forEach((p) => p.classList.toggle('hidden', p.dataset.look !== id));
        });
      });

      panels.forEach((p) => initPanel(p, bundleCode));
    });
  }

  initShopTheLook();
  document.addEventListener('astro:page-load', initShopTheLook);
</script>
