---
// ============================================================
//  CategoryGrid — "Shop by Category" newsstand row. Mirrors the
//  @astro/magazine source 1:1: dark section, centered heading, a
//  5-up grid with the odd-child 34px offset, inset .cv-frame border,
//  gradient scrim and hover "Enter" affordance. Token names mapped
//  to this project (--radius-md / --ease-out-soft / --color-*).
// ============================================================
import Icon from '~/components/ui/Icon.astro';

const categories = [
  { name: 'Ready-to-Wear', handle: 'ready-to-wear', count: 248, image: '/images/Look 01.png' },
  { name: 'Accessories', handle: 'accessories', count: 86, image: '/images/Hero Image 01.png' },
  { name: 'Footwear', handle: 'footwear', count: 64, image: '/images/Campaign 01.png' },
  { name: 'Bags', handle: 'bags', count: 52, image: '/images/Look 02.png' },
  { name: 'Jewelry', handle: 'jewelry', count: 38, image: '/images/Hero Image 02.png' },
];
---

<section id="category" class="cat-section">
  <div class="container-mag">
    {/* Centered heading (mirrors #category .sec-head override) */}
    <div class="sec-head-center">
      <span class="house-tag">Browse the House</span>
      <h2 class="cat-title">Shop by <span class="text-coral">Category</span></h2>
    </div>

    <div class="cat-news">
      {
        categories.map((c, i) => (
          <a href={`/collections/${c.handle}`} class="cat-cover">
            <img src={c.image} alt={`${c.name} collection`} loading="lazy" />
            <span class="cv-frame" />
            <div class="cv-top">
              <span class="cv-kick">TAILORED Dept.</span>
              <span class="cv-no">N°0{i + 1}</span>
            </div>
            <div class="cv-bot">
              <div class="cv-count">{c.count} Pieces</div>
              <div class="cv-name">{c.name}</div>
              <span class="cv-enter">
                Enter
                <span><Icon name="arrowUpRight" size={15} /></span>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ===== Section + centered heading ===== */
  .cat-section {
    background: var(--color-dark);
    color: #fff;
    /* Responsive rhythm — 50px mobile, up to the 100/104px desktop default. */
    padding: clamp(50px, 8vw, 100px) 0 clamp(50px, 8vw, 104px);
  }
  .sec-head-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-bottom: 60px;
  }
  .house-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
  }
  .house-tag::before {
    content: '✦';
    color: var(--color-coral);
    font-size: 10px;
  }
  .house-tag::after {
    content: '';
    width: 28px;
    height: 2px;
    background: rgba(255, 255, 255, 0.32);
  }
  .cat-title {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.5px;
  }

  /* ===== Newsstand grid ===== */
  .cat-news {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 18px;
    align-items: end;
  }

  .cat-cover {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4.1;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.5s var(--ease-out-soft),
      box-shadow 0.5s var(--ease-out-soft);
  }
  .cat-cover:nth-child(odd) {
    margin-bottom: 34px;
  }
  .cat-cover:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
  }

  .cat-cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.3s var(--ease-out-soft);
  }
  .cat-cover:hover img {
    transform: scale(1.07);
  }

  .cat-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(9, 10, 11, 0.28) 0%,
      rgba(9, 10, 11, 0) 32%,
      rgba(9, 10, 11, 0) 50%,
      rgba(9, 10, 11, 0.82) 100%
    );
  }

  .cat-cover .cv-frame {
    position: absolute;
    inset: 10px;
    z-index: 2;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: calc(var(--radius-md) - 6px);
    pointer-events: none;
  }

  .cat-cover .cv-top {
    position: absolute;
    top: 22px;
    left: 22px;
    right: 22px;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #fff;
  }
  .cat-cover .cv-kick {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
  }
  .cat-cover .cv-no {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 800;
    color: #fff;
  }

  .cat-cover .cv-bot {
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 24px;
    z-index: 3;
    color: #fff;
  }
  .cat-cover .cv-count {
    font-size: 10px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
    font-weight: 700;
  }
  .cat-cover .cv-name {
    font-family: var(--font-heading);
    font-weight: 800;
    line-height: 0.92;
    font-size: clamp(24px, 1.9vw, 32px);
    margin-top: 5px;
  }

  .cat-cover .cv-enter {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.4s var(--ease-out-soft);
  }
  .cat-cover .cv-enter span {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-coral);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cat-cover:hover .cv-enter {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== Responsive (mirrors the demo's 1080 / 680 breakpoints) ===== */
  @media (max-width: 1080px) {
    .cat-news {
      grid-template-columns: repeat(3, 1fr);
    }
    .cat-cover:nth-child(odd) {
      margin-bottom: 0;
    }
  }
  @media (max-width: 680px) {
    .cat-news {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
