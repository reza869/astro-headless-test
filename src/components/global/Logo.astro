//  (e.g. `h-[34px] w-auto text-text-primary`). The subtitle line
//  is rendered at reduced opacity to echo the two-tone original.
// ============================================================
interface Props {
  /** Sizing + colour utilities, e.g. "h-9 w-auto text-white". */
  class?: string;
  /** Accessible name (also the alt for assistive tech). */
  label?: string;
}
const { class: className = 'h-[34px] w-auto', label = "L'ÉDITION" } = Astro.props;
