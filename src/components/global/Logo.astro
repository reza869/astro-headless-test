---
// ============================================================
//  Logo — the brand wordmark, rendered as scalable inline SVG
//  <text> driven by SITE.name. It inherits the current text
//  colour via `currentColor` (dark on the light header, white on
//  the dark footer) and scales to whatever height you pass through
//  `class` (e.g. `h-[34px] w-auto text-text-primary`). Using SVG
//  <text> keeps it razor-sharp at any size and makes the brand a
//  single source of truth — change SITE.name and the mark follows.
// ============================================================
import { SITE } from '~/config/site';

interface Props {
  /** Sizing + colour utilities, e.g. "h-9 w-auto text-white". */
  class?: string;
  /** Accessible name (also the alt for assistive tech). */
  label?: string;
  /** Override the displayed wordmark (defaults to SITE.name). */
  text?: string;
}
const { class: className = 'h-[34px] w-auto', label, text = SITE.name } = Astro.props;

// Approximate advance width per character for the condensed heading face at
// the viewBox font-size, so `w-auto` preserves the aspect ratio for any name.
const CHAR_ADVANCE = 20;
const vbWidth = Math.max(text.length * CHAR_ADVANCE, CHAR_ADVANCE);
---

<svg
  viewBox={`0 0 ${vbWidth} 38`}
  role="img"
  aria-label={label ?? text}
  xmlns="http://www.w3.org/2000/svg"
  class:list={['block', className]}
>
  <text
    x="0"
    y="29"
    fill="currentColor"
    font-family="'Big Shoulders Display', sans-serif"
    font-size="34"
    font-weight="800"
    letter-spacing="0.5"
    textLength={vbWidth}
    lengthAdjust="spacingAndGlyphs"
  >{text}</text>
</svg>
