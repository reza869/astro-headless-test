---
// Page header band — eyebrow + display title + optional description,
// over the topographic field. Used by listing + content pages.
import Contour from '~/components/ui/Contour.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}
const { eyebrow, title, description } = Astro.props;
---

<section class="contour-field border-b border-line">
  <Contour class="opacity-40" />
  <div class="wrap py-12 md:py-16">
    {eyebrow && <p class="eyebrow mb-3 text-accent-strong">{eyebrow}</p>}
    <h1 class="masthead text-4xl uppercase sm:text-5xl md:text-6xl">{title}</h1>
    {
      description && (
        <p class="mt-4 max-w-xl text-graphite" set:html={description} />
      )
    }
  </div>
</section>
