---
// ============================================================
//  Blog (Journal) — faithful port of the designer Blog.html.
//  Loads real Shopify articles (newest first, across every blog)
//  and lays them out as: a magazine hero with stats, a light
//  featured split card, a filterable archive bar with category
//  tabs + counts, and a 3-up grid of light article cards.
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import ArticleCard from '~/components/cards/ArticleCard.astro';
import Cta from '~/components/sections/Cta.astro';
import Icon from '~/components/ui/Icon.astro';
import { getArticles } from '~/lib/shopify';
import type { ArticleCard as TArticleCard } from '~/lib/shopify/types';

export const prerender = false;

let articles: TArticleCard[] = [];
try {
  const { items } = await getArticles({ first: 25 });
  articles = items;
} catch (err) {
  console.error('[blog] articles load failed:', (err as Error).message);
}

const [featured, ...rest] = articles;

// Category tabs from the grid articles' first tag, with counts.
const catOf = (a: TArticleCard) => a.tags?.[0] ?? a.blogTitle ?? 'Journal';
const counts = new Map<string, number>();
for (const a of rest) counts.set(catOf(a), (counts.get(catOf(a)) ?? 0) + 1);
const categories = [...counts.entries()].map(([name, count]) => ({ name, count }));

// Featured meta
const featCat = featured ? catOf(featured) : '';
const featDate = featured?.publishedAt
  ? new Date(featured.publishedAt).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : '';
const featAuthor = featured?.author?.name ?? 'The Editors';
const featInitials = featAuthor
  .split(' ')
  .map((p) => p[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<BaseLayout
  title="Journal"
  description="Stories from the house — the people, places and process behind each collection. Read like a magazine, written with intention."
>
  {/* ===================== JOURNAL HERO ===================== */}
  <section class="py-hero">
    <div class="container-mag" data-enter data-stagger>
      <span class="mag-label mb-[18px]">The Journal · Issue N°02</span>
      <div class="flex flex-col items-start justify-between gap-10 lg:flex-row">
        <h1 class="h1 uppercase">
          The <em class="not-italic text-coral">Journal.</em>
        </h1>
        <p class="max-w-[430px] pt-3 text-base leading-[1.65] text-text-secondary">
          Stories from the house — the people, places and process behind each collection. Read like a
          magazine, written with intention.
        </p>
      </div>
      <div class="mt-[34px] flex flex-wrap items-start gap-[18px]">
        {
          [
            { b: '120', plus: true, s: 'Stories' },
            { b: 'Weekly', s: 'New Reads' },
            { b: '6', s: 'Columns' },
            { b: '2014', s: 'Since' },
          ].map((st, i) => (
            <div class:list={['pr-[18px]', i < 3 && 'border-r border-border']}>
              <b class="block font-heading text-[34px] font-extrabold leading-[0.9]">
                {st.b}
                {st.plus && <em class="not-italic text-coral">+</em>}
              </b>
              <span class="mt-[7px] block text-[10.5px] font-semibold uppercase tracking-[1.4px] text-text-muted">
                {st.s}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    articles.length === 0 ? (
      <section class="bg-surface py-section">
        <div class="container-mag flex flex-col items-center text-center">
          <span class="mb-4 grid h-16 w-16 place-items-center rounded-pill bg-surface-cool text-text-muted">
            <Icon name="pencil" size={26} />
          </span>
          <h2 class="h3">No stories yet</h2>
          <p class="mt-3 max-w-[420px] text-text-secondary">
            The journal is being written. Check back soon for cover features, interviews and style
            notes.
          </p>
          <a
            href="/products"
            class="btn mt-6 inline-flex h-12 items-center gap-2 rounded-sm bg-dark px-6 text-white transition-fluid hover:bg-dark-hover"
          >
            Explore the collections <Icon name="arrowRight" size={16} />
          </a>
        </div>
      </section>
    ) : (
      <>
        {/* ===================== FEATURED ===================== */}
        {featured && (
          <section class="pt-[18px] pb-1.5">
            <div class="container-mag">
              <article
                class="grid grid-cols-1 overflow-hidden rounded-xl bg-surface shadow-sm lg:grid-cols-[1.12fr_0.88fr]"
                data-reveal
              >
                <a
                  href={`/blog/${featured.handle}`}
                  class="relative block min-h-[320px] overflow-hidden bg-surface-cool lg:min-h-[clamp(360px,46vw,520px)]"
                >
                  <span class="absolute left-5 top-5 z-[2] inline-flex items-center gap-[7px] rounded-pill bg-coral px-[15px] py-2 text-[11px] font-extrabold uppercase tracking-[1.5px] text-white shadow-sm">
                    <Icon name="star" size={13} /> Featured Story
                  </span>
                  {featured.image ? (
                    <img
                      src={featured.image.url}
                      alt={featured.image.altText ?? featured.title}
                      loading="eager"
                      class="h-full w-full object-cover"
                    />
                  ) : (
                    <span class="grid h-full place-items-center bg-gradient-to-br from-coral-soft via-surface-cool to-blue-soft">
                      <span class="font-heading text-4xl font-bold text-text-muted/50">TAILORED</span>
                    </span>
                  )}
                </a>

                <div class="p-[clamp(30px,3.4vw,52px)]">
                  <div class="mb-4 flex items-center gap-3 text-[11px] font-extrabold uppercase tracking-[1.6px] text-coral">
                    <span>{featCat}</span>
                    <span class="h-1 w-1 rounded-pill bg-text-muted" />
                    <span class="text-text-muted">{featured.readMinutes} min read</span>
                  </div>
                  <h2 class="mb-[18px] font-heading text-[clamp(32px,3.4vw,52px)] font-extrabold leading-[0.96] tracking-[-0.5px]">
                    <a href={`/blog/${featured.handle}`} class="transition-fluid hover:text-coral">
                      {featured.title}
                    </a>
                  </h2>
                  <p class="mb-[26px] max-w-[48ch] text-base leading-[1.7] text-text-secondary">
                    {featured.excerpt}
                  </p>
                  <div class="mb-[26px] flex items-center gap-3">
                    <span class="grid h-11 w-11 place-items-center rounded-pill bg-dark text-[13px] font-bold text-white">
                      {featInitials}
                    </span>
                    <div>
                      <b class="block text-[13.5px] font-bold text-text-primary">{featAuthor}</b>
                      <span class="text-xs text-text-muted">{featDate}</span>
                    </div>
                  </div>
                  <a
                    href={`/blog/${featured.handle}`}
                    class="read-link inline-flex items-center gap-[9px] text-xs font-extrabold uppercase tracking-[1.2px] text-text-primary transition-[gap,color] duration-200 hover:gap-3.5 hover:text-coral"
                  >
                    Read the Story <Icon name="arrowRight" size={16} />
                  </a>
                </div>
              </article>
            </div>
          </section>
        )}

        {/* ===================== FILTER + GRID ===================== */}
        <section class="pb-section-sm">
          <div class="container-mag">
            <div class="flex flex-wrap items-end justify-between gap-[18px] pt-[52px] pb-[22px]">
              <div data-reveal>
                <span class="mag-label mb-3.5">The Archive</span>
                <h2 class="font-heading text-[clamp(30px,3.4vw,46px)] font-extrabold leading-[0.95] tracking-[-0.5px]">
                  Latest <em class="not-italic text-coral">Stories</em>
                </h2>
              </div>
              <div class="inline-flex items-center gap-2 pb-[5px] text-[13px] font-semibold text-text-secondary">
                <Icon name="files" size={17} class="text-coral" />
                <span data-blog-count>Showing {rest.length} of {rest.length} stories</span>
              </div>
            </div>

            {/* Category tabs */}
            <div
              class="mb-8 flex flex-wrap items-center gap-2 border-b border-border pb-[26px]"
              role="group"
              aria-label="Filter by column"
              data-blog-tabs
            >
              <button
                type="button"
                data-cat="all"
                aria-pressed="true"
                class="btab inline-flex items-center gap-2 rounded-pill px-[15px] py-[9px] text-[12.5px] font-semibold ring-1 ring-inset ring-border transition-fluid"
              >
                All <span class="tc rounded-pill px-2 py-0.5 text-[10.5px] font-bold">{rest.length}</span>
              </button>
              {categories.map((c) => (
                <button
                  type="button"
                  data-cat={c.name.toLowerCase()}
                  aria-pressed="false"
                  class="btab inline-flex items-center gap-2 rounded-pill px-[15px] py-[9px] text-[12.5px] font-semibold ring-1 ring-inset ring-border transition-fluid hover:ring-text-muted"
                >
                  {c.name}{' '}
                  <span class="tc rounded-pill px-2 py-0.5 text-[10.5px] font-bold">{c.count}</span>
                </button>
              ))}
            </div>

            <div class="grid grid-cols-1 gap-7 sm:grid-cols-2 lg:grid-cols-3" data-reveal data-blog-grid>
              {rest.map((article, i) => (
                <ArticleCard article={article} eager={i < 3} />
              ))}
            </div>

            <p data-blog-empty class="hidden py-[50px] text-center text-sm text-text-muted">
              No stories in this column yet — check back soon.
            </p>
          </div>
        </section>
      </>
    )
  }

  <Cta />

  {/* ===================== BLOG FILTER LOGIC ===================== */}
  <script>
    // Client-side category filtering for the archive grid + live count.
    // Idempotent + View-Transition safe; no network.
    function initBlogFilters(): void {
      const bar = document.querySelector<HTMLElement>('[data-blog-tabs]');
      const grid = document.querySelector<HTMLElement>('[data-blog-grid]');
      if (!bar || !grid || bar.dataset.bound) return;
      bar.dataset.bound = 'true';

      const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-article-card]'));
      const empty = document.querySelector<HTMLElement>('[data-blog-empty]');
      const countEl = document.querySelector<HTMLElement>('[data-blog-count]');
      const pills = Array.from(bar.querySelectorAll<HTMLButtonElement>('[data-cat]'));
      const total = cards.length;

      const apply = (cat: string): void => {
        let shown = 0;
        cards.forEach((card) => {
          const match = cat === 'all' || card.dataset.category === cat;
          card.style.display = match ? '' : 'none';
          if (match) shown++;
        });
        if (empty) empty.classList.toggle('hidden', shown > 0);
        if (countEl) {
          countEl.textContent = `Showing ${shown} of ${total} ${shown === 1 ? 'story' : 'stories'}`;
        }
        pills.forEach((p) => p.setAttribute('aria-pressed', String(p.dataset.cat === cat)));
      };

      bar.addEventListener('click', (e) => {
        const pill = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-cat]');
        if (pill) apply(pill.dataset.cat ?? 'all');
      });
    }

    initBlogFilters();
    document.addEventListener('astro:page-load', initBlogFilters);
  </script>
</BaseLayout>

<style>
  /* Active tab — coral fill + white count badge (designer .btab.on). */
  .btab .tc {
    background: var(--color-surface-cool);
    color: var(--color-text-muted);
    transition: all 0.2s;
  }
  .btab:hover .tc {
    color: var(--color-text-primary);
  }
  .btab[aria-pressed='true'] {
    background: var(--color-coral);
    color: #fff;
    box-shadow: none;
    --tw-ring-color: transparent;
  }
  .btab[aria-pressed='true'] .tc {
    background: rgba(255, 255, 255, 0.26);
    color: #fff;
  }
</style>
