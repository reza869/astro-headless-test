---
// ============================================================
//  /wishlist — the customer's saved edit. The wishlist is a
//  client-only store (product gids in localStorage), so we SSR
//  the full catalogue as hidden ProductCards and let a small
//  controller reveal only the saved ones, live-update the count,
//  and swap in an on-brand empty state. Chrome + motion come from
//  BaseLayout; cards are the theme's own ProductCard (its heart
//  doubles as the "remove" control). No new data plumbing — the
//  same enriched catalogue the /collections/all page already uses.
//  (Client-only + demo-scale: fine to embed the catalogue; a large
//  store would fetch the saved ids on demand instead.)
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProductCard from '~/components/cards/ProductCard.astro';
import Icon from '~/components/ui/Icon.astro';
import { getShopProducts } from '~/lib/shopify';
import type { ProductCard as ProductCardType } from '~/lib/shopify/types';

let products: ProductCardType[] = [];
let loadError = false;
try {
  products = await getShopProducts({ pageSize: 48 });
} catch (err) {
  console.error('[wishlist] catalogue load failed:', (err as Error).message);
  loadError = true;
}

const description = 'Your saved edit — the pieces you are keeping an eye on at TAILORED.';
---

<BaseLayout title="Wishlist" description={description} noindex>
  {/* ── Hero ─────────────────────────────────────────────── */}
  <section class="container-mag pb-3.5 pt-10 md:pt-[34px]">
    <span class="mb-[18px] flex w-fit items-center gap-[11px] text-[11px] font-extrabold uppercase tracking-[2.6px] text-text-primary">
      <span class="text-[14px] leading-none text-coral">✦</span>Saved · Your Edit
      <span class="h-px w-6 bg-border"></span>
    </span>

    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between lg:gap-10">
      <h1 class="font-heading text-[clamp(54px,7.2vw,112px)] font-extrabold uppercase leading-[0.8] tracking-[-1.5px]">
        The <em class="not-italic text-coral">Wishlist.</em>
      </h1>
      <p class="max-w-[430px] pt-3 text-[16px] leading-[1.65] text-text-secondary">
        Every piece you have saved, kept in one place. Tap the heart on any card to remove it, or
        <a href="/collections/all" class="font-semibold text-coral underline underline-offset-[3px]">keep shopping</a>.
      </p>
    </div>

    {/* Count + clear — only shown when the list has items */}
    <div
      class="mt-[34px] flex flex-wrap items-center gap-x-6 gap-y-4"
      data-wishlist-toolbar
      hidden
    >
      <div class="pr-[18px] shadow-[inset_-1px_0_0_var(--color-border)]">
        <b class="block font-heading text-[34px] font-extrabold leading-[0.9]" data-wishlist-count>00</b>
        <span class="mt-[7px] block text-[10.5px] font-semibold uppercase tracking-[1.4px] text-text-muted">
          Saved Pieces
        </span>
      </div>
      <button
        type="button"
        data-wishlist-clear
        class="inline-flex items-center gap-2 rounded-sm border border-border px-4 py-2.5 text-[11px] font-bold uppercase tracking-[1.4px] text-text-secondary transition-fluid hover:border-coral hover:text-coral"
      >
        <Icon name="close" size={14} /> Clear all
      </button>
    </div>
  </section>

  {/* ── Grid (all catalogue, hidden; controller reveals saved) ── */}
  <section class="container-mag pb-section pt-section-sm">
    <div
      id="wishlistGrid"
      class="grid grid-cols-2 gap-x-4 gap-y-8 sm:gap-x-5 sm:gap-y-9 lg:grid-cols-3 xl:grid-cols-4"
      hidden
    >
      {
        products.map((product) => (
          <div class="wl-item" data-wishlist-item={product.id} hidden>
            <ProductCard product={product} actionsVisible />
          </div>
        ))
      }
    </div>

    {/* ── Empty / fallback state ─────────────────────────── */}
    <div
      id="wishlistEmpty"
      class="mx-auto flex max-w-[520px] flex-col items-center rounded-xl border border-border bg-surface px-6 py-20 text-center md:py-24"
      hidden
    >
      <span class="mb-5 grid h-[68px] w-[68px] place-items-center rounded-full bg-coral-soft text-coral">
        <Icon name="heart" size={30} />
      </span>
      <h2 class="font-heading text-[28px] font-bold leading-[1.05] text-text-primary md:text-[34px]">
        {loadError ? 'Wishlist unavailable' : 'Your wishlist is empty'}
      </h2>
      <p class="mt-3 max-w-[380px] text-[14.5px] leading-[1.6] text-text-secondary">
        {
          loadError
            ? 'We could not load your saved pieces right now. Please try again shortly.'
            : 'Save the pieces you love by tapping the heart on any product — they will land here so you never lose track.'
        }
      </p>
      <a
        href="/collections/all"
        class="mt-7 inline-flex items-center justify-center gap-2.5 rounded-sm bg-dark px-[26px] py-[15px] text-[12.5px] font-bold uppercase tracking-[1.4px] text-white transition-fluid hover:bg-coral"
      >
        Explore the catalogue <Icon name="arrowRight" size={16} />
      </a>
    </div>
  </section>

  {/* ============================================================
       Wishlist controller — reveals only the saved cards from the
       SSR catalogue, keeps the count/clear toolbar in sync, and
       swaps the empty state in/out. Reactive to the shared store,
       so removing a card here (or from anywhere) updates instantly.
       Idempotent + View-Transition safe.
       ============================================================ */}
  <script>
    import { $wishlist, clearWishlist } from '~/stores/wishlist';

    function pad(n: number): string {
      return String(n).padStart(2, '0');
    }

    function renderWishlist(ids: readonly string[]): void {
      const grid = document.getElementById('wishlistGrid');
      const empty = document.getElementById('wishlistEmpty');
      if (!grid || !empty) return;

      const saved = new Set(ids);
      let shown = 0;
      grid.querySelectorAll<HTMLElement>('.wl-item').forEach((el) => {
        const inList = saved.has(el.dataset.wishlistItem ?? '');
        el.hidden = !inList;
        if (inList) shown += 1;
      });

      const hasItems = shown > 0;
      grid.hidden = !hasItems;
      empty.hidden = hasItems;
      document
        .querySelectorAll<HTMLElement>('[data-wishlist-toolbar]')
        .forEach((t) => (t.hidden = !hasItems));
      document
        .querySelectorAll<HTMLElement>('[data-wishlist-count]')
        .forEach((c) => (c.textContent = pad(shown)));
    }

    function initWishlistPage(): void {
      // Paint against the current store on every load (fresh DOM after a
      // View Transition), then bind the reactive + click handlers once.
      renderWishlist($wishlist.get());

      if (document.documentElement.dataset.wishlistPageBound) return;
      document.documentElement.dataset.wishlistPageBound = 'true';

      $wishlist.subscribe((ids) => renderWishlist(ids));

      document.addEventListener('click', (e) => {
        const clear = (e.target as HTMLElement).closest('[data-wishlist-clear]');
        if (!clear) return;
        e.preventDefault();
        clearWishlist();
        window.dispatchEvent(new CustomEvent('wishlist-updated')); // header badge
      });
    }

    initWishlistPage();
    document.addEventListener('astro:page-load', initWishlistPage);
  </script>
</BaseLayout>
