---
// ============================================================
//  /collections/[handle] — a single collection with the EXACT
//  design + functionality of /collections/all. The only diffs:
//  the hero shows this collection's title + description (clamped
//  to 3 lines), and the control deck opens with this collection's
//  tab active + the grid filtered to its products. Everything else
//  (deck, refine, sort, grid, CTA, islands) is the shared
//  ShopCatalogue component.
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import ShopCatalogue from '~/components/shop/ShopCatalogue.astro';
import { getCollection } from '~/lib/shopify';
import { toShopItems, catalogueCurrency } from '~/lib/shop-catalogue';
import type { CollectionWithProducts } from '~/lib/shopify/types';

const { handle } = Astro.params;

// Fetch THIS collection's own products (scoped + enriched), not a global slice.
// A missing collection returns null → a real 404; an out-of-range handle no
// longer has to be inferred from a truncated best-sellers list.
let collection: CollectionWithProducts | null = null;
let loadError = false;
try {
  collection = await getCollection({ handle: handle!, pageSize: 250 });
} catch (err) {
  console.error('[collection] load failed:', (err as Error).message);
  loadError = true;
}

const notFound = !loadError && !collection;
if (loadError) Astro.response.status = 503;
else if (notFound) Astro.response.status = 404;

const raw = collection?.products.items ?? [];
const items = toShopItems(raw);
const currency = catalogueCurrency(raw);

const title = collection?.title ?? (handle ?? '').replace(/-/g, ' ');
const description = (collection?.description ?? '').trim();
// Pre-activate this collection's Browse tab (all loaded items belong to it).
const initialCat = collection?.title ?? null;

// Stats for this collection's products.
const products = items.length;
const designers = new Set(items.map((i) => i.vendor).filter(Boolean)).size;
const categories = new Set(items.flatMap((i) => i.cats)).size;

const esc = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

const hero = {
  eyebrow: 'Collection · Issue N°02',
  titleHtml: `${esc(title)}<em class="not-italic text-coral">.</em>`,
  intro:
    description ||
    `Explore the ${title} edit — ${products} piece${products === 1 ? '' : 's'}, hand-selected and editor-styled.`,
  clampIntro: true,
  products,
  designers,
  categories,
};
---

{
  notFound ? (
    <BaseLayout title="Collection not found">
      <div class="container-mag flex flex-col items-center py-28 text-center">
        <span class="mag-label mb-3">Error 404</span>
        <h1 class="h2">Collection not found</h1>
        <p class="mt-3 text-text-secondary">We couldn't find that collection.</p>
        <a
          href="/collections"
          class="mt-6 inline-flex items-center justify-center gap-2.5 rounded-xs bg-dark px-[26px] py-[15px] text-[12.5px] font-bold uppercase tracking-[1.4px] text-white transition-colors duration-300 hover:bg-dark-hover"
        >
          All collections
        </a>
      </div>
    </BaseLayout>
  ) : (
    <BaseLayout title={title} description={description || `Shop the ${title} collection.`}>
      <ShopCatalogue
        items={items}
        currency={currency}
        hero={hero}
        initialCat={initialCat}
        loadError={loadError}
        errorTitle="Collection unavailable"
        errorBody="We couldn't load this collection right now. Please try again shortly."
      />
    </BaseLayout>
  )
}
