---
// ============================================================
//  Terms & Conditions — the store's legal terms. Pulls the live
//  Terms of Service straight from Shopify (Settings → Policies) so
//  merchants edit it in one place and the storefront mirrors it
//  automatically. When no policy is set, a well-structured default
//  is rendered instead, so the page never dead-ends. Either way it
//  shares the theme's editorial hero, sticky table-of-contents rail
//  (with scrollspy) and closing CTA.
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import Icon from '~/components/ui/Icon.astro';
import { getShopPolicy } from '~/lib/shopify';
import { SITE } from '~/config/site';

const SUPPORT_EMAIL = 'care@ledition.com';
const LAST_UPDATED = 'July 1, 2026';

interface TocEntry {
  id: string;
  label: string;
}
interface Section {
  id: string;
  title: string;
  /** Inner HTML for the section body (paragraphs / lists). */
  html: string;
}

/** URL/anchor-safe slug from a heading's text. */
function slugify(text: string): string {
  return text
    .toLowerCase()
    .replace(/&[a-z]+;/g, ' ')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 60) || 'section';
}

/** Turn a SHOUTING legal heading into a refined, on-brand one, e.g.
 *  "SECTION 1 - ONLINE STORE TERMS" → "1. Online Store Terms". */
function prettyHeading(raw: string): string {
  const titleCase = (s: string): string =>
    s.toLowerCase().replace(/\b([a-z])/g, (_, c: string) => c.toUpperCase());
  const m = raw.match(/^section\s+(\d+)\s*[-–]\s*(.+)$/i);
  return m ? `${m[1]}. ${titleCase(m[2])}` : titleCase(raw);
}

// ── Load the live policy from Shopify (null when unset) ──────────
const policy = await getShopPolicy('termsOfService');

// ── Maintainable fallback — edit these sections to update the
//    on-site terms when no Shopify policy is configured. ──────────
const fallbackSections: Section[] = [
  {
    id: 'introduction',
    title: '1. Introduction',
    html: `
      <p>Welcome to ${SITE.name}. These Terms &amp; Conditions ("Terms") govern your access to
      and use of our website, products and services (together, the "Service"). By browsing,
      creating an account or placing an order, you agree to be bound by these Terms. Please read
      them carefully — if you do not agree, please do not use the Service.</p>
      <p>These Terms should be read alongside our
      <a href="/pages/privacy">Privacy Policy</a> and
      <a href="/pages/shipping">Shipping &amp; Returns</a> information, which are incorporated
      here by reference.</p>`,
  },
  {
    id: 'eligibility-accounts',
    title: '2. Eligibility & Accounts',
    html: `
      <p>You must be at least 18 years old, or the age of majority in your jurisdiction, to make
      a purchase. By placing an order you confirm that you meet this requirement and that the
      information you provide is accurate and complete.</p>
      <p>An account is optional — you may check out as a guest. If you do create one, you are
      responsible for:</p>
      <ul>
        <li>maintaining the confidentiality of your login credentials;</li>
        <li>all activity that occurs under your account; and</li>
        <li>notifying us promptly of any unauthorised use.</li>
      </ul>`,
  },
  {
    id: 'orders-acceptance',
    title: '3. Orders & Acceptance',
    html: `
      <p>Your order is an offer to purchase. All orders are subject to acceptance and
      availability; a confirmation email acknowledges receipt but does not constitute
      acceptance. A contract is formed only when we dispatch the items to you.</p>
      <p>We reserve the right to decline or cancel any order — including where a product is
      mispriced, out of stock, or where we suspect fraud — and to limit quantities. If we cancel
      an order you have paid for, you will receive a full refund to your original payment
      method.</p>`,
  },
  {
    id: 'pricing-payment',
    title: '4. Pricing & Payment',
    html: `
      <p>Prices are shown in the currency selected at checkout and are inclusive or exclusive of
      taxes as indicated. We take care to price accurately, but errors can occur; where a product
      is listed at an incorrect price we may cancel the affected order as set out above.</p>
      <p>Payment is taken at the time of order through our secure, PCI-compliant checkout. We
      accept the cards and wallets displayed at checkout. For international orders, any customs
      duties or import taxes are your responsibility unless stated otherwise.</p>`,
  },
  {
    id: 'shipping-delivery',
    title: '5. Shipping & Delivery',
    html: `
      <p>Delivery times and costs are shown at checkout and in our
      <a href="/pages/shipping">Shipping &amp; Returns</a> information. Estimated delivery dates
      are indicative and not guaranteed. Risk of loss passes to you upon delivery to the address
      you provide.</p>
      <p>Complimentary standard shipping applies to orders over $${SITE.freeShippingThreshold}.</p>`,
  },
  {
    id: 'returns-refunds',
    title: '6. Returns, Exchanges & Refunds',
    html: `
      <p>We want you to love your pieces. Unworn items with their original tags may be returned
      within 30 days of delivery for a refund to your original payment method, subject to our
      returns process. Certain items (such as final-sale or personalised pieces) may be
      non-returnable, as noted on their product pages.</p>
      <p>To start a return or exchange, visit your account or contact us. Refunds are processed
      once we receive and inspect the returned item. Full details are set out in our
      <a href="/faq">FAQ</a>.</p>`,
  },
  {
    id: 'products-availability',
    title: '7. Products & Availability',
    html: `
      <p>We work to display our products — including colours and materials — as accurately as
