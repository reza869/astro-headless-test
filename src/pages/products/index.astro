---
// ============================================================
//  /products — the full designed catalogue, identical to
//  /collections/all. Thin wrapper: fetch the enriched catalogue,
//  flatten, and hand it to the shared ShopCatalogue component
//  (hero + control deck + grid + CTA + the client controller).
//  Kept in lock-step with /collections/all so only the route differs.
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import ShopCatalogue from '~/components/shop/ShopCatalogue.astro';
import { getAllShopProducts } from '~/lib/shopify';
import { toShopItems, catalogueCurrency } from '~/lib/shop-catalogue';
import type { ProductCard } from '~/lib/shopify/types';

let raw: ProductCard[] = [];
let loadError = false;
try {
  // Load the full catalogue (paged past the Storefront 250-per-query limit) so
  // every product is reachable and filterable — the deck filters/sorts/paginates
  // client-side over this set.
  raw = await getAllShopProducts();
} catch (err) {
  console.error('[shop] catalogue load failed:', (err as Error).message);
  loadError = true;
}

const items = toShopItems(raw);
const currency = catalogueCurrency(raw);

// Real hero stats (ShopHero falls back to marketing figures when empty).
const designers = new Set(items.map((i) => i.vendor).filter(Boolean)).size;
const categories = new Set(items.flatMap((i) => i.cats)).size;
const hero = items.length ? { products: items.length, designers, categories } : {};
---

<BaseLayout title="Shop" description="The full catalogue — every piece from Issue N°02.">
  <ShopCatalogue items={items} currency={currency} hero={hero} loadError={loadError} />
</BaseLayout>
